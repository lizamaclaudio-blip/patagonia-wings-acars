[WASM]
MODULE_NAME=patagonia-acars-wasm
MODULE_DESCRIPTION=Bridge para leer LVARs de aviones complejos en ACARS
VERSION=1.0.0
ENABLE_LVAR_READ=1

[LVARS_A319_HEADWIND]
; Airbus A319 by Headwind Simulations
; Variables requeridas para lectura completa
A319_Light_Beacon=1
A319_Light_Strobe=1
A319_Light_Landing=1
A319_Light_Nav=1
A319_Light_Taxi=1
A319_Engine_N1_1=1
A319_Engine_N1_2=1
A319_Transponder_Code=1
A319_Cabin_Altitude=1
A319_Cabin_Pressure=1

[LVARS_FENIX_A320]
; Fenix A320
FNX320_LIGHT_BEACON=1
FNX320_LIGHT_STROBE=1
FNX320_LIGHT_LANDING=1
FNX320_ENG_N1_1=1
FNX320_ENG_N1_2=1
FNX320_XPDR_CODE=1

[LVARS_PMDG_737]
; PMDG 737
PMDG_BeaconLight=1
PMDG_StrobeLight=1
PMDG_LandingLight=1

[OUTPUT]
; Prefijo para variables expuestas a SimConnect
PREFIX=MOBIFLIGHT_
UPDATE_RATE=1
