                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TaxiOn}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource LedAmber}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="TAXI" Foreground="#8B949E" FontSize="9" HorizontalAlignment="Center"/>
                                <TextBlock HorizontalAlignment="Center" FontSize="9" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="OFF"/>
                                            <Setter Property="Foreground" Value="#606C7A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TaxiOn}" Value="True">
                                                    <Setter Property="Text" Value="ON"/>
                                                    <Setter Property="Foreground" Value="#FFCC44"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- SEAT BELT -->
                            <StackPanel Grid.Column="5" HorizontalAlignment="Center">
                                <Ellipse Width="20" Height="20" HorizontalAlignment="Center" Margin="0,0,0,5">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource LedOff}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SeatBeltSign}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource LedAmber}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="SEATBELT" Foreground="#8B949E" FontSize="9" HorizontalAlignment="Center"/>
                                <TextBlock HorizontalAlignment="Center" FontSize="9" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="OFF"/>
                                            <Setter Property="Foreground" Value="#606C7A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SeatBeltSign}" Value="True">
                                                    <Setter Property="Text" Value="ON"/>
                                                    <Setter Property="Foreground" Value="#FFCC44"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- NO SMOKING -->
                            <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                                <Ellipse Width="20" Height="20" HorizontalAlignment="Center" Margin="0,0,0,5">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource LedOff}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NoSmokingSign}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource LedAmber}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="NO SMOKE" Foreground="#8B949E" FontSize="9" HorizontalAlignment="Center"/>
                                <TextBlock HorizontalAlignment="Center" FontSize="9" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="OFF"/>
                                            <Setter Property="Foreground" Value="#606C7A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NoSmokingSign}" Value="True">
                                                    <Setter Property="Text" Value="ON"/>
                                                    <Setter Property="Foreground" Value="#FFCC44"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ══ FOOTER ══════════════════════════════════════════════════ -->
