<Window x:Class="PatagoniaWings.Acars.Master.Views.LiveFlightWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:PatagoniaWings.Acars.Master.Helpers"
        Title="Patagonia Wings · Vuelo en Vivo"
        Width="900" Height="600"
        MinWidth="820" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:VSToColorConverter x:Key="VSColor"/>
        <helpers:BoolToColorConverter x:Key="BoolToColor"/>

        <!-- LED brushes -->
        <RadialGradientBrush x:Key="LedGreen" RadiusX="0.6" RadiusY="0.6" GradientOrigin="0.35,0.3">
            <GradientStop Color="#CCFFDD" Offset="0"/>
            <GradientStop Color="#00EE55" Offset="0.4"/>
            <GradientStop Color="#009933" Offset="0.75"/>
            <GradientStop Color="#003311" Offset="1"/>
        </RadialGradientBrush>
        <RadialGradientBrush x:Key="LedRed" RadiusX="0.6" RadiusY="0.6" GradientOrigin="0.35,0.3">
            <GradientStop Color="#FFCCCC" Offset="0"/>
            <GradientStop Color="#FF2222" Offset="0.4"/>
            <GradientStop Color="#BB0000" Offset="0.75"/>
        </RadialGradientBrush>
        <RadialGradientBrush x:Key="LedAmber" RadiusX="0.6" RadiusY="0.6" GradientOrigin="0.35,0.3">
            <GradientStop Color="#FFEECC" Offset="0"/>
            <GradientStop Color="#FFBB00" Offset="0.4"/>
            <GradientStop Color="#CC7700" Offset="0.75"/>
        </RadialGradientBrush>
        <RadialGradientBrush x:Key="LedWhite" RadiusX="0.6" RadiusY="0.6" GradientOrigin="0.35,0.3">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#CCDDEE" Offset="0.5"/>
            <GradientStop Color="#6688AA" Offset="1"/>
        </RadialGradientBrush>
        <RadialGradientBrush x:Key="LedOff" RadiusX="0.5" RadiusY="0.5">
            <GradientStop Color="#2A3040" Offset="0"/>
            <GradientStop Color="#0A0C10" Offset="1"/>
        </RadialGradientBrush>
    </Window.Resources>

    <Border CornerRadius="12" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF080C12" Offset="0"/>
                <GradientStop Color="#FF0A0E16" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ══ TITLEBAR ══════════════════════════════════════════════ -->
            <Border Grid.Row="0" Background="#0F1520" BorderBrush="#1A2840" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                        <!-- Indicador backend vivo -->
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#FF3333"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSimConnected}" Value="True">
                                            <Setter Property="Fill" Value="#00EE55"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="VUELO EN VIVO" Foreground="White" FontSize="12" FontWeight="Bold"
                                   FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="·" Foreground="#252D3A" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding SimBackendDisplay}" Foreground="#2D9CDB"
                                   FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="·" Foreground="#252D3A" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding PhaseLabelDisplay}" Foreground="#8B949E"
                                   FontFamily="Segoe UI" FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding ElapsedTimeDisplay}" Foreground="#0CA789"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Button Content="—" Width="32" Height="30" Background="Transparent"
                                BorderThickness="0" Foreground="#8B949E" FontSize="13" Cursor="Hand"
                                Click="BtnMinimize_Click"/>
                        <Button Content="✕" Width="32" Height="30" BorderThickness="0"
                                Foreground="#8B949E" Cursor="Hand" FontSize="12" Click="BtnClose_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#CC2222"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══ MAIN CONTENT ═══════════════════════════════════════════ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,12">

                <StackPanel>

                    <!-- Alerta strobes -->
                    <Border Background="#7A0E0E" CornerRadius="6" Padding="12,8" Margin="0,0,0,10"
                            Visibility="{Binding AlertNoStrobe, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠ STROBES APAGADOS EN VUELO — PENALIZACIÓN ACTIVA"
                                       Foreground="White" FontWeight="Bold" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- ══ FILA 1: IAS / ALT / HDG / FUEL ════════════════ -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- IAS -->
                        <Border Grid.Column="0" Background="#0D1520" BorderBrush="#1A3A5C" BorderThickness="0,2,0,0" CornerRadius="8" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="IAS" Foreground="#606C7A" FontSize="10" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding IASDisplay}" Foreground="White" FontFamily="Consolas" FontSize="28" FontWeight="Bold"/>
                                    <TextBlock Text="kts" Foreground="#606C7A" FontSize="12" VerticalAlignment="Bottom" Margin="5,0,0,4"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="GS " Foreground="#606C7A" FontSize="10"/>
                                    <TextBlock Text="{Binding GSDisplay}" Foreground="#2D9CDB" FontFamily="Consolas" FontSize="12"/>
                                    <TextBlock Text=" kts" Foreground="#606C7A" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ALT -->
                        <Border Grid.Column="2" Background="#0D1520" BorderBrush="#0CA789" BorderThickness="0,2,0,0" CornerRadius="8" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="ALT" Foreground="#606C7A" FontSize="10" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding AltitudeDisplay}" Foreground="White" FontFamily="Consolas" FontSize="28" FontWeight="Bold"/>
                                    <TextBlock Text="ft" Foreground="#606C7A" FontSize="12" VerticalAlignment="Bottom" Margin="5,0,0,4"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="VS " Foreground="#606C7A" FontSize="10"/>
                                    <TextBlock Text="{Binding VSDisplay}"
                                               Foreground="{Binding VS, Converter={StaticResource VSColor}}"
                                               FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text=" fpm" Foreground="#606C7A" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- HDG + POS -->
                        <Border Grid.Column="4" Background="#0D1520" BorderBrush="#252D3A" BorderThickness="0,2,0,0" CornerRadius="8" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="HDG / POSICIÓN" Foreground="#606C7A" FontSize="10" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Heading, StringFormat={}{0:000}°}"
                                           Foreground="White" FontFamily="Consolas" FontSize="28" FontWeight="Bold" Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding Lat, StringFormat=Lat {0:F4}°}" Foreground="#606C7A" FontFamily="Consolas" FontSize="10" Margin="0,4,0,1"/>
                                <TextBlock Text="{Binding Lon, StringFormat=Lon {0:F4}°}" Foreground="#606C7A" FontFamily="Consolas" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <!-- FUEL -->
                        <Border Grid.Column="6" Background="#0D1520" BorderBrush="#CC8800" BorderThickness="0,2,0,0" CornerRadius="8" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="COMBUSTIBLE" Foreground="#606C7A" FontSize="10" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding FuelKgDisplay}" Foreground="White" FontFamily="Consolas" FontSize="28" FontWeight="Bold"/>
                                    <TextBlock Text="kg" Foreground="#606C7A" FontSize="12" VerticalAlignment="Bottom" Margin="5,0,0,4"/>
                                </StackPanel>
                                <TextBlock Foreground="#606C7A" FontFamily="Consolas" FontSize="10" Margin="0,4,0,0">
                                    <Run Text="{Binding FuelLbsDisplay}"/>
                                    <Run Text=" lbs"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ══ FILA 2: MOTORES + AMBIENTE + AVIÓNICA ══════════ -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- MOTORES -->
                        <Border Grid.Column="0" Background="#0D1520" BorderBrush="#252D3A" BorderThickness="1" CornerRadius="8" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="MOTORES N1 %" Foreground="#606C7A" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="ENG 1 " Foreground="#606C7A" FontSize="11" Width="48" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding N1Eng1Display}" Foreground="#2D9CDB"
                                               FontFamily="Consolas" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="%" Foreground="#606C7A" FontSize="11" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="ENG 2 " Foreground="#606C7A" FontSize="11" Width="48" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding N1Eng2Display}" Foreground="#2D9CDB"
                                               FontFamily="Consolas" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="%" Foreground="#606C7A" FontSize="11" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                </StackPanel>
                                <!-- AP/REV badges -->
                                <StackPanel Orientation="Horizontal">
                                    <Border CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1A0808"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AutopilotOn}" Value="True">
                                                        <Setter Property="Background" Value="#081A0E"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10" FontWeight="Bold" FontFamily="Consolas">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="AP OFF"/>
                                                    <Setter Property="Foreground" Value="#FF4444"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AutopilotOn}" Value="True">
                                                            <Setter Property="Text" Value="AP ON"/>
                                                            <Setter Property="Foreground" Value="#3FB950"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#0A0A0A"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ReverserActive}" Value="True">
                                                        <Setter Property="Background" Value="#1A1000"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10" FontWeight="Bold" FontFamily="Consolas">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="REV"/>
                                                    <Setter Property="Foreground" Value="#2A3040"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ReverserActive}" Value="True">
                                                            <Setter Property="Text" Value="REV ON"/>
                                                            <Setter Property="Foreground" Value="#FFAA00"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- AMBIENTE -->
                        <Border Grid.Column="2" Background="#0D1520" BorderBrush="#252D3A" BorderThickness="1" CornerRadius="8" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="AMBIENTE" Foreground="#606C7A" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="OAT  " Foreground="#606C7A" FontSize="11" Width="52" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding OAT, StringFormat={}{0:F1} °C}" Foreground="#2D9CDB" FontFamily="Consolas" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="WIND " Foreground="#606C7A" FontSize="11" Width="52" VerticalAlignment="Center"/>
                                    <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#2D9CDB">
                                        <Run Text="{Binding WindDir, StringFormat={}{0:000}}"/>
                                        <Run Text="°/"/><Run Text="{Binding WindSpeed, StringFormat={}{0:F0}}"/>
                                        <Run Text="kt"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="FLAP " Foreground="#606C7A" FontSize="11" Width="52" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding FlapsDisplay}" Foreground="#FFCC44" FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="SQWK " Foreground="#606C7A" FontSize="11" Width="52" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SquawkDisplay}" Foreground="#FFCC44" FontFamily="Consolas" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Margin="6,0,0,0" FontFamily="Consolas" FontSize="10" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="STBY"/>
                                                <Setter Property="Foreground" Value="#606C7A"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CharlieMode}" Value="True">
                                                        <Setter Property="Text" Value="C"/>
                                                        <Setter Property="Foreground" Value="#3FB950"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- PRESURIZACIÓN + TREN -->
                        <Border Grid.Column="4" Background="#0D1520" BorderBrush="#252D3A" BorderThickness="1" CornerRadius="8" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="PRESURIZACIÓN / TREN" Foreground="#606C7A" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="CABIN " Foreground="#606C7A" FontSize="11" Width="52" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CabinAlt, StringFormat={}{0:F0} ft}" Foreground="#0CA789" FontFamily="Consolas" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="ΔPSI  " Foreground="#606C7A" FontSize="11" Width="52" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PressDiff, StringFormat={}{0:F2} psi}" Foreground="#0CA789" FontFamily="Consolas" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="GEAR  " Foreground="#606C7A" FontSize="11" Width="52" VerticalAlignment="Center"/>
                                    <TextBlock FontFamily="Consolas" FontSize="12" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="UP"/>
                                                <Setter Property="Foreground" Value="#606C7A"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GearDown}" Value="True">
                                                        <Setter Property="Text" Value="DOWN"/>
                                                        <Setter Property="Foreground" Value="#3FB950"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GearTransitioning}" Value="True">
                                                        <Setter Property="Text" Value="TRANSIT"/>
                                                        <Setter Property="Foreground" Value="#FFCC44"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="GND   " Foreground="#606C7A" FontSize="11" Width="52" VerticalAlignment="Center"/>
                                    <TextBlock FontFamily="Consolas" FontSize="12" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="AIRBORNE"/>
                                                <Setter Property="Foreground" Value="#3FB950"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding OnGround}" Value="True">
                                                        <Setter Property="Text" Value="ON GND"/>
                                                        <Setter Property="Foreground" Value="#FFCC44"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ══ PANEL DE LUCES EN VIVO ═════════════════════════ -->
                    <Border Background="#090D14" BorderBrush="#141C28" BorderThickness="1" CornerRadius="8" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- STROBE -->
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <Ellipse Width="20" Height="20" HorizontalAlignment="Center" Margin="0,0,0,5">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource LedOff}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StrobeOn}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource LedWhite}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="STROBE" Foreground="#8B949E" FontSize="9" HorizontalAlignment="Center"/>
                                <TextBlock HorizontalAlignment="Center" FontSize="9" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="OFF"/>
                                            <Setter Property="Foreground" Value="#FF4444"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StrobeOn}" Value="True">
                                                    <Setter Property="Text" Value="ON"/>
                                                    <Setter Property="Foreground" Value="#3FB950"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- BEACON -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <Ellipse Width="20" Height="20" HorizontalAlignment="Center" Margin="0,0,0,5">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource LedOff}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding BeaconOn}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource LedRed}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="BEACON" Foreground="#8B949E" FontSize="9" HorizontalAlignment="Center"/>
                                <TextBlock HorizontalAlignment="Center" FontSize="9" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="OFF"/>
                                            <Setter Property="Foreground" Value="#606C7A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding BeaconOn}" Value="True">
                                                    <Setter Property="Text" Value="ON"/>
                                                    <Setter Property="Foreground" Value="#FF4444"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- NAV -->
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <Ellipse Width="20" Height="20" HorizontalAlignment="Center" Margin="0,0,0,5">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource LedOff}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NavOn}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource LedGreen}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="NAV" Foreground="#8B949E" FontSize="9" HorizontalAlignment="Center"/>
                                <TextBlock HorizontalAlignment="Center" FontSize="9" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="OFF"/>
                                            <Setter Property="Foreground" Value="#606C7A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NavOn}" Value="True">
                                                    <Setter Property="Text" Value="ON"/>
                                                    <Setter Property="Foreground" Value="#3FB950"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- LANDING -->
                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <Ellipse Width="20" Height="20" HorizontalAlignment="Center" Margin="0,0,0,5">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource LedOff}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LandingOn}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource LedWhite}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="LANDING" Foreground="#8B949E" FontSize="9" HorizontalAlignment="Center"/>
                                <TextBlock HorizontalAlignment="Center" FontSize="9" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="OFF"/>
                                            <Setter Property="Foreground" Value="#606C7A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LandingOn}" Value="True">
                                                    <Setter Property="Text" Value="ON"/>
                                                    <Setter Property="Foreground" Value="#CCDDFF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- TAXI -->
                            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                <Ellipse Width="20" Height="20" HorizontalAlignment="Center" Margin="0,0,0,5">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
