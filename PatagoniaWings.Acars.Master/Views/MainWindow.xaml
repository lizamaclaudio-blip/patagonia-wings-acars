<Window x:Class="PatagoniaWings.Acars.Master.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pages="clr-namespace:PatagoniaWings.Acars.Master.Views.Pages"
        xmlns:vm="clr-namespace:PatagoniaWings.Acars.Master.ViewModels"
        Title="Patagonia Wings ACARS"
        Width="300"
        Height="730"
        MinWidth="292"
        MinHeight="720"
        MaxWidth="306"
        MaxHeight="736"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Grid Background="Transparent">
        <Border Margin="8"
                CornerRadius="22"
                BorderBrush="#243141"
                BorderThickness="1"
                Background="{StaticResource WindowBackgroundBrush}"
                Effect="{StaticResource PanelShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="68"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="26"/>
                </Grid.RowDefinitions>

                <Grid Grid.RowSpan="3" IsHitTestVisible="False">
                    <Ellipse Width="210" Height="210" Fill="#162D4864" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-90,-70,0,0"/>
                    <Ellipse Width="150" Height="150" Fill="#0D0F1825" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-60,-48"/>
                </Grid>

                <Border Grid.Row="0"
                        Background="#0A121A"
                        BorderBrush="#1C2A39"
                        BorderThickness="0,0,0,1"
                        CornerRadius="22,22,0,0"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="11,9,9,9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="32"
                                Height="32"
                                CornerRadius="16"
                                BorderBrush="#335173"
                                BorderThickness="1"
                                Background="#0E1824"
                                VerticalAlignment="Center">
                            <Image Source="pack://application:,,,/Assets/patagonia-logo.png"
                                   Width="18"
                                   Height="18"
                                   Stretch="Uniform"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="10,0,6,0" VerticalAlignment="Center">
                            <TextBlock Text="PATAGONIA WINGS"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="9.5"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding HeaderTitle}"
                                       Foreground="{StaticResource AccentLightBlueBrush}"
                                       FontSize="9.5"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <Border Grid.Column="2"
                                Background="#111B28"
                                BorderBrush="#2A3E57"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="7,3"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0">
                            <TextBlock Text="{Binding StepBadge}"
                                       Foreground="{StaticResource AccentBlueBrush}"
                                       FontSize="8.5"
                                       FontWeight="Bold"/>
                        </Border>

                        <Button Grid.Column="3"
                                Width="22"
                                Height="22"
                                Margin="0,0,6,0"
                                Background="#111A25"
                                BorderBrush="#243141"
                                BorderThickness="1"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                FontSize="9"
                                Click="BtnMinimize_Click"
                                Content="-"/>

                        <Button Grid.Column="4"
                                Width="22"
                                Height="22"
                                Background="#231417"
                                BorderBrush="#5A3137"
                                BorderThickness="1"
                                Foreground="#FFD3D3"
                                FontSize="8.5"
                                Click="BtnClose_Click"
                                Content="X"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Padding="10,10,10,8"
                        Background="#93081119">
                    <ContentControl x:Name="ShellContentHost">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:AcarsShellStep.Login}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <pages:LoginPage/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:AcarsShellStep.PilotLounge}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <pages:DashboardPage/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:AcarsShellStep.NoDispatch}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <pages:NoDispatchPage/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:AcarsShellStep.Dispatch}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <pages:PreFlightPage/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:AcarsShellStep.LiveFlight}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <pages:InFlightPage/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:AcarsShellStep.CloseFlight}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <pages:PostFlightPage/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:AcarsShellStep.Support}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <pages:SupportPage/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </Border>

                <Border Grid.Row="2"
                        Background="#0A121A"
                        BorderBrush="#1C2A39"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,22,22">
                    <Grid Margin="10,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Ellipse Width="8"
                                 Height="8"
                                 Fill="#59D98B"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding FooterStatus}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="8.5"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>

                        <TextBlock Grid.Column="2"
                                   Text="ACARS 6.0"
                                   Foreground="{StaticResource AccentBlueBrush}"
                                   FontSize="8.5"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
