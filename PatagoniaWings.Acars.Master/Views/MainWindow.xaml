<Window x:Class="PatagoniaWings.Acars.Master.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pages="clr-namespace:PatagoniaWings.Acars.Master.Views.Pages"
        xmlns:vm="clr-namespace:PatagoniaWings.Acars.Master.ViewModels"
        Title="Patagonia Wings ACARS"
        Width="318"
        Height="760"
        MinWidth="310"
        MinHeight="750"
        MaxWidth="326"
        MaxHeight="768"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Grid Background="Transparent">
        <Border Margin="8"
                CornerRadius="20"
                BorderBrush="#C2D8EF"
                BorderThickness="1.5"
                Background="{StaticResource WindowBackgroundBrush}"
                Effect="{StaticResource PanelShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="62"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <!-- TITLE BAR -->
                <Border Grid.Row="0"
                        Background="#FFFFFF"
                        BorderBrush="#D4E8F8"
                        BorderThickness="0,0,0,1.5"
                        CornerRadius="20,20,0,0"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="12,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Logo sin borde ni fondo -->
                        <Image Source="pack://application:,,,/Assets/patagonia-logo.png"
                               Width="34"
                               Height="34"
                               Stretch="Uniform"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>

                        <!-- Brand + page title -->
                        <StackPanel Grid.Column="1" Margin="10,0,6,0" VerticalAlignment="Center">
                            <TextBlock Text="PATAGONIA WINGS"
                                       Foreground="#0D1F3C"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"/>
                            <TextBlock Text="{Binding HeaderTitle}"
                                       Foreground="#1565C0"
                                       FontSize="9"
                                       FontFamily="Segoe UI"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Step badge — solo visible si no es paso auxiliar -->
                        <Border Grid.Column="2"
                                Background="#E0EDFF"
                                BorderBrush="#90B4D8"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="8,3"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                Visibility="{Binding StepBadge, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Text="{Binding StepBadge}"
                                       Foreground="#1565C0"
                                       FontSize="8.5"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"/>
                        </Border>

                        <!-- Minimize -->
                        <Button Grid.Column="3"
                                Width="24"
                                Height="24"
                                Margin="0,0,6,0"
                                Background="#EEF5FF"
                                BorderBrush="#B8D0EA"
                                BorderThickness="1"
                                Foreground="#4A6E9A"
                                FontSize="11"
                                FontWeight="Bold"
                                Click="BtnMinimize_Click"
                                Content="—"/>

                        <!-- Close -->
                        <Button Grid.Column="4"
                                Width="24"
                                Height="24"
                                Background="#FFF0F0"
                                BorderBrush="#F5BBBB"
                                BorderThickness="1"
                                Foreground="#C62828"
                                FontSize="9"
                                FontWeight="Bold"
                                Click="BtnClose_Click"
                                Content="✕"/>
                    </Grid>
                </Border>

                <!-- CONTENT AREA -->
                <Border Grid.Row="1"
                        Padding="10,10,10,8"
                        Background="Transparent">
                    <ContentControl x:Name="ShellContentHost">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:AcarsShellStep.Login}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <pages:LoginPage/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:AcarsShellStep.PilotLounge}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <pages:DashboardPage/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:AcarsShellStep.NoDispatch}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <pages:NoDispatchPage/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:AcarsShellStep.Dispatch}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <pages:PreFlightPage/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:AcarsShellStep.LiveFlight}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <pages:InFlightPage/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:AcarsShellStep.CloseFlight}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <pages:PostFlightPage/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:AcarsShellStep.Support}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <pages:SupportPage/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </Border>

                <!-- FOOTER -->
                <Border Grid.Row="2"
                        Background="#FFFFFF"
                        BorderBrush="#D4E8F8"
                        BorderThickness="0,1.5,0,0"
                        CornerRadius="0,0,20,20">
                    <Grid Margin="12,0,12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Ellipse Width="7"
                                 Height="7"
                                 Fill="#22C55E"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding FooterStatus}"
                                   Foreground="#4A6E9A"
                                   FontSize="8.5"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>

                        <TextBlock Grid.Column="2"
                                   Text="ACARS 6.0.1"
                                   Foreground="#1565C0"
                                   FontSize="8.5"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
