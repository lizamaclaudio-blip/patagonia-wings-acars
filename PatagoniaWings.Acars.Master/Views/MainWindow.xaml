<Window x:Class="PatagoniaWings.Acars.Master.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pages="clr-namespace:PatagoniaWings.Acars.Master.Views.Pages"
        xmlns:vm="clr-namespace:PatagoniaWings.Acars.Master.ViewModels"
        Title="Patagonia Wings ACARS"
        Width="1280" Height="800"
        MinWidth="1100" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="10" ClipToBounds="True">
        <Grid Background="{StaticResource BackgroundDarkBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <!-- TitleBar -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <!-- Sidebar -->
                <ColumnDefinition Width="*"/>
                <!-- Content -->
            </Grid.ColumnDefinitions>

            <!-- ═══ TITLEBAR ════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="{StaticResource BackgroundMidBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="✈" FontSize="18" Foreground="{StaticResource AccentLightBlueBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="PATAGONIA WINGS" FontSize="13" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    </StackPanel>

                    <!-- Info central: fase + sim + UTC -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{Binding SimStatusColor}"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="{Binding SimStatusText}" Foreground="#8B949E"
                                       FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="|" Foreground="#30363D" VerticalAlignment="Center" Margin="0,0,24,0"/>
                        <TextBlock Text="{Binding UtcTime}" Foreground="#8B949E"
                                   FontSize="12" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,24,0"/>
                        <TextBlock Text="|" Foreground="#30363D" VerticalAlignment="Center" Margin="0,0,24,0"/>
                        <TextBlock Text="{Binding PilotDisplay}" Foreground="White"
                                   FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Controles de ventana -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button Content="—" Width="36" Height="32" Background="Transparent"
                                BorderThickness="0" Foreground="#8B949E" Cursor="Hand"
                                FontSize="14" Click="BtnMinimize_Click"/>
                        <Button Content="⬜" Width="36" Height="32" Background="Transparent"
                                BorderThickness="0" Foreground="#8B949E" Cursor="Hand"
                                FontSize="11" Click="BtnMaximize_Click"/>
                        <Button Content="✕" Width="36" Height="32" Background="Transparent"
                                BorderThickness="0" Foreground="#8B949E" Cursor="Hand"
                                FontSize="13" Click="BtnClose_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground" Value="#8B949E"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#CC2222"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ SIDEBAR ═════════════════════════════════════════════════ -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="{StaticResource BackgroundMidBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Menú de navegación -->
                    <StackPanel DockPanel.Dock="Top" Margin="8,12">
                        <Button Style="{StaticResource SidebarButton}"
                                Command="{Binding NavDashboardCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⊞  " FontSize="14"/>
                                <TextBlock Text="Dashboard"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}"
                                Command="{Binding NavPreFlightCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋  " FontSize="13"/>
                                <TextBlock Text="Pre-Vuelo"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}"
                                Command="{Binding NavInFlightCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✈  " FontSize="13"/>
                                <TextBlock Text="En Vuelo"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}"
                                Command="{Binding NavCommunityCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👥  " FontSize="13"/>
                                <TextBlock Text="Comunidad"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}"
                                Command="{Binding NavProfileCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👤  " FontSize="13"/>
                                <TextBlock Text="Mi Perfil"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Logout al fondo -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,16">
                        <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,8"/>
                        <Button Style="{StaticResource SidebarButton}"
                                Command="{Binding LogoutCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏏  " FontSize="13" Foreground="#FF4444"/>
                                <TextBlock Text="Cerrar Sesión" Foreground="#FF4444"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ═══ CONTENT AREA ═════════════════════════════════════════════ -->
            <ScrollViewer Grid.Row="1" Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{StaticResource BackgroundDarkBrush}">
                <ContentControl x:Name="PageHost" Margin="24,20">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentPageName}" Value="Dashboard">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <pages:DashboardPage/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentPageName}" Value="PreFlight">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <pages:PreFlightPage/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentPageName}" Value="InFlight">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <pages:InFlightPage/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentPageName}" Value="PostFlight">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <pages:PostFlightPage/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentPageName}" Value="Profile">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <pages:ProfilePage/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentPageName}" Value="Community">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <pages:CommunityPage/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
