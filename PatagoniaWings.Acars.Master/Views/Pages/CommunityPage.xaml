<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.CommunityPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
<UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:TabToVisibilityConverter x:Key="TabToVisibilityConverter"
                                        xmlns:local="clr-namespace:PatagoniaWings.Acars.Master.Helpers"/>
        <local:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"
                                         xmlns:local="clr-namespace:PatagoniaWings.Acars.Master.Helpers"/>
    </UserControl.Resources>

    <StackPanel x:Name="PageRoot">

        <!-- CABECERA -->
        <TextBlock Text="RED · PILOTOS" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,10">
            <TextBlock Text="Comunidad" Style="{StaticResource PageTitle}" Margin="0"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Actualizando..." Foreground="#2D9CDB" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Content="↻  ACTUALIZAR" Style="{StaticResource SecondaryButton}"
                        Command="{Binding RefreshCommand}" Padding="10,6"/>
            </StackPanel>
        </Grid>

        <!-- TABS -->
        <Border Background="#F0F9FF" CornerRadius="8" Padding="3" Margin="0,0,0,10"
                BorderBrush="#BFDBFE" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <Button Click="TabOnline_Click" Padding="12,7" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="FontFamily" Value="Segoe UI"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="7" Height="7" Fill="#3FB950"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="0">
                                    <Setter Property="Background" Value="#DBEAFE"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentLightBlueBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource AccentLightBlueBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Content>Pilotos En Línea</Button.Content>
                </Button>

                <Button Click="TabLeader_Click" Margin="3,0,0,0" Padding="12,7" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="FontFamily" Value="Segoe UI"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🏆" FontSize="11"
                                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                    <Setter Property="Background" Value="#DBEAFE"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentLightBlueBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource AccentLightBlueBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Content>Tabla de Líderes</Button.Content>
                </Button>
            </StackPanel>
        </Border>

        <!-- PILOTOS EN LÍNEA -->
        <Border Style="{StaticResource Card}"
                Visibility="{Binding SelectedTab, Converter={StaticResource TabToVisibilityConverter}, ConverterParameter=0}">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="95"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="CALLSIGN" Style="{StaticResource FieldLabel}" Grid.Column="0"/>
                    <TextBlock Text="PILOTO" Style="{StaticResource FieldLabel}" Grid.Column="1"/>
                    <TextBlock Text="RANGO" Style="{StaticResource FieldLabel}" Grid.Column="2"/>
                    <TextBlock Text="HORAS" Style="{StaticResource FieldLabel}" Grid.Column="3"
                               HorizontalAlignment="Right"/>
                </Grid>
                <Rectangle Height="1" Margin="0,0,0,4">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#EFF6FF" Offset="0"/>
                            <GradientStop Color="#93C5FD" Offset="0.5"/>
                            <GradientStop Color="#EFF6FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <ItemsControl ItemsSource="{Binding OnlinePilots}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="3,7" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#EFF6FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="95"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                        <Grid Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                            <Ellipse Width="8" Height="8">
                                                <Ellipse.Fill>
                                                    <RadialGradientBrush>
                                                        <GradientStop Color="#803FB950" Offset="0.4"/>
                                                        <GradientStop Color="#003FB950" Offset="1"/>
                                                    </RadialGradientBrush>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <Ellipse Width="5" Height="5">
                                                <Ellipse.Fill>
                                                    <RadialGradientBrush>
                                                        <GradientStop Color="#CCFFDD" Offset="0"/>
                                                        <GradientStop Color="#3FB950" Offset="0.5"/>
                                                        <GradientStop Color="#1A6630" Offset="1"/>
                                                    </RadialGradientBrush>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                        </Grid>
                                        <TextBlock Text="{Binding CallSign}" Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding FullName}" Grid.Column="1"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                               VerticalAlignment="Center"/>

                                    <Border Grid.Column="2" CornerRadius="4" BorderThickness="1"
                                            Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center"
                                            BorderBrush="#FCD34D" Background="#FEF3C7">
                                        <TextBlock Text="{Binding RankName}" Foreground="#92400E"
                                                   FontSize="10" FontWeight="SemiBold"/>
                                    </Border>

                                    <TextBlock Text="{Binding TotalHours, StringFormat={}{0:F0}h}"
                                               Grid.Column="3" Foreground="{StaticResource TextSecondaryBrush}"
                                               FontFamily="Consolas" FontSize="10"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Padding="0,16"
                        Visibility="{Binding OnlinePilots.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="✈" FontSize="22" Foreground="#CBD5E1"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="Sin pilotos en línea en este momento."
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Sé el primero en conectarte al simulador."
                                   Foreground="#94A3B8" FontSize="10"
                                   HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- LEADERBOARD -->
        <Border Style="{StaticResource Card}"
                Visibility="{Binding SelectedTab, Converter={StaticResource TabToVisibilityConverter}, ConverterParameter=1}">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="95"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="58"/>
                        <ColumnDefinition Width="68"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="#" Style="{StaticResource FieldLabel}" Grid.Column="0"/>
                    <TextBlock Text="CALLSIGN" Style="{StaticResource FieldLabel}" Grid.Column="1"/>
                    <TextBlock Text="PILOTO" Style="{StaticResource FieldLabel}" Grid.Column="2"/>
                    <TextBlock Text="RANGO" Style="{StaticResource FieldLabel}" Grid.Column="3"/>
                    <TextBlock Text="HORAS" Style="{StaticResource FieldLabel}" Grid.Column="4"
                               HorizontalAlignment="Right"/>
                    <TextBlock Text="PUNTOS" Style="{StaticResource FieldLabel}" Grid.Column="5"
                               HorizontalAlignment="Right"/>
                </Grid>
                <Rectangle Height="1" Margin="0,0,0,4">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#EFF6FF" Offset="0"/>
                            <GradientStop Color="#FCD34D" Offset="0.5"/>
                            <GradientStop Color="#EFF6FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <ItemsControl ItemsSource="{Binding Leaderboard}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="3,6" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#EFF6FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="95"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="58"/>
                                        <ColumnDefinition Width="68"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Foreground="#FFD700" FontFamily="Consolas"
                                               FontSize="11" FontWeight="Bold"
                                               Grid.Column="0" VerticalAlignment="Center" Text="·"/>

                                    <TextBlock Text="{Binding CallSign}" Foreground="{StaticResource TextPrimaryBrush}"
                                               FontFamily="Consolas" FontSize="11"
                                               FontWeight="Bold" Grid.Column="1" VerticalAlignment="Center"/>

                                    <TextBlock Text="{Binding FullName}" Grid.Column="2"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                               VerticalAlignment="Center"/>

                                    <Border Grid.Column="3" CornerRadius="4" BorderThickness="1"
                                            Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center"
                                            BorderBrush="#FCD34D" Background="#FEF3C7">
                                        <TextBlock Text="{Binding RankName}" Foreground="#92400E"
                                                   FontSize="9" FontWeight="SemiBold"/>
                                    </Border>

                                    <TextBlock Text="{Binding TotalHours, StringFormat={}{0:F0}}"
                                               Grid.Column="4" Foreground="{StaticResource AccentLightBlueBrush}"
                                               FontFamily="Consolas" FontSize="11"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                    <Border Grid.Column="5" CornerRadius="4" BorderThickness="1"
                                            Padding="5,2" HorizontalAlignment="Right" VerticalAlignment="Center"
                                            BorderBrush="#FCD34D" Background="#FEF3C7">
                                        <TextBlock Text="{Binding Points}" Foreground="#92400E"
                                                   FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Sin datos de pilotos disponibles."
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,16"
                           Visibility="{Binding Leaderboard.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
