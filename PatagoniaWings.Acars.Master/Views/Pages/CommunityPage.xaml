<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.CommunityPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.DataContext>
        <Binding Path="CommunityVM" RelativeSource="{RelativeSource AncestorType=Window}"/>
    </UserControl.DataContext>

    <StackPanel>
        <Grid Margin="0,0,0,20">
            <TextBlock Text="Comunidad" Style="{StaticResource PageTitle}" Margin="0"/>
            <Button Content="🔄 Actualizar" Style="{StaticResource SecondaryButton}"
                    Command="{Binding RefreshCommand}" HorizontalAlignment="Right"
                    VerticalAlignment="Top"/>
        </Grid>

        <!-- Tabs -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="Pilotos En Línea" Click="TabOnline_Click"
                    Tag="0" x:Name="TabOnlineBtn">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="0">
                                <Setter Property="Background" Value="#1A3A5C"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentLightBlueBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Tabla de Líderes" Click="TabLeader_Click"
                    Tag="1" Margin="8,0,0,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                <Setter Property="Background" Value="#1A3A5C"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentLightBlueBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Pilotos en línea -->
        <Border Style="{StaticResource Card}"
                Visibility="{Binding SelectedTab, Converter={StaticResource TabToVisibilityConverter}, ConverterParameter=0}">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding OnlinePilots}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="0,8" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                                        <Ellipse Width="8" Height="8" Fill="#3FB950"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding CallSign}" Foreground="White"
                                                   FontFamily="Consolas" FontSize="13" FontWeight="Bold"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding FullName}" Grid.Column="1"
                                               Foreground="#8B949E" FontSize="13"/>
                                    <TextBlock Text="{Binding RankName}" Grid.Column="2"
                                               Foreground="#FFD700" FontSize="12"/>
                                    <TextBlock Text="{Binding TotalHours, StringFormat={}{0:F0}h}"
                                               Grid.Column="3" Foreground="#8B949E"
                                               FontFamily="Consolas" FontSize="12"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="Sin pilotos en línea en este momento."
                           Foreground="#8B949E" FontSize="13" HorizontalAlignment="Center"
                           Margin="0,20"
                           Visibility="{Binding OnlinePilots.Count,
                               Converter={StaticResource ZeroToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <!-- Leaderboard -->
        <Border Style="{StaticResource Card}"
                Visibility="{Binding SelectedTab, Converter={StaticResource TabToVisibilityConverter}, ConverterParameter=1}">
            <StackPanel>
                <!-- Header -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="#" Style="{StaticResource FieldLabel}" Grid.Column="0"/>
                    <TextBlock Text="CALLSIGN" Style="{StaticResource FieldLabel}" Grid.Column="1"/>
                    <TextBlock Text="PILOTO" Style="{StaticResource FieldLabel}" Grid.Column="2"/>
                    <TextBlock Text="RANGO" Style="{StaticResource FieldLabel}" Grid.Column="3"/>
                    <TextBlock Text="HORAS" Style="{StaticResource FieldLabel}" Grid.Column="4"/>
                    <TextBlock Text="PUNTOS" Style="{StaticResource FieldLabel}" Grid.Column="5"/>
                </Grid>
                <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,8"/>

                <ItemsControl ItemsSource="{Binding Leaderboard}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="0,8" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="#FFD700" FontFamily="Consolas"
                                               FontSize="13" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CallSign}" Foreground="White"
                                               FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                               Grid.Column="1"/>
                                    <TextBlock Text="{Binding FullName}" Grid.Column="2"
                                               Foreground="#8B949E" FontSize="13"/>
                                    <TextBlock Text="{Binding RankName}" Grid.Column="3"
                                               Foreground="#FFD700" FontSize="11"/>
                                    <TextBlock Text="{Binding TotalHours, StringFormat={}{0:F0}}"
                                               Grid.Column="4" Foreground="{StaticResource AccentLightBlueBrush}"
                                               FontFamily="Consolas" FontSize="13"/>
                                    <TextBlock Text="{Binding Points}" Grid.Column="5"
                                               Foreground="#FFD700" FontFamily="Consolas"
                                               FontSize="13" FontWeight="Bold"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </StackPanel>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
</UserControl>
