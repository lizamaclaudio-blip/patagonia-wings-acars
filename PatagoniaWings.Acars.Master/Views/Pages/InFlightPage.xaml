<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.InFlightPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0C111B">

    <UserControl.DataContext>
        <Binding Path="DataContext.InFlightVM" RelativeSource="{RelativeSource AncestorType=Window}" />
    </UserControl.DataContext>

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#0C111B"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#121926"/>
        <SolidColorBrush x:Key="CardBrush" Color="#162234"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#223247"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F0F6FC"/>
        <SolidColorBrush x:Key="SubtleBrush" Color="#8B949E"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2D9CDB"/>
        <SolidColorBrush x:Key="OkBrush" Color="#3FB950"/>
        <SolidColorBrush x:Key="WarnBrush" Color="#F2C94C"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FF5D5D"/>

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
        </Style>

        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubtleBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>

        <Style x:Key="PillBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#0F1724"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#18304B"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#1A2230"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        </Style>

        <Style x:Key="LightStateTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,18" Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" Text="EN VUELO"/>
                    <TextBlock Foreground="{StaticResource TextBrush}" FontSize="26" FontWeight="Bold" Margin="0,4,0,0" Text="Telemetría real en vivo"/>
                    <TextBlock Foreground="{StaticResource SubtleBrush}" FontSize="12" Margin="0,4,0,0"
                               Text="Esta vista debe responder a telemetría real del simulador y mostrar el estado vivo del vuelo."/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnConnectMsfs"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="BtnConnectMsfs_Click"
                                Content="Conectar simulador"/>
                        <Button x:Name="BtnRefreshFlight"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="BtnRefreshFlight_Click"
                                Content="Reintentar"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Right">
                        <Border Style="{StaticResource PillBorderStyle}">
                            <TextBlock Foreground="{StaticResource AccentBrush}" FontSize="10" Text="{Binding SimBackendDisplay, FallbackValue=Sin backend}"/>
                        </Border>
                        <Border Style="{StaticResource PillBorderStyle}">
                            <TextBlock Foreground="{StaticResource OkBrush}" FontSize="10" Text="{Binding PhaseLabelDisplay, FallbackValue=Desconectado}"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <UniformGrid Columns="5" Margin="0,0,0,18">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource LabelStyle}" Text="IAS"/>
                            <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding IASDisplay, FallbackValue=---}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource LabelStyle}" Text="GS"/>
                            <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding GSDisplay, FallbackValue=---}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource LabelStyle}" Text="ALTITUD"/>
                            <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding AltitudeDisplay, FallbackValue=---}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource LabelStyle}" Text="V/S"/>
                            <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding VSDisplay, FallbackValue=---}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource LabelStyle}" Text="TIEMPO"/>
                            <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding ElapsedTimeDisplay, FallbackValue=00:00:00}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.7*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <Border Style="{StaticResource PanelStyle}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Style="{StaticResource TitleTextStyle}" Text="Motor y configuración"/>
                                <UniformGrid Columns="4">
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="FUEL KG"/>
                                            <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding FuelKgDisplay, FallbackValue=---}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="N1 ENG 1"/>
                                            <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding N1Eng1Display, FallbackValue=---}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="N1 ENG 2"/>
                                            <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding N1Eng2Display, FallbackValue=---}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="SQUAWK"/>
                                            <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding SquawkDisplay, FallbackValue=----}"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <UniformGrid Columns="4" Margin="0,12,0,0">
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="HEADING"/>
                                            <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding HeadingDisplay, FallbackValue=---}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="FLAPS"/>
                                            <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding FlapsDisplay, FallbackValue=---}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="GEAR"/>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource LightStateTextStyle}">
                                                        <Setter Property="Text" Value="UP"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding GearDown}" Value="True">
                                                                <Setter Property="Text" Value="DOWN"/>
                                                                <Setter Property="Foreground" Value="{StaticResource WarnBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="AUTOPILOT"/>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource LightStateTextStyle}">
                                                        <Setter Property="Text" Value="OFF"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AutopilotOn}" Value="True">
                                                                <Setter Property="Text" Value="ON"/>
                                                                <Setter Property="Foreground" Value="{StaticResource OkBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource TitleTextStyle}" Text="Luces y señales"/>
                                <UniformGrid Columns="4">
                                    <!-- row 1 -->
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel><TextBlock Style="{StaticResource LabelStyle}" Text="BEACON"/><TextBlock><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource LightStateTextStyle}"><Setter Property="Text" Value="OFF"/><Style.Triggers><DataTrigger Binding="{Binding BeaconOn}" Value="True"><Setter Property="Text" Value="ON"/><Setter Property="Foreground" Value="{StaticResource OkBrush}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel><TextBlock Style="{StaticResource LabelStyle}" Text="NAV"/><TextBlock><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource LightStateTextStyle}"><Setter Property="Text" Value="OFF"/><Style.Triggers><DataTrigger Binding="{Binding NavOn}" Value="True"><Setter Property="Text" Value="ON"/><Setter Property="Foreground" Value="{StaticResource OkBrush}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel><TextBlock Style="{StaticResource LabelStyle}" Text="STROBE"/><TextBlock><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource LightStateTextStyle}"><Setter Property="Text" Value="OFF"/><Style.Triggers><DataTrigger Binding="{Binding StrobeOn}" Value="True"><Setter Property="Text" Value="ON"/><Setter Property="Foreground" Value="{StaticResource OkBrush}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel><TextBlock Style="{StaticResource LabelStyle}" Text="LANDING"/><TextBlock><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource LightStateTextStyle}"><Setter Property="Text" Value="OFF"/><Style.Triggers><DataTrigger Binding="{Binding LandingOn}" Value="True"><Setter Property="Text" Value="ON"/><Setter Property="Foreground" Value="{StaticResource OkBrush}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></StackPanel>
                                    </Border>

                                    <!-- row 2 -->
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel><TextBlock Style="{StaticResource LabelStyle}" Text="TAXI"/><TextBlock><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource LightStateTextStyle}"><Setter Property="Text" Value="OFF"/><Style.Triggers><DataTrigger Binding="{Binding TaxiOn}" Value="True"><Setter Property="Text" Value="ON"/><Setter Property="Foreground" Value="{StaticResource OkBrush}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel><TextBlock Style="{StaticResource LabelStyle}" Text="SEATBELT"/><TextBlock><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource LightStateTextStyle}"><Setter Property="Text" Value="OFF"/><Style.Triggers><DataTrigger Binding="{Binding SeatBeltSign}" Value="True"><Setter Property="Text" Value="ON"/><Setter Property="Foreground" Value="{StaticResource OkBrush}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel><TextBlock Style="{StaticResource LabelStyle}" Text="NO SMOKING"/><TextBlock><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource LightStateTextStyle}"><Setter Property="Text" Value="OFF"/><Style.Triggers><DataTrigger Binding="{Binding NoSmokingSign}" Value="True"><Setter Property="Text" Value="ON"/><Setter Property="Foreground" Value="{StaticResource OkBrush}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel><TextBlock Style="{StaticResource LabelStyle}" Text="CHARLIE"/><TextBlock><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource LightStateTextStyle}"><Setter Property="Text" Value="OFF"/><Style.Triggers><DataTrigger Binding="{Binding CharlieMode}" Value="True"><Setter Property="Text" Value="ON"/><Setter Property="Foreground" Value="{StaticResource OkBrush}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></StackPanel>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <Border Style="{StaticResource PanelStyle}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Style="{StaticResource TitleTextStyle}" Text="Condiciones y posición"/>

                                <TextBlock Style="{StaticResource LabelStyle}" Text="POSICIÓN"/>
                                <TextBlock Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontWeight="SemiBold" FontSize="16">
                                    <Run Text="{Binding Lat, StringFormat={}{0:F4}}"/>
                                    <Run Text=", "/>
                                    <Run Text="{Binding Lon, StringFormat={}{0:F4}}"/>
                                </TextBlock>

                                <TextBlock Style="{StaticResource LabelStyle}" Text="OAT" Margin="0,14,0,0"/>
                                <TextBlock Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontWeight="SemiBold" FontSize="16">
                                    <Run Text="{Binding OAT, StringFormat={}{0:F1}}"/>
                                    <Run Text=" °C"/>
                                </TextBlock>

                                <TextBlock Style="{StaticResource LabelStyle}" Text="VIENTO" Margin="0,14,0,0"/>
                                <TextBlock Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontWeight="SemiBold" FontSize="16">
                                    <Run Text="{Binding WindDir, StringFormat={}{0:F0}}"/>
                                    <Run Text="° / "/>
                                    <Run Text="{Binding WindSpeed, StringFormat={}{0:F0}}"/>
                                    <Run Text=" KT"/>
                                </TextBlock>

                                <WrapPanel Margin="0,16,0,0">
                                    <Border Style="{StaticResource PillBorderStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Foreground="{StaticResource SubtleBrush}" FontSize="10" Text="On Ground: "/>
                                            <TextBlock Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" FontSize="10">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="NO"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding OnGround}" Value="True">
                                                                <Setter Property="Text" Value="YES"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource PillBorderStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Foreground="{StaticResource SubtleBrush}" FontSize="10" Text="Autopilot: "/>
                                            <TextBlock Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" FontSize="10">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="OFF"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AutopilotOn}" Value="True">
                                                                <Setter Property="Text" Value="ON"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelStyle}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Style="{StaticResource TitleTextStyle}" Text="Cabina y sistemas"/>

                                <UniformGrid Columns="2">
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="ALT. CABINA"/>
                                            <TextBlock Style="{StaticResource ValueStyle}" FontSize="20">
                                                <Run Text="{Binding CabinAlt, StringFormat={}{0:F0}}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="PRESS DIFF"/>
                                            <TextBlock Style="{StaticResource ValueStyle}" FontSize="20">
                                                <Run Text="{Binding PressDiff, StringFormat={}{0:F2}}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <UniformGrid Columns="2" Margin="0,12,0,0">
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="APU"/>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource LightStateTextStyle}">
                                                        <Setter Property="Text" Value="OFF"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ApuRunning}" Value="True">
                                                                <Setter Property="Text" Value="RUN"/>
                                                                <Setter Property="Foreground" Value="{StaticResource OkBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ApuAvailable}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource WarnBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="BLEED AIR"/>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource LightStateTextStyle}">
                                                        <Setter Property="Text" Value="OFF"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding BleedAirOn}" Value="True">
                                                                <Setter Property="Text" Value="ON"/>
                                                                <Setter Property="Foreground" Value="{StaticResource OkBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource TitleTextStyle}" Text="Resumen operativo"/>
                                <TextBlock Foreground="{StaticResource TextBrush}" FontSize="13" TextWrapping="Wrap">
                                    <Run Text="Backend: "/><Run Text="{Binding SimBackendDisplay, FallbackValue=Sin conexión}"/>
                                </TextBlock>
                                <TextBlock Foreground="{StaticResource TextBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,6,0,0">
                                    <Run Text="Fase: "/><Run Text="{Binding PhaseLabelDisplay, FallbackValue=Desconectado}"/>
                                </TextBlock>
                                <TextBlock Foreground="{StaticResource SubtleBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0"
                                           Text="Si esta pantalla no cambia en vivo con MSFS abierto, el problema ya no es de diseño sino de telemetría o runtime."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
