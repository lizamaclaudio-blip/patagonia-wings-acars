<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.InFlightPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#EFF6FF"
             Loaded="OnPageLoaded">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style x:Key="SHead" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0284C7"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,7"/>
        </Style>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SysLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LightOn" TargetType="Ellipse">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Fill" Value="#10B981"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>

        <Style x:Key="LightOff" TargetType="Ellipse">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Fill" Value="#EF4444"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>

        <Style x:Key="PillOn" TargetType="Border">
            <Setter Property="Background" Value="#D1FAE5"/>
            <Setter Property="BorderBrush" Value="#6EE7B7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="PillOff" TargetType="Border">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="FinishBtn" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0284C7" Offset="0"/>
                        <GradientStop Color="#0EA5E9" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConnectBtn" TargetType="Button">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="Foreground" Value="#0284C7"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel x:Name="PageRoot" Background="#EFF6FF">

        <!-- ═══ HEADER ═══ -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="VUELO EN VIVO" FontSize="16" FontWeight="Bold"
                           Foreground="#0284C7" FontFamily="Segoe UI"/>
                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                    <Border CornerRadius="8" Padding="8,2" Margin="0,0,6,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#FEF3C7"/>
                                <Setter Property="BorderBrush" Value="#FCD34D"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSimConnected}" Value="True">
                                        <Setter Property="Background" Value="#D1FAE5"/>
                                        <Setter Property="BorderBrush" Value="#6EE7B7"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding SimBackendDisplay}"
                                   FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#92400E"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSimConnected}" Value="True">
                                            <Setter Property="Foreground" Value="#065F46"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <Border CornerRadius="8" Padding="8,2" Margin="0,0,6,0"
                            Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1">
                        <TextBlock Text="{Binding PhaseLabelDisplay}"
                                   FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                                   Foreground="#0284C7"/>
                    </Border>
                    <TextBlock Text="{Binding AircraftStatusDisplay}"
                               FontSize="10" Foreground="#64748B" FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ConnectBtn}" Click="BtnConnectMsfs_Click" Margin="0,0,5,0">
                    <TextBlock Text="Conectar MSFS"/>
                </Button>
                <Button Style="{StaticResource ConnectBtn}" Click="BtnRefreshFlight_Click">
                    <TextBlock Text="↺  Refrescar"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══ MÉTRICAS PRIMARIAS ═══ -->
        <Border Style="{StaticResource Card}" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding IASDisplay}" Style="{StaticResource MetricValue}"/>
                    <TextBlock Text="IAS kt" Style="{StaticResource MetricLabel}"/>
                </StackPanel>
                <Rectangle Grid.Column="1" Fill="#E2E8F0" Width="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="{Binding GSDisplay}" Style="{StaticResource MetricValue}"/>
                    <TextBlock Text="GS kt" Style="{StaticResource MetricLabel}"/>
                </StackPanel>
                <Rectangle Grid.Column="3" Fill="#E2E8F0" Width="1"/>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="{Binding AltitudeDisplay}" Style="{StaticResource MetricValue}"
                               Foreground="#0284C7"/>
                    <TextBlock Text="ALT ft" Style="{StaticResource MetricLabel}"/>
                </StackPanel>
                <Rectangle Grid.Column="5" Fill="#E2E8F0" Width="1"/>
                <StackPanel Grid.Column="6">
                    <TextBlock Text="{Binding VSDisplay}" Style="{StaticResource MetricValue}" FontSize="15"/>
                    <TextBlock Text="V/S fpm" Style="{StaticResource MetricLabel}"/>
                </StackPanel>
                <Rectangle Grid.Column="7" Fill="#E2E8F0" Width="1"/>
                <StackPanel Grid.Column="8">
                    <TextBlock Text="{Binding ElapsedTimeDisplay}" Style="{StaticResource MetricValue}"
                               FontSize="15" Foreground="#64748B"/>
                    <TextBlock Text="Tiempo vuelo" Style="{StaticResource MetricLabel}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ SISTEMAS ═══ -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="128"/>
            </Grid.ColumnDefinitions>

            <!-- ── LUCES (compacto) ── -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="LUCES" Style="{StaticResource SHead}"/>

                    <!-- Macro helper: Label + Dot por fila -->
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Beacon" Style="{StaticResource SysLabel}"/>
                        <Ellipse Grid.Column="1">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse" BasedOn="{StaticResource LightOff}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding BeaconOn}" Value="True"><Setter Property="Fill" Value="#10B981"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Grid>
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Nav" Style="{StaticResource SysLabel}"/>
                        <Ellipse Grid.Column="1">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse" BasedOn="{StaticResource LightOff}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NavOn}" Value="True"><Setter Property="Fill" Value="#10B981"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Grid>
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Strobe" Style="{StaticResource SysLabel}"/>
                        <Ellipse Grid.Column="1">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse" BasedOn="{StaticResource LightOff}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StrobeOn}" Value="True"><Setter Property="Fill" Value="#10B981"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Grid>
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Landing" Style="{StaticResource SysLabel}"/>
                        <Ellipse Grid.Column="1">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse" BasedOn="{StaticResource LightOff}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LandingOn}" Value="True"><Setter Property="Fill" Value="#10B981"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Taxi" Style="{StaticResource SysLabel}"/>
                        <Ellipse Grid.Column="1">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse" BasedOn="{StaticResource LightOff}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TaxiOn}" Value="True"><Setter Property="Fill" Value="#10B981"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── SISTEMAS (compacto, sin Alt Baro/Suelo) ── -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="SISTEMAS" Style="{StaticResource SHead}"/>

                    <!-- APU — solo jets / turbohélices con APU -->
                    <Grid Margin="0,0,0,3" Visibility="{Binding ShowApu, Converter={StaticResource BoolVis}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="APU" Style="{StaticResource SysLabel}"/>
                        <Border Grid.Column="1">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource PillOff}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ApuRunning}" Value="True">
                                            <Setter Property="Background" Value="#D1FAE5"/>
                                            <Setter Property="BorderBrush" Value="#6EE7B7"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="9" FontWeight="SemiBold" FontFamily="Segoe UI">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="OFF"/>
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ApuRunning}" Value="True">
                                                <Setter Property="Text" Value="ON"/>
                                                <Setter Property="Foreground" Value="#065F46"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <!-- Bleed Air — solo presurizados -->
                    <Grid Margin="0,0,0,3" Visibility="{Binding HasPressurization, Converter={StaticResource BoolVis}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Bleed Air" Style="{StaticResource SysLabel}"/>
                        <Border Grid.Column="1">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource PillOff}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding BleedAirOn}" Value="True">
                                            <Setter Property="Background" Value="#D1FAE5"/>
                                            <Setter Property="BorderBrush" Value="#6EE7B7"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="9" FontWeight="SemiBold" FontFamily="Segoe UI">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="OFF"/>
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BleedAirOn}" Value="True">
                                                <Setter Property="Text" Value="ON"/>
                                                <Setter Property="Foreground" Value="#065F46"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <!-- Seatbelt — todas las aeronaves -->
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Seatbelt" Style="{StaticResource SysLabel}"/>
                        <Border Grid.Column="1">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource PillOff}">
                                    <Setter Property="Background" Value="#FEE2E2"/>
                                    <Setter Property="BorderBrush" Value="#FCA5A5"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SeatBeltSign}" Value="True">
                                            <Setter Property="Background" Value="#D1FAE5"/>
                                            <Setter Property="BorderBrush" Value="#6EE7B7"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="9" FontWeight="SemiBold" FontFamily="Segoe UI">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="OFF"/>
                                        <Setter Property="Foreground" Value="#991B1B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SeatBeltSign}" Value="True">
                                                <Setter Property="Text" Value="ON"/>
                                                <Setter Property="Foreground" Value="#065F46"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <!-- No Smoking — solo presurizados -->
                    <Grid Margin="0,0,0,3" Visibility="{Binding HasPressurization, Converter={StaticResource BoolVis}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="No Smoking" Style="{StaticResource SysLabel}"/>
                        <Border Grid.Column="1">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource PillOff}">
                                    <Setter Property="Background" Value="#FEE2E2"/>
                                    <Setter Property="BorderBrush" Value="#FCA5A5"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NoSmokingSign}" Value="True">
                                            <Setter Property="Background" Value="#D1FAE5"/>
                                            <Setter Property="BorderBrush" Value="#6EE7B7"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="9" FontWeight="SemiBold" FontFamily="Segoe UI">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="OFF"/>
                                        <Setter Property="Foreground" Value="#991B1B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NoSmokingSign}" Value="True">
                                                <Setter Property="Text" Value="ON"/>
                                                <Setter Property="Foreground" Value="#065F46"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <!-- Cabin Alt / Press Diff — solo presurizados -->
                    <Grid Margin="0,0,0,3" Visibility="{Binding HasPressurization, Converter={StaticResource BoolVis}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Cabin Alt" Style="{StaticResource SysLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding CabinAlt, StringFormat='{}{0:0} ft'}"
                                   FontSize="11" FontWeight="SemiBold" FontFamily="Consolas"
                                   Foreground="#0284C7" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,3" Visibility="{Binding HasPressurization, Converter={StaticResource BoolVis}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Press Diff" Style="{StaticResource SysLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding PressDiff, StringFormat='{}{0:0.00} psi'}"
                                   FontSize="11" FontWeight="SemiBold" FontFamily="Consolas"
                                   Foreground="#0284C7" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Squawk + Modo transponder -->
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Squawk" Style="{StaticResource SysLabel}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding SquawkDisplay}"
                                       FontSize="11" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="#0F172A" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource PillOff}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CharlieMode}" Value="True">
                                                <Setter Property="Background" Value="#EDE9FE"/>
                                                <Setter Property="BorderBrush" Value="#A78BFA"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="9" FontWeight="SemiBold" FontFamily="Segoe UI">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="STBY"/>
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CharlieMode}" Value="True">
                                                    <Setter Property="Text" Value="MODE C"/>
                                                    <Setter Property="Foreground" Value="#5B21B6"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Autopilot -->
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Autopilot" Style="{StaticResource SysLabel}"/>
                        <Border Grid.Column="1">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource PillOff}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AutopilotOn}" Value="True">
                                            <Setter Property="Background" Value="#EDE9FE"/>
                                            <Setter Property="BorderBrush" Value="#A78BFA"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="9" FontWeight="SemiBold" FontFamily="Segoe UI">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="MANUAL"/>
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AutopilotOn}" Value="True">
                                                <Setter Property="Text" Value="AP ON"/>
                                                <Setter Property="Foreground" Value="#5B21B6"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── AERONAVE / FOTO ── -->
            <Border Grid.Column="4" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="AERONAVE" Style="{StaticResource SHead}"/>

                    <!-- Placeholder visual de foto: muestra ICAO centrado.
                         Para activar una imagen real, reemplaza este Border por:
                         <Image Source="{Binding AircraftImageUrl}" Stretch="UniformToFill"
                                RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True"/>
                    -->
                    <Border Grid.Row="1" CornerRadius="6" MinHeight="80" ClipToBounds="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#EFF6FF" Offset="0"/>
                                <GradientStop Color="#DBEAFE" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <!-- Texto de fondo decorativo -->
                            <TextBlock Text="{Binding AircraftImageInitials}"
                                       FontSize="38" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="#BFDBFE" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Opacity="0.7"/>
                            <!-- Nombre completo + variante abajo -->
                            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="6,0,6,5">
                                <TextBlock Text="{Binding AircraftTitle}" FontSize="8"
                                           Foreground="#0284C7" FontFamily="Segoe UI"
                                           TextTrimming="CharacterEllipsis" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="▸ " FontSize="7" Foreground="#64748B" FontFamily="Segoe UI"/>
                                    <TextBlock Text="{Binding DetectedAddonLabel}" FontSize="7"
                                               Foreground="#64748B" FontFamily="Segoe UI"/>
                                </StackPanel>
                                <!-- Badge match variante -->
                                <Border CornerRadius="3" Padding="4,1" Margin="0,2,0,0" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#D1FAE5"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding VariantMatchOk}" Value="False">
                                                    <Setter Property="Background" Value="#FEF3C7"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="7" FontWeight="Bold" FontFamily="Segoe UI">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding VariantMatchDisplay}"/>
                                                <Setter Property="Foreground" Value="#065F46"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding VariantMatchOk}" Value="False">
                                                        <Setter Property="Foreground" Value="#92400E"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            <!-- Badge de estado suelo/vuelo -->
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                    CornerRadius="4" Padding="5,2" Margin="0,0,4,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#DBEAFE"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OnGround}" Value="True">
                                                <Setter Property="Background" Value="#D1FAE5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="8" FontWeight="Bold" FontFamily="Segoe UI">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="● VUELO"/>
                                            <Setter Property="Foreground" Value="#1D4ED8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding OnGround}" Value="True">
                                                    <Setter Property="Text" Value="● TIERRA"/>
                                                    <Setter Property="Foreground" Value="#065F46"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ── ENTORNO ── -->
            <Border Grid.Column="6" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="ENTORNO" Style="{StaticResource SHead}"/>
                    <TextBlock Text="OAT" FontSize="9" Foreground="#94A3B8" FontFamily="Segoe UI" Margin="0,0,0,1"/>
                    <TextBlock FontSize="13" FontWeight="Bold" FontFamily="Consolas" Foreground="#0F172A" Margin="0,0,0,5">
                        <TextBlock.Text>
                            <Binding Path="OAT" StringFormat="{}{0:F0} °C" FallbackValue="—"/>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Text="Viento" FontSize="9" Foreground="#94A3B8" FontFamily="Segoe UI" Margin="0,0,0,1"/>
                    <TextBlock FontSize="11" FontWeight="SemiBold" FontFamily="Consolas" Foreground="#334155" Margin="0,0,0,5">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:000}° / {1:F0} kt">
                                <Binding Path="WindDir"/>
                                <Binding Path="WindSpeed"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Text="Combustible" FontSize="9" Foreground="#94A3B8" FontFamily="Segoe UI" Margin="0,0,0,1"/>
                    <TextBlock Text="{Binding FuelKgDisplay, StringFormat='{}{0} kg'}"
                               FontSize="11" FontWeight="SemiBold" FontFamily="Consolas"
                               Foreground="#334155" Margin="0,0,0,5"/>
                    <TextBlock FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="● En vuelo"/>
                                <Setter Property="Foreground" Value="#0284C7"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OnGround}" Value="True">
                                        <Setter Property="Text" Value="● En tierra"/>
                                        <Setter Property="Foreground" Value="#10B981"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ ALERT NO STROBE ═══ -->
        <Border Margin="0,0,0,8" CornerRadius="8" Padding="12,8"
                Visibility="{Binding AlertNoStrobe, Converter={StaticResource BoolVis}}"
                Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1">
            <TextBlock Text="⚠  Luces de posición apagadas en vuelo. Activa strobe y nav lights."
                       FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI" Foreground="#DC2626"/>
        </Border>

        <!-- ═══ FINISH FLIGHT ═══ -->
        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Para finalizar el vuelo el avión debe estar en tierra con GS &lt; 3 kt."
                               FontSize="10" Foreground="#64748B" FontFamily="Segoe UI"/>
                    <TextBlock Text="{Binding PhaseLabel, StringFormat='Fase actual: {0}'}"
                               FontSize="10" Foreground="#0284C7" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource FinishBtn}"
                        Command="{Binding FinishFlightCommand}">
                    <TextBlock Text="FINALIZAR VUELO"/>
                </Button>
            </Grid>
        </Border>

    </StackPanel>
</UserControl>
