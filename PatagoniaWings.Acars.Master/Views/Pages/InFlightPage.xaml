<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.InFlightPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:preview="clr-namespace:PatagoniaWings.Acars.Master.Preview"
             Background="Transparent"
             Loaded="OnPageLoaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel x:Name="PageRoot"
                    DataContext="{Binding DataContext.MainVM.InFlightVM, RelativeSource={RelativeSource AncestorType=Window}}">
            <TextBlock Text="VUELO EN VIVO"
                       Style="{StaticResource PageTitle}"
                       Margin="0,0,0,8"/>

            <Border Style="{StaticResource CardBlue}" Margin="0,0,0,8">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding DataContext.MainVM.PreFlightVM.FlightNumber, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.LiveFlightNumber}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       FontFamily="Consolas"/>
                            <TextBlock Text="{Binding DataContext.MainVM.PreFlightVM.PreparedDispatch.AircraftRegistration, RelativeSource={RelativeSource AncestorType=Window}, TargetNullValue={x:Static preview:AcarsPreviewData.LiveRegistration}}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="10"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Style="{StaticResource PillBlue}"
                                HorizontalAlignment="Right">
                            <TextBlock Text="{Binding RouteProgressDisplay, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.LiveProgress}}"
                                       Foreground="{StaticResource AccentBlueBrush}"
                                       FontSize="8.5"
                                       FontWeight="Bold"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,9,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding RouteOrigin, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.LiveOrigin}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       FontSize="20"
                                       FontWeight="Bold"/>
                            <TextBlock Text="{Binding RouteDistanceFromOriginDisplay, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.LiveDistanceFromOrigin}}"
                                       Foreground="{StaticResource AccentLightBlueBrush}"
                                       FontSize="9"
                                       Margin="0,3,0,0"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="&#x2708;"
                                   Foreground="{StaticResource AccentBlueBrush}"
                                   FontSize="18"
                                   Margin="8,11,8,0"/>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding RouteDestination, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.LiveDestination}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding RouteDistanceToDestinationDisplay, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.LiveDistanceToDestination}}"
                                       Foreground="{StaticResource AccentLightBlueBrush}"
                                       FontSize="9"
                                       Margin="0,3,0,0"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <Viewbox Stretch="Fill" Height="16" Margin="0,9,0,5">
                        <Canvas Width="320" Height="16">
                            <Ellipse Width="6" Height="6" Fill="#2C445C" Canvas.Left="0" Canvas.Top="5"/>
                            <Ellipse Width="6" Height="6" Fill="#2C445C" Canvas.Left="314" Canvas.Top="5"/>
                            <Rectangle Width="320"
                                       Height="2"
                                       RadiusX="1"
                                       RadiusY="1"
                                       Fill="#223243"
                                       Canvas.Top="7"/>
                            <Rectangle Width="{Binding RouteTrackWidth}"
                                       Height="2"
                                       RadiusX="1"
                                       RadiusY="1"
                                       Fill="{StaticResource AccentBlueBrush}"
                                       Canvas.Top="7"/>
                            <TextBlock Text="&#x2708;"
                                       FontSize="14"
                                       Foreground="{StaticResource AccentLightBlueBrush}"
                                       Canvas.Left="{Binding RoutePlaneLeft}"
                                       Canvas.Top="-1"/>
                        </Canvas>
                    </Viewbox>

                    <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding OfficialPhaseDisplay, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.LiveOfficialPhase}}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="9.2"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PhaseLabelDisplay, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.LivePhaseLabel}}"
                                   Foreground="{StaticResource AccentLightBlueBrush}"
                                   FontSize="9.2"
                                   Margin="8,0,0,0"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ElapsedTimeDisplay, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.LiveElapsed}}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Consolas"
                                   FontSize="9.2"
                                   Margin="8,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="RESUMEN OPERACIONAL" Style="{StaticResource SectionLabel}"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource InsetCard}">
                            <StackPanel>
                                <TextBlock Text="COMBUSTIBLE" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding FuelKgDisplay, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.LiveFuel}}"
                                           Foreground="{StaticResource AccentLightBlueBrush}"
                                           FontSize="13"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource InsetCard}">
                            <StackPanel>
                                <TextBlock Text="XPDR" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding TransponderModeDisplay, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.LiveTransponder}}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.ColumnSpan="3"
                                Style="{StaticResource InsetCard}"
                                Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="92"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="ETAPA" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="{Binding PhaseLabelDisplay, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.LivePhaseLabel}}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="RUTA" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="{Binding RouteDisplay, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.LiveRoute}}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="9.2"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                <StackPanel>
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="SISTEMAS Y PARAMETROS"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0"/>
                        <Border DockPanel.Dock="Right"
                                Style="{StaticResource PillBlue}">
                            <Grid>
                                <TextBlock Text="LIVE"
                                           Foreground="{StaticResource AccentLightBlueBrush}"
                                           FontSize="8.5"
                                           FontWeight="Bold"
                                           Visibility="{Binding HasLiveTelemetry, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBlock Text="PREVIEW"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="8.5"
                                           FontWeight="Bold"
                                           Visibility="{Binding HasLiveTelemetry, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Border>
                    </DockPanel>

                    <UniformGrid Columns="3"
                                 Visibility="{Binding HasLiveTelemetry, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Style="{StaticResource InsetCardTight}" Margin="0,0,4,6"><StackPanel><TextBlock Text="NAV" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="{Binding NavOn, Converter={StaticResource BoolToColorConverter}, ConverterParameter=#59D98B|#304355}" Effect="{StaticResource GlowShadow}"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,4,6"><StackPanel><TextBlock Text="BCN" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="{Binding BeaconOn, Converter={StaticResource BoolToColorConverter}, ConverterParameter=#59D98B|#304355}" Effect="{StaticResource GlowShadow}"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,0,6"><StackPanel><TextBlock Text="TAXI" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="{Binding TaxiOn, Converter={StaticResource BoolToColorConverter}, ConverterParameter=#F3C25B|#304355}" Effect="{StaticResource GlowShadow}"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="0,0,4,6"><StackPanel><TextBlock Text="STB" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="{Binding StrobeOn, Converter={StaticResource BoolToColorConverter}, ConverterParameter=#59D98B|#304355}" Effect="{StaticResource GlowShadow}"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,4,6"><StackPanel><TextBlock Text="LAND" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="{Binding LandingOn, Converter={StaticResource BoolToColorConverter}, ConverterParameter=#F56B6B|#304355}" Effect="{StaticResource GlowShadow}"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,0,6"><StackPanel><TextBlock Text="FRENO" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="{Binding LiveParkingBrakeOn, Converter={StaticResource BoolToColorConverter}, ConverterParameter=#59D98B|#304355}" Effect="{StaticResource GlowShadow}"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="0,0,4,0"><StackPanel><TextBlock Text="AP" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="{Binding LiveAutopilotOn, Converter={StaticResource BoolToColorConverter}, ConverterParameter=#59D98B|#304355}" Effect="{StaticResource GlowShadow}"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,4,0"><StackPanel><TextBlock Text="MODO C" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="{Binding LiveCharlieMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter=#59D98B|#304355}" Effect="{StaticResource GlowShadow}"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,0,0"><StackPanel><TextBlock Text="PUERTAS" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="{Binding LiveDoorOpen, Converter={StaticResource BoolToColorConverter}, ConverterParameter=#F3C25B|#304355}" Effect="{StaticResource GlowShadow}"/></StackPanel></Border>
                    </UniformGrid>

                    <UniformGrid Columns="3"
                                 Visibility="{Binding HasLiveTelemetry, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <Border Style="{StaticResource InsetCardTight}" Margin="0,0,4,6"><StackPanel><TextBlock Text="NAV" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="#59D98B" Effect="{StaticResource GlowShadow}"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,4,6"><StackPanel><TextBlock Text="BCN" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="#59D98B" Effect="{StaticResource GlowShadow}"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,0,6"><StackPanel><TextBlock Text="TAXI" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="#304355"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="0,0,4,6"><StackPanel><TextBlock Text="STB" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="#59D98B" Effect="{StaticResource GlowShadow}"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,4,6"><StackPanel><TextBlock Text="LAND" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="#304355"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,0,6"><StackPanel><TextBlock Text="FRENO" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="#304355"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="0,0,4,0"><StackPanel><TextBlock Text="AP" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="#59D98B" Effect="{StaticResource GlowShadow}"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,4,0"><StackPanel><TextBlock Text="MODO C" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="#59D98B" Effect="{StaticResource GlowShadow}"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,0,0"><StackPanel><TextBlock Text="PUERTAS" Style="{StaticResource LedStatusLabel}"/><Ellipse Style="{StaticResource LedStatusDot}" Fill="#304355"/></StackPanel></Border>
                    </UniformGrid>

                    <Border Height="1" Background="#1B2837" Margin="0,8,0,8"/>

                    <UniformGrid Columns="3"
                                 Visibility="{Binding HasLiveTelemetry, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Style="{StaticResource InsetCardTight}" Margin="0,0,4,6"><StackPanel><TextBlock Text="ALTURA" Style="{StaticResource FieldLabel}"/><TextBlock Text="{Binding AltitudeDisplay}" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,4,6"><StackPanel><TextBlock Text="RUMBO" Style="{StaticResource FieldLabel}"/><TextBlock Text="{Binding HeadingDisplay}" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,0,6"><StackPanel><TextBlock Text="GS" Style="{StaticResource FieldLabel}"/><TextBlock Text="{Binding GsDisplay}" Foreground="{StaticResource AccentLightBlueBrush}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="0,0,4,0"><StackPanel><TextBlock Text="V/S" Style="{StaticResource FieldLabel}"/><TextBlock Text="{Binding VsDisplay}" Foreground="{StaticResource AccentLightBlueBrush}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,4,0"><StackPanel><TextBlock Text="VIENTO" Style="{StaticResource FieldLabel}"/><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding WindDir, StringFormat={}{0:000}}" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/><TextBlock Text=" / " Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="2,1,2,0"/><TextBlock Text="{Binding WindSpeed, StringFormat={}{0:F0}}" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/></StackPanel></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,0,0"><StackPanel><TextBlock Text="BLOCK" Style="{StaticResource FieldLabel}"/><TextBlock Text="{Binding ElapsedTimeDisplay}" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/></StackPanel></Border>
                    </UniformGrid>

                    <UniformGrid Columns="3"
                                 Visibility="{Binding HasLiveTelemetry, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <Border Style="{StaticResource InsetCardTight}" Margin="0,0,4,6"><StackPanel><TextBlock Text="ALTURA" Style="{StaticResource FieldLabel}"/><TextBlock Text="{x:Static preview:AcarsPreviewData.LiveAltitude}" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,4,6"><StackPanel><TextBlock Text="RUMBO" Style="{StaticResource FieldLabel}"/><TextBlock Text="{x:Static preview:AcarsPreviewData.LiveHeading}" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,0,6"><StackPanel><TextBlock Text="GS" Style="{StaticResource FieldLabel}"/><TextBlock Text="{x:Static preview:AcarsPreviewData.LiveGs}" Foreground="{StaticResource AccentLightBlueBrush}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="0,0,4,0"><StackPanel><TextBlock Text="V/S" Style="{StaticResource FieldLabel}"/><TextBlock Text="{x:Static preview:AcarsPreviewData.LiveVs}" Foreground="{StaticResource AccentLightBlueBrush}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,4,0"><StackPanel><TextBlock Text="VIENTO" Style="{StaticResource FieldLabel}"/><TextBlock Text="{x:Static preview:AcarsPreviewData.LiveWind}" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/></StackPanel></Border>
                        <Border Style="{StaticResource InsetCardTight}" Margin="4,0,0,0"><StackPanel><TextBlock Text="BLOCK" Style="{StaticResource FieldLabel}"/><TextBlock Text="{x:Static preview:AcarsPreviewData.LiveBlock}" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/></StackPanel></Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="ACARS LOG" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource InsetCard}" Padding="6">
                        <Grid>
                            <TextBox Text="{Binding PirepPreview, Mode=OneWay}"
                                     Background="Transparent"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Height="90"
                                     Visibility="{Binding HasLiveTelemetry, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBox Text="{x:Static preview:AcarsPreviewData.LiveAcarsLog}"
                                     Background="Transparent"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Height="90"
                                     Visibility="{Binding HasLiveTelemetry, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding DataContext.GoDispatchCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Content="CANCELAR"
                        Height="38"
                        Margin="0,0,5,0"/>
                <Button Grid.Column="1"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding FinishFlightCommand}"
                        Content="CERRAR VUELO"
                        Height="40"
                        Margin="5,0,0,0"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
