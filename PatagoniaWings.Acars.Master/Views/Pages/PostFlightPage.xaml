<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.PostFlightPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:preview="clr-namespace:PatagoniaWings.Acars.Master.Preview"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="MaintenanceToggle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="42" Height="22">
                            <Border x:Name="Track"
                                    CornerRadius="11"
                                    Background="#D0DFF0"
                                    BorderBrush="#90B4D8"
                                    BorderThickness="1"/>
                            <Ellipse x:Name="Thumb"
                                     Width="16"
                                     Height="16"
                                     Fill="#8AAAC8"
                                     HorizontalAlignment="Left"
                                     Margin="3,0,0,0"
                                     VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#D0F0E0"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="#4CAF82"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="#22C55E"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.45"/>
                                <Setter TargetName="Thumb" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="PageRoot"
          DataContext="{Binding DataContext.MainVM.PostFlightVM, RelativeSource={RelativeSource AncestorType=Window}}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="Transparent">
            <StackPanel>
                <TextBlock Text="CERRAR VUELO"
                           Style="{StaticResource PageTitle}"
                           Margin="0,0,0,8"/>

                <Border Style="{StaticResource CardBlue}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="{Binding FlightNumberDisplay, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.CloseFlightNumber}}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="Consolas"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding DataContext.MainVM.PreFlightVM.PreparedDispatch.AircraftRegistration, RelativeSource={RelativeSource AncestorType=Window}, TargetNullValue={x:Static preview:AcarsPreviewData.CloseRegistration}}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="10"
                                   Margin="0,2,0,0"/>
                        <TextBlock Text="{Binding RouteDisplay, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.CloseRoute}}"
                                   Foreground="{StaticResource AccentLightBlueBrush}"
                                   FontFamily="Consolas"
                                   FontSize="10.5"
                                   Margin="0,7,0,0"/>
                    </StackPanel>
                </Border>

                <UniformGrid Columns="3" Margin="0,0,0,8">
                    <Border Style="{StaticResource Card}" Margin="0,0,3,0" Padding="8">
                        <StackPanel>
                            <TextBlock Text="PATAGONIA" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding PatagoniaScore, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.ClosePatagoniaScore}}"
                                       Foreground="{StaticResource AccentBlueBrush}"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Margin="3,0,3,0" Padding="8">
                        <StackPanel>
                            <TextBlock Text="PROC" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding ProcedureScore, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.CloseProcedureScore}}"
                                       Foreground="{StaticResource AccentLightBlueBrush}"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Margin="3,0,0,0" Padding="8">
                        <StackPanel>
                            <TextBlock Text="PERF" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding PerformanceScore, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.ClosePerformanceScore}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="COMENTARIOS DEL VUELO" Style="{StaticResource SectionLabel}"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding CloseoutComments, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="74"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="NOTAMS SOBRE EL AVION" Style="{StaticResource SectionLabel}"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding AircraftNotams, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="62"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding SendToMaintenance}"
                                  Style="{StaticResource MaintenanceToggle}"
                                  VerticalAlignment="Top"
                                  Margin="0,2,0,0"/>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="ENVIAR A MANTENIMIENTO"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding MaintenanceHint}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="8.8"
                                       Margin="0,5,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="HABILITACIONES" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding QualificationsDisplay, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.CloseQualifications}}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="9.2"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding SubmitMessage}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="9.2"
                           Margin="0,0,0,8"
                           TextWrapping="Wrap"
                           Visibility="{Binding SubmitMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding DataContext.GoLiveFlightCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Content="CANCELAR"
                            Height="38"
                            Margin="0,0,5,0"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SubmitCommand}"
                            Content="{Binding CloseButtonTitle}"
                            Height="40"
                            Margin="5,0,0,0"
                            IsEnabled="{Binding CanSubmit}"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
