<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.ProfilePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.DataContext>
        <Binding Path="DataContext.ProfileVM" RelativeSource="{RelativeSource AncestorType=Window}"/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <Style x:Key="PLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="PValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#0F1827"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,14"/>
        </Style>
        <Style x:Key="GCard" TargetType="Border">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="22"/>
        </Style>
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Padding="20,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#0A7EA4" Offset="0"/>
                                    <GradientStop Color="#0CA789" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.88"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScorePill" TargetType="Border">
            <Setter Property="Background" Value="#0D1520"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="980" Margin="0,4,0,28">

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="PILOTO" Foreground="#2D9CDB" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text=" · MI PERFIL" Foreground="#475569" FontSize="11" VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock Text="Mi Perfil" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,0,0,22"/>

        <!-- Hero card -->
        <Border Margin="0,0,0,14" CornerRadius="14" BorderThickness="1" Padding="28,22">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0B1525" Offset="0"/>
                    <GradientStop Color="#060E1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1A4A8A" Offset="0"/>
                    <GradientStop Color="#0CA789" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Avatar -->
                <Grid Grid.Column="0" Width="88" Height="88">
                    <Ellipse Width="88" Height="88">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#1A3A6A" Offset="0"/>
                                <GradientStop Color="#060E1A" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="88" Height="88" StrokeThickness="2">
                        <Ellipse.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2D9CDB" Offset="0"/>
                                <GradientStop Color="#0CA789" Offset="1"/>
                            </LinearGradientBrush>
                        </Ellipse.Stroke>
                    </Ellipse>
                    <TextBlock Text="{Binding Pilot.CallSign, TargetNullValue=?}"
                               Foreground="White" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <!-- Info piloto -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Pilot.FullName, TargetNullValue=Cargando...}"
                               Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="{Binding Pilot.CallSign}" Foreground="#38BDF8"
                                   FontFamily="Consolas" FontSize="14" FontWeight="Bold" Margin="0,0,12,0"/>
                        <Border Background="#0A1F14" CornerRadius="4" Padding="8,3">
                            <TextBlock Text="{Binding Pilot.RankName, TargetNullValue=—}"
                                       Foreground="#34D399" FontSize="11" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    <!-- Barra progreso rango -->
                    <TextBlock Text="PROGRESO AL SIGUIENTE RANGO" Foreground="#334155" FontSize="9" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Grid>
                        <Border Background="#0D1520" CornerRadius="4" Height="6"/>
                        <Border CornerRadius="4" Height="6" HorizontalAlignment="Left"
                                Width="{Binding ProgressToNextRankValue}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#2D9CDB" Offset="0"/>
                                    <GradientStop Color="#0CA789" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- Email -->
                <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="EMAIL" Foreground="#334155" FontSize="9" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Pilot.Email, TargetNullValue=—}"
                               Foreground="#475569" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stats 3 columnas -->
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource StatCard}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="HORAS DE VUELO" Style="{StaticResource PLabel}" HorizontalAlignment="Center"/>
                    <TextBlock Foreground="#38BDF8" FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                               HorizontalAlignment="Center"
                               Text="{Binding Pilot.TotalHours, StringFormat={}{0:F1}, TargetNullValue=0.0}"/>
                    <TextBlock Text="h totales" Foreground="#334155" FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource StatCard}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="VUELOS COMPLETADOS" Style="{StaticResource PLabel}" HorizontalAlignment="Center"/>
                    <TextBlock Foreground="#34D399" FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                               HorizontalAlignment="Center"
                               Text="{Binding Pilot.TotalFlights, TargetNullValue=0}"/>
                    <TextBlock Text="pirons aprobados" Foreground="#334155" FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource StatCard}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="PUNTOS ACUMULADOS" Style="{StaticResource PLabel}" HorizontalAlignment="Center"/>
                    <TextBlock Foreground="#F59E0B" FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                               HorizontalAlignment="Center"
                               Text="{Binding Pilot.Points, TargetNullValue=0}"/>
                    <TextBlock Text="pts acumulados" Foreground="#334155" FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Info + Preferencias -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- Info piloto -->
            <Border Grid.Column="0" Style="{StaticResource GCard}">
                <StackPanel>
                    <TextBlock Text="INFORMACIÓN DEL PILOTO" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="0,0,0,18"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource PLabel}" Text="CALLSIGN"/>
                            <TextBlock Style="{StaticResource PValue}" FontFamily="Consolas" FontSize="18"
                                       Text="{Binding Pilot.CallSign, TargetNullValue=—}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource PLabel}" Text="RANGO ACTUAL"/>
                            <TextBlock Style="{StaticResource PValue}"
                                       Text="{Binding Pilot.RankName, TargetNullValue=—}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource PLabel}" Text="NOMBRE COMPLETO"/>
                            <TextBlock Style="{StaticResource PValue}"
                                       Text="{Binding Pilot.FullName, TargetNullValue=—}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource PLabel}" Text="CORREO ELECTRÓNICO"/>
                            <TextBlock Style="{StaticResource PValue}" FontSize="12"
                                       Text="{Binding Pilot.Email, TargetNullValue=—}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="SISTEMA DE PUNTUACIÓN" Foreground="#334155" FontSize="9" FontWeight="Bold" Margin="0,0,0,12"/>
                    <WrapPanel>
                        <Border Style="{StaticResource ScorePill}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="#34D399" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Aterrizaje suave (&lt;150 fpm)" Foreground="#64748B" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource ScorePill}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="#34D399" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Luces strobe encendidas" Foreground="#64748B" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource ScorePill}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="#34D399" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Transponder modo C" Foreground="#64748B" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource ScorePill}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="#34D399" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="No pausar el simulador" Foreground="#64748B" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource ScorePill}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="#34D399" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Ruta completada" Foreground="#64748B" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource ScorePill}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="#34D399" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="G-force normal (&lt;2.0g)" Foreground="#64748B" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Preferencias -->
            <Border Grid.Column="2" Style="{StaticResource GCard}">
                <StackPanel>
                    <TextBlock Text="PREFERENCIAS" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="0,0,0,18"/>

                    <TextBlock Style="{StaticResource PLabel}" Text="IDIOMA DEL COPILOTO" Margin="0,0,0,6"/>
                    <ComboBox Style="{StaticResource DarkComboBox}" Height="38" Margin="0,0,0,16"
                              SelectedValue="{Binding PreferredLanguage, Mode=TwoWay}">
                        <ComboBoxItem Content="Español" Tag="ESP"/>
                        <ComboBoxItem Content="English" Tag="ENG"/>
                    </ComboBox>

                    <TextBlock Style="{StaticResource PLabel}" Text="VOZ DEL COPILOTO" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <RadioButton Content="Femenina" IsChecked="{Binding VoiceFemale, Mode=TwoWay}"
                                     Foreground="#94A3B8" FontSize="12" Margin="0,0,16,0"
                                     GroupName="VoiceGroup"/>
                        <RadioButton Content="Masculina" IsChecked="{Binding VoiceFemale, Converter={StaticResource BoolInverseConverter}, Mode=TwoWay}"
                                     Foreground="#94A3B8" FontSize="12"
                                     GroupName="VoiceGroup"/>
                    </StackPanel>

                    <Button Style="{StaticResource SaveBtn}" Command="{Binding SavePreferencesCommand}">
                        <TextBlock Text="✓  Guardar Preferencias"/>
                    </Button>

                    <TextBlock Text="Cargando perfil..." Foreground="#2D9CDB" FontSize="11"
                               Margin="0,12,0,0" HorizontalAlignment="Center"
                               Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}"/>
                </StackPanel>
            </Border>
        </Grid>

    </StackPanel>
    </ScrollViewer>
</UserControl>
