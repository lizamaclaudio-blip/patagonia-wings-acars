<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.ProfilePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.DataContext>
        <Binding Path="ProfileVM" RelativeSource="{RelativeSource AncestorType=Window}"/>
    </UserControl.DataContext>

    <StackPanel MaxWidth="760">
        <TextBlock Text="Mi Perfil" Style="{StaticResource PageTitle}"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Info piloto -->
            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Información del Piloto" FontSize="15" FontWeight="SemiBold"
                                   Foreground="White" FontFamily="Segoe UI" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CALLSIGN" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding Pilot.CallSign}"
                                           Foreground="White" FontFamily="Consolas"
                                           FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="RANGO" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding Pilot.RankName}"
                                           Foreground="#FFD700" FontSize="14"
                                           FontWeight="SemiBold" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="NOMBRE COMPLETO" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding Pilot.FullName}"
                                           Foreground="White" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="EMAIL" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding Pilot.Email}"
                                           Foreground="#8B949E" FontSize="13"/>
                            </StackPanel>
                        </Grid>

                        <Separator Background="{StaticResource BorderBrush}" Margin="0,8"/>

                        <!-- Stats del piloto -->
                        <UniformGrid Columns="3" Margin="0,8,0,0">
                            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock Text="HORAS" Style="{StaticResource FieldLabel}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Pilot.TotalHours, StringFormat={}{0:F1}}"
                                           Foreground="{StaticResource AccentLightBlueBrush}"
                                           FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock Text="VUELOS" Style="{StaticResource FieldLabel}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Pilot.TotalFlights}"
                                           Foreground="{StaticResource AccentLightBlueBrush}"
                                           FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock Text="PUNTOS" Style="{StaticResource FieldLabel}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Pilot.Points}"
                                           Foreground="#FFD700"
                                           FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Preferencias -->
            <Border Grid.Column="2" Style="{StaticResource Card}" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Preferencias" FontSize="15" FontWeight="SemiBold"
                               Foreground="White" FontFamily="Segoe UI" Margin="0,0,0,16"/>

                    <!-- Idioma de voz -->
                    <TextBlock Text="IDIOMA DEL COPILOTO" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Style="{StaticResource DarkComboBox}" Height="36"
                              SelectedValue="{Binding PreferredLanguage}"
                              SelectedValuePath="Tag" Margin="0,4,0,12">
                        <ComboBoxItem Tag="ESP" Content="Español"/>
                        <ComboBoxItem Tag="CHI" Content="Chileno"/>
                        <ComboBoxItem Tag="BRA" Content="Português (BR)"/>
                    </ComboBox>

                    <!-- Voz femenina/masculina -->
                    <TextBlock Text="VOZ DEL COPILOTO" Style="{StaticResource FieldLabel}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,16">
                        <RadioButton Content="Femenina" IsChecked="{Binding VoiceFemale}"
                                     Foreground="White" FontFamily="Segoe UI" Margin="0,0,16,0"/>
                        <RadioButton Content="Masculina" Foreground="White" FontFamily="Segoe UI"/>
                    </StackPanel>

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,16"/>

                    <Button Content="Guardar Preferencias" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SavePreferencesCommand}" Height="38"/>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
