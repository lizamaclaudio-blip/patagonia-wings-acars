<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.ProfilePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.DataContext>
        <Binding Path="DataContext.ProfileVM" RelativeSource="{RelativeSource AncestorType=Window}"/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="ProfileValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1040" Margin="0,0,0,20">
            <TextBlock Text="PILOTO - DATOS REALES" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
            <TextBlock Text="Mi Perfil" Style="{StaticResource PageTitle}" Margin="0,0,0,18"/>

            <Border Margin="0,0,0,16" CornerRadius="14" BorderThickness="1" Padding="26,24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#111A27" Offset="0"/>
                        <GradientStop Color="#0A1018" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A6FB5" Offset="0"/>
                        <GradientStop Color="#0CA789" Offset="0.7"/>
                        <GradientStop Color="#FFD700" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96"/>
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <Grid Width="96" Height="96">
                        <Ellipse StrokeThickness="2">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#21476A" Offset="0"/>
                                    <GradientStop Color="#0B1420" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2D9CDB" Offset="0"/>
                                    <GradientStop Color="#0CA789" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                        </Ellipse>
                        <TextBlock Text="{Binding PilotInitials}" Foreground="White" FontSize="28"
                                   FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Pilot.FullName, TargetNullValue=Sin nombre cargado}"
                                   Foreground="White" FontSize="28" FontWeight="Bold" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Border Style="{StaticResource PillBlue}" Margin="0,0,10,0">
                                <TextBlock Text="{Binding Pilot.CallSign, TargetNullValue=Sin callsign}"
                                           Foreground="#2D9CDB" FontFamily="Consolas" FontWeight="Bold"/>
                            </Border>
                            <Border Style="{StaticResource PillGold}">
                                <TextBlock Text="{Binding Pilot.RankName, TargetNullValue=Sin rango}"
                                           Foreground="#FFD700" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding Pilot.Email, TargetNullValue=Sin correo cargado}"
                                   Foreground="#8B949E" FontSize="13" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding ProgressToNextRank, StringFormat=Progreso al siguiente rango: {0}}"
                                   Foreground="#0CA789" FontSize="12" Margin="0,10,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="3" Style="{StaticResource CardBlue}" Padding="18,16">
                        <StackPanel>
                            <TextBlock Text="ESTADO DEL PERFIL" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="Sincronizado desde Supabase" Foreground="#2D9CDB"
                                       FontSize="16" FontWeight="Bold" Margin="0,2,0,14"/>
                            <TextBlock Text="Aeropuerto actual" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding CurrentAirportDisplay}" Style="{StaticResource ProfileValueText}" Margin="0,2,0,12"/>
                            <TextBlock Text="Hub base" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding BaseHubDisplay}" Style="{StaticResource ProfileValueText}" Margin="0,2,0,12"/>
                            <TextBlock Text="Simulador preferido" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding PreferredSimulatorDisplay}" Style="{StaticResource ProfileValueText}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <UniformGrid Columns="4" Margin="0,0,0,16">
                <Border Style="{StaticResource CardBlue}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="HORAS DE VUELO" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding Pilot.TotalHours, StringFormat={}{0:F1}, TargetNullValue=0.0}" Style="{StaticResource StatBig}" Margin="0,6,0,0"/>
                        <TextBlock Text="horas registradas" Foreground="#606C7A" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardTeal}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="VUELOS COMPLETADOS" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding Pilot.TotalFlights, TargetNullValue=0}" Foreground="#0CA789" FontFamily="Consolas" FontSize="32" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="pireps aprobados" Foreground="#606C7A" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardGold}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="PUNTOS" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding Pilot.Points, TargetNullValue=0}" Foreground="#FFD700" FontFamily="Consolas" FontSize="32" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="progreso de carrera" Foreground="#606C7A" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardGreen}">
                    <StackPanel>
                        <TextBlock Text="DISTANCIA" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding TotalDistanceDisplay}" Foreground="#3FB950" FontFamily="Consolas" FontSize="28" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="distancia acumulada" Foreground="#606C7A" FontSize="11"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="0.95*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Identidad Operativa" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,12,12">
                                    <TextBlock Text="CALLSIGN" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="{Binding Pilot.CallSign, TargetNullValue=Sin callsign}" Style="{StaticResource ProfileValueText}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="RANGO" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="{Binding Pilot.RankName, TargetNullValue=Sin rango}" Style="{StaticResource ProfileValueText}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,12,12">
                                    <TextBlock Text="USUARIO" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="{Binding Pilot.Username, TargetNullValue=Sin usuario}" Style="{StaticResource ProfileValueText}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="CORREO" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="{Binding Pilot.Email, TargetNullValue=Sin correo}" Style="{StaticResource ProfileValueText}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="HORAS TRANSFERIDAS" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="{Binding TransferredHoursDisplay}" Style="{StaticResource ProfileValueText}"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="PUNTOS LEGADO" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="{Binding LegadoPointsDisplay}" Style="{StaticResource ProfileValueText}"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Actividad y Carrera" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,12,14">
                                    <TextBlock Text="PULSO10" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="{Binding Pulso10Display}" Style="{StaticResource ProfileValueText}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,14">
                                    <TextBlock Text="RUTA10" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="{Binding Ruta10Display}" Style="{StaticResource ProfileValueText}"/>
                                </StackPanel>
                            </UniformGrid>
                            <TextBlock Text="CALIFICACIONES ACTIVAS" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding QualificationsDisplay}" Foreground="#8B949E" TextWrapping="Wrap" Margin="0,4,0,14"/>
                            <TextBlock Text="CERTIFICACIONES ACTIVAS" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding CertificationsDisplay}" Foreground="#8B949E" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Preferencias" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <TextBlock Text="IDIOMA DEL COPILOTO" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Style="{StaticResource DarkComboBox}" Height="38"
                                      SelectedValue="{Binding PreferredLanguage}"
                                      SelectedValuePath="Tag" Margin="0,4,0,12">
                                <ComboBoxItem Tag="ESP" Content="Espanol"/>
                                <ComboBoxItem Tag="CHI" Content="Chileno"/>
                                <ComboBoxItem Tag="BRA" Content="Portugues (BR)"/>
                            </ComboBox>

                            <TextBlock Text="VOZ DEL COPILOTO" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Style="{StaticResource DarkComboBox}" Height="38"
                                      SelectedIndex="{Binding VoiceSelection}" Margin="0,4,0,16">
                                <ComboBoxItem Content="Femenina"/>
                                <ComboBoxItem Content="Masculina"/>
                            </ComboBox>

                            <Button Content="GUARDAR PREFERENCIAS"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SavePreferencesCommand}" Height="40"/>

                            <TextBlock Text="Cargando perfil real desde Supabase..." Foreground="#2D9CDB"
                                       FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"
                                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBlue}">
                        <StackPanel>
                            <TextBlock Text="Resumen de Configuracion" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <TextBlock Text="Idioma activo" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding PreferredLanguageLabel}" Style="{StaticResource ProfileValueText}" Margin="0,2,0,12"/>
                            <TextBlock Text="Voz activa" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding VoiceLabel}" Style="{StaticResource ProfileValueText}" Margin="0,2,0,12"/>
                            <TextBlock Text="Avatar" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding Pilot.AvatarUrl, TargetNullValue=Sin avatar configurado}" Foreground="#8B949E" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
