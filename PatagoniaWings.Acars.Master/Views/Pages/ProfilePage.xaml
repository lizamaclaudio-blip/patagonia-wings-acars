<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.ProfilePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
<UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>

        <Style x:Key="SHead" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0284C7"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,1"/>
        </Style>

        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,7"/>
        </Style>

        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,1,0,0"/>
        </Style>

        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0284C7" Offset="0"/>
                        <GradientStop Color="#0EA5E9" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel x:Name="PageRoot" Background="#EFF6FF">

        <TextBlock Text="Cargando perfil..."
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}"
                   FontSize="11" Foreground="#0EA5E9" FontFamily="Segoe UI"
                   HorizontalAlignment="Center" Margin="0,0,0,8"/>

        <!-- HERO CARD -->
        <Border Style="{StaticResource Card}" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Avatar -->
                <Border Grid.Column="0" Width="60" Height="60" CornerRadius="30"
                        BorderBrush="#BFDBFE" BorderThickness="2" Margin="0,0,14,0"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0EA5E9" Offset="0"/>
                            <GradientStop Color="#0284C7" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="{Binding Pilot.CallSign, FallbackValue='?'}"
                               FontSize="15" FontWeight="Bold" FontFamily="Segoe UI"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Pilot.FullName, FallbackValue='—'}"
                               FontSize="15" FontWeight="Bold" Foreground="#0F172A" FontFamily="Segoe UI"/>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,4">
                        <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                                CornerRadius="8" Padding="8,2" Margin="0,0,6,0">
                            <TextBlock Text="{Binding Pilot.CallSign, FallbackValue='—'}"
                                       FontSize="11" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="#0284C7"/>
                        </Border>
                        <Border Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="1"
                                CornerRadius="8" Padding="8,2">
                            <TextBlock Text="{Binding Pilot.RankName, FallbackValue='—'}"
                                       FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                                       Foreground="#15803D"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding Pilot.Email, FallbackValue='—'}"
                               FontSize="10" Foreground="#64748B" FontFamily="Segoe UI"/>

                    <!-- Progress bar -->
                    <StackPanel Margin="0,7,0,0">
                        <TextBlock FontSize="9" Foreground="#94A3B8" FontFamily="Segoe UI" Margin="0,0,0,2">
                            <Run Text="Progreso al siguiente rango: "/>
                            <Run Text="{Binding ProgressToNextRank, Mode=OneWay, FallbackValue='—'}"
                                 FontWeight="SemiBold" Foreground="#0284C7"/>
                        </TextBlock>
                        <Border Height="4" CornerRadius="2" Background="#E2E8F0" MaxWidth="260" HorizontalAlignment="Left">
                            <Border CornerRadius="2" HorizontalAlignment="Left" Height="4"
                                    Width="{Binding ProgressToNextRankValue, Mode=OneWay}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#0EA5E9" Offset="0"/>
                                        <GradientStop Color="#38BDF8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Rank image -->
                <Image Grid.Column="2" Width="50" Height="50"
                       VerticalAlignment="Center" Margin="10,0,0,0" Opacity="0.85">
                    <Image.Source>
                        <Binding Path="RankImageResource"/>
                    </Image.Source>
                </Image>
            </Grid>
        </Border>

        <!-- STATS ROW -->
        <Border Style="{StaticResource Card}" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Pilot.TotalHours, StringFormat='{}{0:N0}', FallbackValue='—'}"
                               Style="{StaticResource StatValue}" Foreground="#0284C7"/>
                    <TextBlock Text="Horas totales" Style="{StaticResource StatLabel}"/>
                </StackPanel>
                <Rectangle Grid.Column="1" Fill="#E2E8F0" Width="1"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="{Binding Pilot.TotalFlights, FallbackValue='—'}"
                               Style="{StaticResource StatValue}" Foreground="#10B981"/>
                    <TextBlock Text="Vuelos" Style="{StaticResource StatLabel}"/>
                </StackPanel>
                <Rectangle Grid.Column="3" Fill="#E2E8F0" Width="1"/>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="{Binding Pilot.Points, FallbackValue='—'}"
                               Style="{StaticResource StatValue}" Foreground="#F59E0B"/>
                    <TextBlock Text="Puntos" Style="{StaticResource StatLabel}"/>
                </StackPanel>
                <Rectangle Grid.Column="5" Fill="#E2E8F0" Width="1"/>
                <StackPanel Grid.Column="6">
                    <TextBlock Text="{Binding Pilot.LegadoPoints, FallbackValue='—'}"
                               Style="{StaticResource StatValue}" Foreground="#8B5CF6"/>
                    <TextBlock Text="Legado" Style="{StaticResource StatLabel}"/>
                </StackPanel>
                <Rectangle Grid.Column="7" Fill="#E2E8F0" Width="1"/>
                <StackPanel Grid.Column="8">
                    <TextBlock Text="{Binding Pilot.TotalDistance, StringFormat='{}{0:N0}', FallbackValue='—'}"
                               Style="{StaticResource StatValue}" Foreground="#64748B" FontSize="15"/>
                    <TextBlock Text="nm totales" Style="{StaticResource StatLabel}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DATA + SCORES + PREFERENCES -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- DATOS DEL PILOTO -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="DATOS DEL PILOTO" Style="{StaticResource SHead}"/>

                    <TextBlock Text="CALLSIGN" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Pilot.CallSign, FallbackValue='—'}"
                               Style="{StaticResource FieldValue}" FontFamily="Consolas" Foreground="#0284C7" FontSize="13"/>

                    <TextBlock Text="NOMBRE COMPLETO" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Pilot.FullName, FallbackValue='—'}" Style="{StaticResource FieldValue}"/>

                    <TextBlock Text="EMAIL" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Pilot.Email, FallbackValue='—'}"
                               Style="{StaticResource FieldValue}" FontSize="10"/>

                    <TextBlock Text="BASE HUB" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Pilot.BaseHubCode, FallbackValue='—'}"
                               Style="{StaticResource FieldValue}" FontFamily="Consolas"/>

                    <TextBlock Text="AEROPUERTO ACTUAL" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Pilot.CurrentAirportCode, FallbackValue='—'}"
                               Style="{StaticResource FieldValue}" FontFamily="Consolas"/>

                    <TextBlock Text="SIMULADOR PREFERIDO" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Pilot.PreferredSimulator, FallbackValue='—'}" Style="{StaticResource FieldValue}"/>

                    <TextBlock Text="HABILITACIONES" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Pilot.ActiveQualifications, FallbackValue='Sin registro'}"
                               FontSize="10" Foreground="#334155" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,7"/>

                    <TextBlock Text="CERTIFICACIONES" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Pilot.ActiveCertifications, FallbackValue='Sin registro'}"
                               FontSize="10" Foreground="#334155" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- MÉTRICAS -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="MÉTRICAS DE DESEMPEÑO" Style="{StaticResource SHead}"/>

                    <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                            CornerRadius="7" Padding="10,7" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="PULSO 10" Style="{StaticResource FieldLabel}" Margin="0"/>
                                <TextBlock Text="Regularidad últimos 10 vuelos"
                                           FontSize="9" Foreground="#94A3B8" FontFamily="Segoe UI"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Pilot.Pulso10, StringFormat='{}{0:F1}', FallbackValue='—'}"
                                       FontSize="18" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="#0284C7" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                            CornerRadius="7" Padding="10,7" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="RUTA 10" Style="{StaticResource FieldLabel}" Margin="0"/>
                                <TextBlock Text="Score de ruta últimos 10 vuelos"
                                           FontSize="9" Foreground="#94A3B8" FontFamily="Segoe UI"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Pilot.Ruta10, StringFormat='{}{0:F1}', FallbackValue='—'}"
                                       FontSize="18" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="#0284C7" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="7" Padding="10,7">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="HORAS TRANSFERIDAS" Style="{StaticResource FieldLabel}" Margin="0"/>
                                <TextBlock Text="Historial acumulado"
                                           FontSize="9" Foreground="#94A3B8" FontFamily="Segoe UI"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Pilot.TransferredHours, StringFormat='{}{0:N0}', FallbackValue='—'}"
                                       FontSize="15" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="#64748B" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- PREFERENCIAS -->
            <Border Grid.Column="4" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="PREFERENCIAS" Style="{StaticResource SHead}"/>

                    <TextBlock Text="IDIOMA COPILOTO" Style="{StaticResource FieldLabel}"/>
                    <ComboBox SelectedValue="{Binding PreferredLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Tag" Margin="0,0,0,10"
                              FontSize="11" FontFamily="Segoe UI"
                              BorderBrush="#BFDBFE" BorderThickness="1"
                              Background="#FFFFFF" Foreground="#0F172A" Padding="6,5">
                        <ComboBoxItem Content="Español" Tag="ESP"/>
                        <ComboBoxItem Content="English" Tag="ENG"/>
                    </ComboBox>

                    <TextBlock Text="VOZ COPILOTO" Style="{StaticResource FieldLabel}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,12">
                        <RadioButton Content="Femenina" GroupName="VoiceGroup"
                                     IsChecked="{Binding VoiceFemale, Mode=TwoWay}"
                                     FontSize="11" FontFamily="Segoe UI"
                                     Foreground="#334155" Margin="0,0,10,0"/>
                        <RadioButton Content="Masculina" GroupName="VoiceGroup"
                                     FontSize="11" FontFamily="Segoe UI" Foreground="#334155"/>
                    </StackPanel>

                    <Button Style="{StaticResource SaveBtn}"
                            Command="{Binding SavePreferencesCommand}"
                            HorizontalAlignment="Stretch">
                        <TextBlock Text="Guardar preferencias"/>
                    </Button>

                    <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}"
                                Margin="0,8,0,0">
                        <TextBlock Text="Guardando..." FontSize="10" Foreground="#0EA5E9"
                                   FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </StackPanel>
</UserControl>
