<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <DataTemplate x:Key="RecentFlightTemplate">
            <Border Style="{StaticResource InsetCardTight}" Margin="0,0,0,5" Padding="7,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Ellipse Width="5"
                             Height="5"
                             Fill="{StaticResource AccentBlueBrush}"
                             VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding FlightNumber}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Consolas"
                               FontSize="9.5"
                               FontWeight="SemiBold"
                               Margin="7,0,8,0"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DepartureIcao}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="8.8"/>
                        <TextBlock Text=" -> "
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="8.8"/>
                        <TextBlock Text="{Binding ArrivalIcao}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="8.8"/>
                    </StackPanel>

                    <Border Grid.Column="3"
                            Style="{StaticResource PillBlue}"
                            Padding="6,2"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Score, Converter={StaticResource ScoreToDisplayConverter}}"
                                   Foreground="{StaticResource AccentLightBlueBrush}"
                                   FontSize="8.1"
                                   FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="PageRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="SALA DE PILOTOS"
                   Style="{StaticResource PageTitle}"
                   Margin="0,0,0,7"/>

        <Border Grid.Row="1" Style="{StaticResource CardBlue}" Margin="0,0,0,7" Padding="9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="66"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="60"
                        Height="60"
                        CornerRadius="30"
                        BorderBrush="{StaticResource AccentBlueBrush}"
                        BorderThickness="1.2"
                        Background="#111B28"
                        VerticalAlignment="Top"
                        ClipToBounds="True">
                    <Grid>
                        <Border Background="#0E1621"/>
                        <TextBlock Text="&#xE77B;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="#5B77A1"
                                   FontSize="23"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Image Source="{Binding PilotAvatarSource}"
                               Stretch="UniformToFill"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="{Binding PilotCallsignDisplay}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="16"
                               FontWeight="Bold"
                               FontFamily="Consolas"/>
                    <TextBlock Text="{Binding PilotNameDisplay}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="10"
                               Margin="0,2,0,0"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="28"/>

                    <Grid Margin="0,7,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource PillGreen}" Margin="0,0,6,0" HorizontalAlignment="Left">
                            <TextBlock Text="ACTIVO"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="8.2"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <Border Grid.Column="1"
                                Style="{StaticResource PillBlue}"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{Binding PilotLocationCodeDisplay}"
                                       Foreground="{StaticResource AccentLightBlueBrush}"
                                       FontSize="8.2"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,7">
            <Border Style="{StaticResource Card}" Margin="0,0,3,0" Padding="7">
                <StackPanel>
                    <TextBlock Text="HORAS" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding PilotHoursDisplay}"
                               Foreground="{StaticResource AccentLightBlueBrush}"
                               FontSize="13"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="3,0,3,0" Padding="7">
                <StackPanel>
                    <TextBlock Text="PW SCORE" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding PilotScoreDisplay}"
                               Foreground="{StaticResource AccentBlueBrush}"
                               FontSize="13"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="3,0,0,0" Padding="7">
                <StackPanel>
                    <TextBlock Text="RANGO" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding PilotRankDisplay}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="9.2"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="24"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,0,0,7" Padding="9,8">
            <StackPanel>
                <TextBlock Text="UBICACION ACTUAL" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding PilotLocationCodeDisplay}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="17"
                           FontWeight="Bold"
                           FontFamily="Consolas"/>
                <TextBlock Text="{Binding PilotLocationSubtitle}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="8.5"
                           Margin="0,2,0,0"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           MaxHeight="24"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,0,0,7" Padding="9,8">
            <StackPanel>
                <DockPanel Margin="0,0,0,5">
                    <TextBlock Text="ULTIMOS VUELOS"
                               Style="{StaticResource SectionLabel}"
                               Margin="0"/>
                    <Border DockPanel.Dock="Right"
                            Style="{StaticResource PillBlue}">
                        <TextBlock Text="{Binding MainVM.DashboardVM.RecentFlights.Count}"
                                   Foreground="{StaticResource AccentLightBlueBrush}"
                                   FontSize="8.2"
                                   FontWeight="Bold"/>
                    </Border>
                </DockPanel>

                <ItemsControl ItemsSource="{Binding MainVM.DashboardVM.RecentFlights}"
                              ItemTemplate="{StaticResource RecentFlightTemplate}"/>

                <TextBlock Text="Sin vuelos recientes registrados."
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="8.8"
                           Margin="0,2,0,0"
                           TextWrapping="Wrap"
                           Visibility="{Binding MainVM.DashboardVM.RecentFlights.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="5" Style="{StaticResource Card}" Margin="0,0,0,7" Padding="9,8">
            <StackPanel>
                <TextBlock Text="COMUNIDAD"
                           Style="{StaticResource SectionLabel}"
                           Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="7"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource InsetCard}" Padding="7,6">
                        <StackPanel>
                            <TextBlock Text="ONLINE" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding OnlinePilotsDisplay}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="14"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource InsetCard}"
                            Padding="7,6">
                        <StackPanel>
                            <TextBlock Text="EN BASE" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding BasePilotsDisplay}"
                                       Foreground="{StaticResource AccentLightBlueBrush}"
                                       FontSize="14"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="7" Margin="0,4,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding OpenSupportCommand}"
                    Content="SOPORTE"
                    Height="38"
                    Margin="0,0,5,0"
                    Background="#101A25"
                    BorderBrush="#273849"/>
            <Button Grid.Column="1"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding BeginDispatchFlowCommand}"
                    Content="COMENZAR"
                    Height="40"
                    Margin="5,0,0,0"/>
        </Grid>
    </Grid>
</UserControl>
