<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <DataTemplate x:Key="RecentFlightTemplate">
            <Border Background="#F0F6FF" BorderBrush="#C8DDF5" BorderThickness="1"
                    CornerRadius="8" Padding="8,5" Margin="0,0,0,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Ellipse Width="5" Height="5"
                             Fill="#1565C0"
                             VerticalAlignment="Center"
                             Margin="0,0,7,0"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding FlightNumber}"
                               Foreground="#0D1F3C"
                               FontFamily="Consolas"
                               FontSize="9.5"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock Text="{Binding DepartureIcao}"
                                   Foreground="#1E3A64"
                                   FontSize="8.8"/>
                        <TextBlock Text=" › "
                                   Foreground="#4A6E9A"
                                   FontSize="8.8"/>
                        <TextBlock Text="{Binding ArrivalIcao}"
                                   Foreground="#1E3A64"
                                   FontSize="8.8"/>
                    </StackPanel>

                    <Border Grid.Column="3"
                            Background="#E0EDFF" BorderBrush="#90B4D8" BorderThickness="1"
                            CornerRadius="8" Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Score, Converter={StaticResource ScoreToDisplayConverter}}"
                                   Foreground="#1565C0"
                                   FontSize="8.1"
                                   FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="PageRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- PAGE TITLE -->
        <TextBlock Text="SALA DE PILOTOS"
                   Foreground="#0D1F3C"
                   FontSize="14"
                   FontWeight="Bold"
                   FontFamily="Segoe UI"
                   Margin="0,0,0,8"/>

        <!-- PILOT CARD -->
        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#B8D0EA"
                BorderThickness="1.5"
                CornerRadius="14"
                Padding="12,10"
                Margin="0,0,0,7"
                Effect="{StaticResource PanelShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Avatar circle -->
                <Border Width="56"
                        Height="56"
                        CornerRadius="28"
                        BorderBrush="#90B4D8"
                        BorderThickness="2"
                        Background="#E8F2FF"
                        VerticalAlignment="Center"
                        ClipToBounds="True">
                    <Grid>
                        <TextBlock Text="&#xE77B;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="#6A9DC8"
                                   FontSize="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Image Source="{Binding PilotAvatarSource}"
                               Stretch="UniformToFill"/>
                    </Grid>
                </Border>

                <!-- Pilot info -->
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding PilotCallsignDisplay}"
                               Foreground="#0D1F3C"
                               FontSize="17"
                               FontWeight="Bold"
                               FontFamily="Consolas"/>
                    <TextBlock Text="{Binding PilotNameDisplay}"
                               Foreground="#1E3A64"
                               FontSize="9.5"
                               FontFamily="Segoe UI"
                               Margin="0,2,0,0"
                               TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                        <Border Background="#E0F5EC" BorderBrush="#4CAF82" BorderThickness="1"
                                CornerRadius="10" Padding="8,3" Margin="0,0,6,0">
                            <TextBlock Text="ACTIVO"
                                       Foreground="#1B6B3A"
                                       FontSize="8"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"/>
                        </Border>
                        <Border Background="#E0EDFF" BorderBrush="#90B4D8" BorderThickness="1"
                                CornerRadius="10" Padding="8,3">
                            <TextBlock Text="{Binding PilotLocationCodeDisplay}"
                                       Foreground="#1565C0"
                                       FontSize="8"
                                       FontWeight="Bold"
                                       FontFamily="Consolas"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- STATS ROW: HORAS / SCORE / RANGO -->
        <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,7">
            <Border Background="#FFFFFF" BorderBrush="#B8D0EA" BorderThickness="1.5"
                    CornerRadius="12" Padding="6,8" Margin="0,0,4,0"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="HORAS"
                               Foreground="#4A6E9A"
                               FontSize="7.5"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding PilotHoursDisplay}"
                               Foreground="#1565C0"
                               FontSize="15"
                               FontWeight="Bold"
                               FontFamily="Consolas"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Background="#FFFFFF" BorderBrush="#B8D0EA" BorderThickness="1.5"
                    CornerRadius="12" Padding="6,8" Margin="2,0,2,0"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="PW SCORE"
                               Foreground="#4A6E9A"
                               FontSize="7.5"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding PilotScoreDisplay}"
                               Foreground="#0288D1"
                               FontSize="15"
                               FontWeight="Bold"
                               FontFamily="Consolas"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Background="#FFFFFF" BorderBrush="#B8D0EA" BorderThickness="1.5"
                    CornerRadius="12" Padding="6,8" Margin="4,0,0,0"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="RANGO"
                               Foreground="#4A6E9A"
                               FontSize="7.5"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding PilotRankDisplay}"
                               Foreground="#0D1F3C"
                               FontSize="9.5"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               TextAlignment="Center"
                               MaxHeight="28"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- UBICACION ACTUAL -->
        <Border Grid.Row="3"
                Background="#FFFFFF"
                BorderBrush="#B8D0EA"
                BorderThickness="1.5"
                CornerRadius="12"
                Padding="12,10"
                Margin="0,0,0,7"
                Effect="{StaticResource PanelShadow}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="UBICACIÓN ACTUAL"
                           Foreground="#1565C0"
                           FontSize="7.5"
                           FontWeight="Bold"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock Text="{Binding PilotLocationCodeDisplay}"
                           Foreground="#0D1F3C"
                           FontSize="22"
                           FontWeight="Bold"
                           FontFamily="Consolas"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding PilotLocationSubtitle}"
                           Foreground="#4A6E9A"
                           FontSize="8.5"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,2,0,0"
                           TextWrapping="Wrap"/>
                <!-- Clima lectura fácil - solo muestra si hay datos -->
                <Border Background="#EEF7FF" BorderBrush="#C0D8F0" BorderThickness="1"
                        CornerRadius="8" Padding="10,5" Margin="0,8,0,0"
                        Visibility="{Binding MainVM.DashboardVM.WeatherLine, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                    <TextBlock Text="{Binding MainVM.DashboardVM.WeatherLine}"
                               Foreground="#1565C0"
                               FontSize="9"
                               FontFamily="Segoe UI"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ULTIMOS VUELOS -->
        <Border Grid.Row="4"
                Background="#FFFFFF"
                BorderBrush="#B8D0EA"
                BorderThickness="1.5"
                CornerRadius="12"
                Padding="10,8"
                Margin="0,0,0,7"
                Effect="{StaticResource PanelShadow}">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="ÚLTIMOS VUELOS"
                               Foreground="#1565C0"
                               FontSize="8"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                    <Border Grid.Column="1"
                            Background="#E0EDFF" BorderBrush="#90B4D8" BorderThickness="1"
                            CornerRadius="8" Padding="8,2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding MainVM.DashboardVM.RecentFlights.Count}"
                                   Foreground="#1565C0"
                                   FontSize="8"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"/>
                    </Border>
                </Grid>

                <ItemsControl ItemsSource="{Binding MainVM.DashboardVM.RecentFlights}"
                              ItemTemplate="{StaticResource RecentFlightTemplate}"/>

                <TextBlock Text="Sin vuelos recientes registrados."
                           Foreground="#4A6E9A"
                           FontSize="8.8"
                           FontFamily="Segoe UI"
                           Margin="0,2,0,0"
                           TextWrapping="Wrap"
                           Visibility="{Binding MainVM.DashboardVM.RecentFlights.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <!-- COMUNIDAD -->
        <Border Grid.Row="5"
                Background="#FFFFFF"
                BorderBrush="#B8D0EA"
                BorderThickness="1.5"
                CornerRadius="12"
                Padding="10,8"
                Margin="0,0,0,7"
                Effect="{StaticResource PanelShadow}">
            <StackPanel>
                <TextBlock Text="COMUNIDAD"
                           Foreground="#1565C0"
                           FontSize="8"
                           FontWeight="Bold"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="#F0F6FF" BorderBrush="#C8DDF5" BorderThickness="1"
                            CornerRadius="10" Padding="8,7">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="ONLINE"
                                       Foreground="#4A6E9A"
                                       FontSize="7.5"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding OnlinePilotsDisplay}"
                                       Foreground="#0D1F3C"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       FontFamily="Consolas"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#F0F6FF" BorderBrush="#C8DDF5" BorderThickness="1"
                            CornerRadius="10" Padding="8,7">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="EN BASE"
                                       Foreground="#4A6E9A"
                                       FontSize="7.5"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding BasePilotsDisplay}"
                                       Foreground="#1565C0"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       FontFamily="Consolas"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- BUTTONS -->
        <Grid Grid.Row="7" Margin="0,4,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Command="{Binding OpenSupportCommand}"
                    Height="40"
                    Margin="0,0,5,0"
                    Background="#EEF5FF"
                    BorderBrush="#90B4D8"
                    BorderThickness="1.5"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <TextBlock Text="SOPORTE"
                                       Foreground="#1565C0"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#D0E8FF"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="1"
                    Command="{Binding BeginDispatchFlowCommand}"
                    Height="40"
                    Margin="5,0,0,0"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1565C0" Offset="0"/>
                                    <GradientStop Color="#1976D2" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="COMENZAR"
                                       Foreground="White"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.92"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.80"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</UserControl>
