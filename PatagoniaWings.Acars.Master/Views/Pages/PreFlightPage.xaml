<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.PreFlightPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:preview="clr-namespace:PatagoniaWings.Acars.Master.Preview"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="GateLedDotStyle" TargetType="Ellipse" BasedOn="{StaticResource LedStatusDot}">
            <Setter Property="Fill" Value="#E8EDF5"/>
            <Setter Property="Stroke" Value="#B8D0EA"/>
            <Style.Triggers>
                <Trigger Property="Tag" Value="True">
                    <Setter Property="Fill" Value="#22C55E"/>
                    <Setter Property="Stroke" Value="#16803D"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="11" ShadowDepth="0" Opacity="0.78" Color="#22C55E"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GateLedCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="BorderBrush" Value="#D4E4F4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="11"/>
            <Setter Property="Padding" Value="5,6"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>

        <Style x:Key="GateLedLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource LedStatusLabel}">
            <Setter Property="FontSize" Value="7.1"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel x:Name="PageRoot"
                    DataContext="{Binding DataContext.MainVM.PreFlightVM, RelativeSource={RelativeSource AncestorType=Window}}">
            <TextBlock Text="OFICINA DE DESPACHO"
                       Style="{StaticResource PageTitle}"
                       Margin="0,0,0,8"/>

            <Border Style="{StaticResource CardBlue}" Margin="0,0,0,8">
                <StackPanel>
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="ORIGEN" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding DepartureIcao, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchOrigin}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       FontSize="20"
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="&#x2708;"
                                   Foreground="{StaticResource AccentBlueBrush}"
                                   FontSize="18"
                                   Margin="8,11,8,0"/>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <TextBlock Text="DESTINO"
                                       Style="{StaticResource FieldLabel}"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding ArrivalIcao, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchDestination}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,1,0,0">
                        <TextBlock Text="{Binding RouteDisplayHeader}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="8.4"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding RouteDisplayLine, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchRoute}}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="9.6"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0,1,0,0"/>
                    </StackPanel>

                    <Grid Margin="0,9,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource InsetCardTight}">
                            <StackPanel>
                                <TextBlock Text="SALIDA" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding PreparedDispatch.ScheduledDepartureUtc, StringFormat={}{0:HH:mm}, TargetNullValue={x:Static preview:AcarsPreviewData.DispatchStd}}"
                                           Foreground="{StaticResource AccentLightBlueBrush}"
                                           FontFamily="Consolas"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource InsetCardTight}">
                            <StackPanel>
                                <TextBlock Text="BLOCK" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding BlockDisplayLine, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchBlock}}"
                                           Foreground="{StaticResource AccentLightBlueBrush}"
                                           FontFamily="Consolas"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="INFORMACION DEL DESPACHO" Style="{StaticResource SectionLabel}"/>
                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,0,4,8">
                            <TextBlock Text="VUELO" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding FlightNumber, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchFlightNumber}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Margin="4,0,0,8">
                            <TextBlock Text="AERONAVE" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding AircraftDisplayLine, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchAircraft}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,4,8">
                            <TextBlock Text="COMBUSTIBLE" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding FuelDisplayLine, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchFuel}}"
                                       Foreground="{StaticResource AccentLightBlueBrush}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Margin="4,0,0,8">
                            <TextBlock Text="PAYLOAD" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding PayloadMainLine}"
                                       Foreground="{StaticResource AccentLightBlueBrush}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding PayloadPaxLine}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="8.3"
                                       Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding PayloadCargoLine}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="8.3"/>
                            <TextBlock Text="{Binding PayloadZfwLine}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="8.3"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,4,0">
                            <TextBlock Text="ALTERNO" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding PreparedDispatch.AlternateIcao, TargetNullValue={x:Static preview:AcarsPreviewData.DispatchAlternate}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       FontSize="13"/>
                        </StackPanel>
                        <StackPanel Margin="4,0,0,0">
                            <TextBlock Text="NIVEL" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding PreparedDispatch.CruiseLevel, TargetNullValue={x:Static preview:AcarsPreviewData.DispatchCruiseLevel}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       FontSize="13"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="TELEMETRIA VIVA" Style="{StaticResource SectionLabel}"/>
                    <UniformGrid Columns="4" Margin="0,3,0,0">
                        <Border Style="{StaticResource GateLedCardStyle}">
                            <StackPanel>
                                <TextBlock Text="FRENO" Style="{StaticResource GateLedLabelStyle}"/>
                                <Ellipse Style="{StaticResource GateLedDotStyle}" Tag="{Binding StartGateParkingBrakeOk}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource GateLedCardStyle}">
                            <StackPanel>
                                <TextBlock Text="COLD &amp; DARK" Style="{StaticResource GateLedLabelStyle}"/>
                                <Ellipse Style="{StaticResource GateLedDotStyle}" Tag="{Binding StartGateColdAndDarkOk}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource GateLedCardStyle}">
                            <StackPanel>
                                <TextBlock Text="TIPO AVION" Style="{StaticResource GateLedLabelStyle}"/>
                                <Ellipse Style="{StaticResource GateLedDotStyle}" Tag="{Binding StartGateAircraftTypeOk}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource GateLedCardStyle}">
                            <StackPanel>
                                <TextBlock Text="GATE" Style="{StaticResource GateLedLabelStyle}"/>
                                <Ellipse Style="{StaticResource GateLedDotStyle}" Tag="{Binding StartGateAirportOk}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="9.5"
                       Margin="0,0,0,8"
                       TextWrapping="Wrap"
                       Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolVis}}"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource SecondaryButton}"
                        Click="BackButton_Click"
                        Content="VOLVER"
                        Height="38"
                        Margin="0,0,5,0"/>
                <Button Grid.Column="1"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding StartFlightCommand}"
                        Content="{Binding StartButtonTitle}"
                        Height="40"
                        Margin="5,0,0,0"
                        IsEnabled="{Binding CanStartFlight}"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
