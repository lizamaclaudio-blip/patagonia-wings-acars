<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.PreFlightPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:PatagoniaWings.Acars.Master.Helpers"
             Background="Transparent">
    <UserControl.DataContext>
        <Binding Path="DataContext.PreFlightVM" RelativeSource="{RelativeSource AncestorType=Window}"/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <helpers:StringToVisibilityConverter x:Key="StrVis"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20,16"/>
        </Style>

        <Style x:Key="SHead" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0284C7"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="DLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="DValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DValueMono" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="MetarBox" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0284C7" Offset="0"/>
                        <GradientStop Color="#0EA5E9" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecBtn" TargetType="Button">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="Foreground" Value="#0284C7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderBrush" Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="#EFF6FF">
        <StackPanel Margin="0,0,0,28">

            <!-- === HEADER === -->
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="DESPACHO" FontSize="26" FontWeight="Bold"
                               Foreground="#0284C7" FontFamily="Segoe UI"/>
                    <TextBlock Text="Reserva activa · Datos de vuelo · Inicio de operación"
                               FontSize="12" Foreground="#64748B" FontFamily="Segoe UI" Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Cargando..." FontSize="11" Foreground="#0EA5E9"
                               Visibility="{Binding IsLoadingDispatch, Converter={StaticResource BoolVis}}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource SecBtn}" Command="{Binding LoadDispatchCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↺  " FontSize="13"/>
                            <TextBlock Text="Recargar"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ═══ BADGE ESTADO ═══ -->
            <Border Margin="0,0,0,12" CornerRadius="8" Padding="12,8" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#FEF3C7"/>
                        <Setter Property="BorderBrush" Value="#FCD34D"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDispatchReady}" Value="True">
                                <Setter Property="Background" Value="#D1FAE5"/>
                                <Setter Property="BorderBrush" Value="#6EE7B7"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center" FontSize="13" Margin="0,0,8,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="⚠"/>
                                    <Setter Property="Foreground" Value="#92400E"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDispatchReady}" Value="True">
                                            <Setter Property="Text" Value="✓"/>
                                            <Setter Property="Foreground" Value="#065F46"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="12" FontFamily="Segoe UI"
                                   TextWrapping="Wrap" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#92400E"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDispatchReady}" Value="True">
                                            <Setter Property="Foreground" Value="#065F46"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <Border Grid.Column="1" CornerRadius="5" Padding="8,3" Margin="10,0,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#FCD34D"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDispatchReady}" Value="True">
                                        <Setter Property="Background" Value="#10B981"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding DispatchStatusLabel}" FontSize="10" FontWeight="Bold"
                                   FontFamily="Segoe UI">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#92400E"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDispatchReady}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ STRIP DE DESPACHO ═══ -->
            <Border Margin="0,0,0,12" CornerRadius="12" BorderThickness="1">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0284C7" Offset="0"/>
                        <GradientStop Color="#0EA5E9" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#F0F9FF" Offset="0"/>
                        <GradientStop Color="#FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Vuelo -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="VUELO" Style="{StaticResource DLabel}"/>
                        <TextBlock Text="{Binding FlightNumber, FallbackValue='—'}"
                                   FontSize="28" FontWeight="Black" FontFamily="Consolas"
                                   Foreground="#0284C7"/>
                    </StackPanel>

                    <!-- Separador -->
                    <Rectangle Grid.Column="1" Width="1" Fill="#BFDBFE" Margin="20,4"/>

                    <!-- Origen -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="ORIGEN" Style="{StaticResource DLabel}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding DepartureIcao, FallbackValue='—'}"
                                   FontSize="32" FontWeight="Black" FontFamily="Consolas"
                                   Foreground="#0F172A" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Flecha -->
                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="→→→→→→  ✈  →→→→→→" FontSize="14"
                                   Foreground="#93C5FD" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Margin="12,0"/>
                    </StackPanel>

                    <!-- Destino -->
                    <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="DESTINO" Style="{StaticResource DLabel}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ArrivalIcao, FallbackValue='—'}"
                                   FontSize="32" FontWeight="Black" FontFamily="Consolas"
                                   Foreground="#0F172A" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ AERONAVE + ALTERNADO ═══ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="AERONAVE" Style="{StaticResource DLabel}"/>
                        <TextBlock Text="{Binding AircraftIcao, FallbackValue='—'}"
                                   Style="{StaticResource DValueMono}" FontSize="16" Foreground="#0284C7"/>
                        <TextBlock Text="{Binding PreparedDispatch.AircraftDisplayName, FallbackValue=''}"
                                   FontSize="11" Foreground="#64748B" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="MATRÍCULA" Style="{StaticResource DLabel}"/>
                        <TextBlock Text="{Binding PreparedDispatch.AircraftRegistration, FallbackValue='—'}"
                                   Style="{StaticResource DValueMono}" FontSize="15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ALTERNADO" Style="{StaticResource DLabel}"/>
                        <TextBlock Text="{Binding PreparedDispatch.AlternateIcao, FallbackValue='—'}"
                                   Style="{StaticResource DValueMono}" FontSize="15" Foreground="#64748B"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="MODO" Style="{StaticResource DLabel}"/>
                        <TextBlock Text="{Binding ReadyFlightModeSummary, FallbackValue='—'}"
                                   Style="{StaticResource DValue}" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ PLAN + PESOS / COMBUSTIBLE ═══ -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Plan de vuelo -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="PLAN DE VUELO" Style="{StaticResource SHead}"/>
                        <TextBlock Text="RUTA" Style="{StaticResource DLabel}"/>
                        <TextBlock Text="{Binding Route, FallbackValue='Sin ruta cargada'}"
                                   FontSize="11" Foreground="#334155" FontFamily="Consolas"
                                   TextWrapping="Wrap" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="FL CRUCERO" Style="{StaticResource DLabel}"/>
                                <TextBlock Text="{Binding PreparedDispatch.CruiseLevel, FallbackValue='—'}"
                                           Style="{StaticResource DValueMono}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="VARIANTE" Style="{StaticResource DLabel}"/>
                                <TextBlock Text="{Binding ReadyFlightVariantSummary, FallbackValue='—'}"
                                           Style="{StaticResource DValue}" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Pesos y combustible -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="PESOS Y COMBUSTIBLE" Style="{StaticResource SHead}"/>
                        <UniformGrid Columns="2" Margin="0,0,0,6">
                            <StackPanel Margin="0,0,8,10">
                                <TextBlock Text="ZFW" Style="{StaticResource DLabel}"/>
                                <TextBlock Style="{StaticResource DValue}">
                                    <TextBlock.Text>
                                        <Binding Path="PreparedDispatch.ZeroFuelWeightKg"
                                                 StringFormat="{}{0:N0} kg" FallbackValue="—"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="PAX" Style="{StaticResource DLabel}"/>
                                <TextBlock Text="{Binding PreparedDispatch.PassengerCount, FallbackValue='—'}"
                                           Style="{StaticResource DValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="FUEL PLAN" Style="{StaticResource DLabel}"/>
                                <TextBlock Style="{StaticResource DValue}" Foreground="#0284C7">
                                    <TextBlock.Text>
                                        <Binding Path="PreparedDispatch.FuelPlannedKg"
                                                 StringFormat="{}{0:N0} kg" FallbackValue="—"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="FUEL BLOCK (SIMBRIEF)" Style="{StaticResource DLabel}"/>
                                <TextBlock Text="{Binding SimbriefFuel, FallbackValue='—'}"
                                           Style="{StaticResource DValueMono}" FontSize="12" Foreground="#0284C7"/>
                            </StackPanel>
                        </UniformGrid>
                        <Rectangle Height="1" Fill="#E2E8F0" Margin="0,6,0,8"/>
                        <Button Style="{StaticResource SecBtn}" Command="{Binding FetchSimbriefCommand}"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Visibility="{Binding IsLoadingSimbrief, Converter={StaticResource BoolVis}}"
                                           Text="Importando...  " FontSize="11"/>
                                <TextBlock Text="↓  Importar OFP SimBrief" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="{Binding SimbriefStatus}"
                                   FontSize="10" Foreground="#0EA5E9" TextWrapping="Wrap"
                                   FontFamily="Segoe UI" Margin="0,5,0,0"
                                   Visibility="{Binding HasSimbriefStatus, Converter={StaticResource BoolVis}}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ METAR ═══ -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="METAR  " FontSize="11" FontWeight="SemiBold"
                                           Foreground="#0284C7" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding DepartureIcao, FallbackValue='ORIGEN'}"
                                           FontSize="11" FontWeight="Bold" Foreground="#0284C7"
                                           FontFamily="Consolas" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource SecBtn}"
                                    Command="{Binding FetchMetarCommand}" Padding="8,4">
                                <TextBlock Text="→" FontSize="12"/>
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding DepMetar, FallbackValue='Sin METAR'}" Style="{StaticResource MetarBox}"/>
                        <TextBlock Text="{Binding DepartureWeatherSummary}" Margin="0,6,0,0"
                                   FontSize="11" Foreground="#334155" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="METAR  " FontSize="11" FontWeight="SemiBold"
                                       Foreground="#0284C7" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ArrivalIcao, FallbackValue='DESTINO'}"
                                       FontSize="11" FontWeight="Bold" Foreground="#0284C7"
                                       FontFamily="Consolas" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ArrMetar, FallbackValue='Sin METAR'}" Style="{StaticResource MetarBox}"/>
                        <TextBlock Text="{Binding ArrivalWeatherSummary}" Margin="0,6,0,0"
                                   FontSize="11" Foreground="#334155" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ EVALUACIÓN OPERACIONAL ═══ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="EVALUACIÓN OPERACIONAL" Style="{StaticResource SHead}"/>
                    <TextBlock Text="{Binding OperationalMinimaSummary}"
                               FontSize="12" Foreground="#334155" FontFamily="Segoe UI"
                               TextWrapping="Wrap" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding OperationalQualificationsSummary}"
                               FontSize="11" Foreground="#64748B" FontFamily="Segoe UI"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ═══ ESTADO SIMBRIEF ═══ -->
            <Border CornerRadius="8" Padding="12,8" Margin="0,0,0,12" BorderThickness="1"
                    BorderBrush="#BFDBFE" Background="#EFF6FF"
                    Visibility="{Binding HasSimbriefStatus, Converter={StaticResource BoolVis}}">
                <TextBlock Text="{Binding SimbriefStatus}" FontSize="11" Foreground="#0284C7"
                           FontFamily="Segoe UI" TextWrapping="Wrap"/>
            </Border>

            <!-- ═══ SIMULADOR + INICIAR ═══ -->
            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="240"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="SIMULADOR" Style="{StaticResource DLabel}"/>
                        <ComboBox ItemsSource="{Binding SimulatorOptions}"
                                  SelectedItem="{Binding SelectedSim}"
                                  FontSize="13" FontFamily="Segoe UI"
                                  BorderBrush="#BFDBFE" BorderThickness="1"
                                  Background="#FFFFFF" Foreground="#0F172A"
                                  Padding="10,6" Width="220" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <Button Grid.Column="2" Style="{StaticResource PrimaryBtn}"
                            Command="{Binding StartFlightCommand}"
                            IsEnabled="{Binding CanStartFlight}"
                            Padding="0,18" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="âœˆ  INICIAR DESPACHO" FontSize="15" FontWeight="Bold"
                                       FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding FlightNumber, StringFormat='Vuelo {0}', FallbackValue=''}"
                                       FontSize="11" HorizontalAlignment="Center"
                                       Opacity="0.8" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
