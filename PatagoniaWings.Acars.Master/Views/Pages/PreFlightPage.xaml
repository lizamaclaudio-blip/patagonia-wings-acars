<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.PreFlightPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.DataContext>
        <Binding Path="DataContext.PreFlightVM" RelativeSource="{RelativeSource AncestorType=Window}"/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- Card container -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20,16"/>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHead" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0284C7"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Data label -->
        <Style x:Key="DLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <!-- Data value -->
        <Style x:Key="DValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Data value muted (when empty) -->
        <Style x:Key="DValueMono" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Route / long text -->
        <Style x:Key="RouteText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Primary action button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0284C7" Offset="0"/>
                        <GradientStop Color="#0EA5E9" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary action button -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="Foreground" Value="#0284C7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderBrush" Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- METAR raw text box -->
        <Style x:Key="MetarBox" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="#EFF6FF">
        <StackPanel Margin="0,0,0,24">

            <!-- ═══ HEADER ROW ═══ -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="PRE-VUELO" FontSize="22" FontWeight="Bold"
                               Foreground="#0284C7" FontFamily="Segoe UI"/>
                    <TextBlock Text="Reserva activa cargada desde la web · SimBrief · Inicio de vuelo"
                               FontSize="12" Foreground="#64748B" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Loading indicator -->
                    <TextBlock Text="Cargando..." FontSize="11" Foreground="#0EA5E9"
                               Visibility="{Binding IsLoadingDispatch, Converter={StaticResource BoolVis}}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource SecondaryBtn}"
                            Command="{Binding LoadDispatchCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↺  " FontSize="13"/>
                            <TextBlock Text="Recargar Despacho"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ═══ FLIGHT INFO CARD ═══ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="DATOS DE VUELO" Style="{StaticResource SectionHead}"/>

                    <!-- Row 1: Flight# | Aircraft | Origin | Dest | Alternate -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <!-- Vuelo -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="VUELO" Style="{StaticResource DLabel}"/>
                            <TextBlock Text="{Binding FlightNumber, FallbackValue='—'}"
                                       Style="{StaticResource DValueMono}" FontSize="18" Foreground="#0284C7"/>
                        </StackPanel>

                        <!-- Aeronave -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="AERONAVE" Style="{StaticResource DLabel}"/>
                            <TextBlock Style="{StaticResource DValue}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}  {1}">
                                        <Binding Path="AircraftIcao" FallbackValue=""/>
                                        <Binding Path="PreparedDispatch.AircraftDisplayName" FallbackValue=""/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="{Binding ReadyFlightVariantSummary}"
                                       FontSize="10" Foreground="#64748B" FontFamily="Segoe UI"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Origen -->
                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                            <TextBlock Text="ORIGEN" Style="{StaticResource DLabel}"/>
                            <TextBlock Text="{Binding DepartureIcao, FallbackValue='—'}"
                                       Style="{StaticResource DValueMono}" FontSize="22"/>
                        </StackPanel>

                        <!-- Destino -->
                        <StackPanel Grid.Column="3" Margin="8,0,0,0">
                            <TextBlock Text="DESTINO" Style="{StaticResource DLabel}"/>
                            <TextBlock Text="{Binding ArrivalIcao, FallbackValue='—'}"
                                       Style="{StaticResource DValueMono}" FontSize="22"/>
                        </StackPanel>

                        <!-- Alternado -->
                        <StackPanel Grid.Column="4" Margin="8,0,0,0">
                            <TextBlock Text="ALTERNADO" Style="{StaticResource DLabel}"/>
                            <TextBlock Text="{Binding PreparedDispatch.AlternateIcao, FallbackValue='—'}"
                                       Style="{StaticResource DValueMono}" FontSize="18" Foreground="#64748B"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ═══ PLAN + SIMBRIEF ROW ═══ -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <!-- Plan de vuelo -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="PLAN DE VUELO" Style="{StaticResource SectionHead}"/>

                        <!-- Route -->
                        <TextBlock Text="RUTA" Style="{StaticResource DLabel}"/>
                        <TextBlock Text="{Binding Route, FallbackValue='Sin ruta cargada'}"
                                   Style="{StaticResource RouteText}" Margin="0,0,0,12"/>

                        <!-- FL / ZFW / PAX / Fuel row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="FL CRUCERO" Style="{StaticResource DLabel}"/>
                                <TextBlock Style="{StaticResource DValueMono}">
                                    <TextBlock.Text>
                                        <Binding Path="PreparedDispatch.CruiseLevel" FallbackValue="—"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="ZFW" Style="{StaticResource DLabel}"/>
                                <TextBlock Style="{StaticResource DValue}">
                                    <TextBlock.Text>
                                        <Binding Path="PreparedDispatch.ZeroFuelWeightKg"
                                                 StringFormat="{}{0:N0} kg" FallbackValue="—"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="PAX" Style="{StaticResource DLabel}"/>
                                <TextBlock Text="{Binding PreparedDispatch.PassengerCount, FallbackValue='—'}"
                                           Style="{StaticResource DValue}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <TextBlock Text="FUEL PLAN" Style="{StaticResource DLabel}"/>
                                <TextBlock Style="{StaticResource DValue}">
                                    <TextBlock.Text>
                                        <Binding Path="PreparedDispatch.FuelPlannedKg"
                                                 StringFormat="{}{0:N0} kg" FallbackValue="—"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <!-- Modo operativo -->
                        <TextBlock Margin="0,10,0,0">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0}  ·  {1}">
                                    <Binding Path="ReadyFlightModeSummary"/>
                                    <Binding Path="PreparedDispatch.AircraftRegistration" FallbackValue=""/>
                                </MultiBinding>
                            </TextBlock.Text>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- SimBrief -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="SIMBRIEF OFP" Style="{StaticResource SectionHead}"/>

                        <Button Style="{StaticResource SecondaryBtn}"
                                Command="{Binding GenerateSimbriefCommand}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,8">
                            <TextBlock Text="✈  Generar en SimBrief" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                        </Button>

                        <Button Style="{StaticResource PrimaryBtn}"
                                Command="{Binding FetchSimbriefCommand}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Visibility="{Binding IsLoadingSimbrief, Converter={StaticResource BoolVis}}"
                                           Text="Importando...  " FontSize="12"/>
                                <TextBlock Text="⬇  Importar OFP" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Button>

                        <!-- OFP data (visible when loaded) -->
                        <StackPanel Visibility="{Binding SimbriefLoaded, Converter={StaticResource BoolVis}}">
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="FUEL BLOCK" Style="{StaticResource DLabel}"/>
                                    <TextBlock Text="{Binding SimbriefFuel, FallbackValue='—'}" Style="{StaticResource DValueMono}" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="FL OFP" Style="{StaticResource DLabel}"/>
                                    <TextBlock Text="{Binding SimbriefAlt, FallbackValue='—'}" Style="{StaticResource DValueMono}" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="ALTERNADO OFP" Style="{StaticResource DLabel}"/>
                            <TextBlock Text="{Binding SimbriefAlternate, FallbackValue='—'}" Style="{StaticResource DValueMono}" FontSize="12" Margin="0,0,0,4"/>
                        </StackPanel>

                        <!-- Status message -->
                        <TextBlock Text="{Binding SimbriefStatus}"
                                   FontSize="10" Foreground="#0EA5E9" FontFamily="Segoe UI"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ METAR ROW ═══ -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- METAR Origen -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="METAR  " FontSize="11" FontWeight="SemiBold" Foreground="#0284C7"
                                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding DepartureIcao, FallbackValue='ORIGEN'}"
                                           FontSize="11" FontWeight="Bold" Foreground="#0284C7"
                                           FontFamily="Consolas" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource SecondaryBtn}"
                                    Command="{Binding FetchMetarCommand}" Padding="8,4">
                                <TextBlock Text="↺" FontSize="12"/>
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding DepMetar, FallbackValue='Sin METAR'}" Style="{StaticResource MetarBox}"/>
                        <TextBlock Text="{Binding DepartureWeatherSummary}" Margin="0,6,0,0"
                                   FontSize="11" Foreground="#334155" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- METAR Destino -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="METAR  " FontSize="11" FontWeight="SemiBold" Foreground="#0284C7"
                                       FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ArrivalIcao, FallbackValue='DESTINO'}"
                                       FontSize="11" FontWeight="Bold" Foreground="#0284C7"
                                       FontFamily="Consolas" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ArrMetar, FallbackValue='Sin METAR'}" Style="{StaticResource MetarBox}"/>
                        <TextBlock Text="{Binding ArrivalWeatherSummary}" Margin="0,6,0,0"
                                   FontSize="11" Foreground="#334155" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ MINIMA ADVISORY ═══ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="EVALUACIÓN OPERACIONAL" Style="{StaticResource SectionHead}"/>
                    <TextBlock Text="{Binding OperationalMinimaSummary}"
                               FontSize="12" Foreground="#334155" FontFamily="Segoe UI"
                               TextWrapping="Wrap" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding OperationalQualificationsSummary}"
                               FontSize="11" Foreground="#64748B" FontFamily="Segoe UI"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ═══ SIMULATOR SELECTOR + START FLIGHT ═══ -->
            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sim selector -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="SIMULADOR" Style="{StaticResource DLabel}"/>
                        <ComboBox ItemsSource="{Binding SimulatorOptions}"
                                  SelectedItem="{Binding SelectedSim}"
                                  FontSize="13" FontFamily="Segoe UI"
                                  BorderBrush="#BFDBFE" BorderThickness="1"
                                  Background="#FFFFFF" Foreground="#0F172A"
                                  Padding="10,6" Width="200" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="11" Foreground="#0EA5E9" FontFamily="Segoe UI"
                                   TextWrapping="Wrap" Margin="0,8,0,0"
                                   MaxWidth="600"/>
                    </StackPanel>

                    <!-- Start button -->
                    <Button Grid.Column="2" Style="{StaticResource PrimaryBtn}"
                            Command="{Binding StartFlightCommand}"
                            IsEnabled="{Binding CanStartFlight}"
                            Padding="0,16" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="INICIAR VUELO" FontSize="15" FontWeight="Bold"
                                       FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding FlightNumber, StringFormat='Vuelo {0}', FallbackValue=''}"
                                       FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"
                                       Opacity="0.8"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
