<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.PreFlightPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:preview="clr-namespace:PatagoniaWings.Acars.Master.Preview"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel x:Name="PageRoot"
                    DataContext="{Binding DataContext.MainVM.PreFlightVM, RelativeSource={RelativeSource AncestorType=Window}}">
            <TextBlock Text="OFICINA DE DESPACHO"
                       Style="{StaticResource PageTitle}"
                       Margin="0,0,0,8"/>

            <Border Style="{StaticResource CardBlue}" Margin="0,0,0,8">
                <StackPanel>
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="ORIGEN" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding DepartureIcao, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchOrigin}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       FontSize="20"
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="&#x2708;"
                                   Foreground="{StaticResource AccentBlueBrush}"
                                   FontSize="18"
                                   Margin="8,11,8,0"/>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <TextBlock Text="DESTINO"
                                       Style="{StaticResource FieldLabel}"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding ArrivalIcao, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchDestination}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding RouteDisplayLine, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchRoute}}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="9.2"
                               TextWrapping="Wrap"/>

                    <Grid Margin="0,9,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource InsetCardTight}">
                            <StackPanel>
                                <TextBlock Text="SALIDA" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding PreparedDispatch.ScheduledDepartureUtc, StringFormat={}{0:HH:mm}, TargetNullValue={x:Static preview:AcarsPreviewData.DispatchStd}}"
                                           Foreground="{StaticResource AccentLightBlueBrush}"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource InsetCardTight}">
                            <StackPanel>
                                <TextBlock Text="BLOCK" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding BlockDisplayLine, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchBlock}}"
                                           Foreground="{StaticResource AccentLightBlueBrush}"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="INFORMACION DEL DESPACHO" Style="{StaticResource SectionLabel}"/>
                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,0,4,8">
                            <TextBlock Text="VUELO" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding FlightNumber, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchFlightNumber}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Margin="4,0,0,8">
                            <TextBlock Text="AERONAVE" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding AircraftDisplayLine, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchAircraft}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="10"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,4,8">
                            <TextBlock Text="COMBUSTIBLE" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding FuelDisplayLine, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchFuel}}"
                                       Foreground="{StaticResource AccentLightBlueBrush}"
                                       FontSize="10.5"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Margin="4,0,0,8">
                            <TextBlock Text="PAYLOAD / PAX" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding PayloadDisplayLine, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchPayload}}"
                                       Foreground="{StaticResource AccentLightBlueBrush}"
                                       FontSize="10"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,4,0">
                            <TextBlock Text="ALTERNO" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding PreparedDispatch.AlternateIcao, TargetNullValue={x:Static preview:AcarsPreviewData.DispatchAlternate}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       FontSize="11"/>
                        </StackPanel>
                        <StackPanel Margin="4,0,0,0">
                            <TextBlock Text="NIVEL" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding PreparedDispatch.CruiseLevel, TargetNullValue={x:Static preview:AcarsPreviewData.DispatchCruiseLevel}}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       FontSize="11"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="TELEMETRIA PREVIA" Style="{StaticResource SectionLabel}"/>
                    <TextBlock Text="{Binding DispatchStatusLabel, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchStatus}}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding DispatchStateLine, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchState}}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="9.5"
                               Margin="0,5,0,0"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding StartGateSummary, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchGate}}"
                               Foreground="{StaticResource AccentLightBlueBrush}"
                               FontSize="9.5"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding DispatchSourceLine, Converter={StaticResource StringFallbackConverter}, ConverterParameter={x:Static preview:AcarsPreviewData.DispatchSource}}"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="8.5"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="9.5"
                       Margin="0,0,0,8"
                       TextWrapping="Wrap"
                       Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolVis}}"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding DataContext.GoPilotLoungeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Content="VOLVER"
                        Height="38"
                        Margin="0,0,5,0"/>
                <Button Grid.Column="1"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding StartFlightCommand}"
                        Content="{Binding StartButtonTitle}"
                        Height="40"
                        Margin="5,0,0,0"
                        IsEnabled="{Binding CanStartFlight}"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
