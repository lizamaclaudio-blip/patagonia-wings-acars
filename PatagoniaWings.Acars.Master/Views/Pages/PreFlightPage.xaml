<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.PreFlightPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.DataContext>
        <Binding Path="DataContext.PreFlightVM" RelativeSource="{RelativeSource AncestorType=Window}"/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="DataLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="DataValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="MetarBox" TargetType="Border">
            <Setter Property="Background" Value="#060B12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
        <Style x:Key="AccentCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
        <Style x:Key="BriefBtn" TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#263348"/>
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StartBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" Padding="20,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#0A7EA4" Offset="0"/>
                                    <GradientStop Color="#0CA789" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Background" Value="#0D1422"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#2D9CDB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2D9CDB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FieldCombo" TargetType="ComboBox" BasedOn="{StaticResource DarkComboBox}"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="980" Margin="0,4,0,28">

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="PRE-VUELO" Foreground="#2D9CDB" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text=" · BRIEFING OPERACIONAL" Foreground="#475569" FontSize="11" VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock Text="Pre-Vuelo" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,0,0,22"/>

        <!-- ROW 1: Despacho + SimBrief -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Despacho ── -->
            <Border Grid.Column="0" CornerRadius="12" BorderThickness="1" Padding="20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0B1420" Offset="0"/>
                        <GradientStop Color="#070D16" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A3A5C" Offset="0"/>
                        <GradientStop Color="#0CA789" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="DESPACHO" Foreground="#64748B" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Border Background="#0A1F14" CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                            <TextBlock Text="SUPABASE" Foreground="#0CA789" FontSize="9" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <!-- Vuelo + ruta -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource DataLabel}" Text="VUELO"/>
                            <TextBlock Style="{StaticResource DataValue}" FontSize="24"
                                       Text="{Binding PreparedDispatch.FlightDesignator, TargetNullValue=—}"/>
                            <TextBlock Foreground="#334155" FontSize="11" Margin="0,6,0,0"
                                       Text="{Binding PreparedDispatch.AircraftDisplayName, TargetNullValue=Sin aeronave asignada}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding PreparedDispatch.DepartureIcao, TargetNullValue=????}"
                                       FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                                       Foreground="#38BDF8" HorizontalAlignment="Center"/>
                            <TextBlock Text="↓" Foreground="#1E3A5F" FontSize="16"
                                       HorizontalAlignment="Center" Margin="0,3"/>
                            <TextBlock Text="{Binding PreparedDispatch.ArrivalIcao, TargetNullValue=????}"
                                       FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                                       Foreground="#34D399" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Ruta corta -->
                    <Border Background="#060B12" CornerRadius="6" Padding="10,8" Margin="0,0,0,14">
                        <TextBlock Text="{Binding PreparedDispatch.RouteText, TargetNullValue=Sin ruta asignada}"
                                   Foreground="#334155" FontFamily="Consolas" FontSize="10"
                                   TextWrapping="Wrap" MaxHeight="32"/>
                    </Border>

                    <!-- Info extra -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource DataLabel}" Text="AERONAVE"/>
                            <TextBlock Foreground="#94A3B8" FontFamily="Consolas" FontSize="12"
                                       Text="{Binding PreparedDispatch.AircraftIcao, TargetNullValue=—}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Style="{StaticResource DataLabel}" Text="FL CRUCERO"/>
                            <TextBlock Foreground="#94A3B8" FontFamily="Consolas" FontSize="12"
                                       Text="{Binding PreparedDispatch.CruiseLevel, TargetNullValue=—}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource DataLabel}" Text="ALTERNADO"/>
                            <TextBlock Foreground="#94A3B8" FontFamily="Consolas" FontSize="12"
                                       Text="{Binding PreparedDispatch.AlternateIcao, TargetNullValue=—}"/>
                        </StackPanel>
                    </Grid>

                    <Button Style="{StaticResource BriefBtn}" Command="{Binding LoadDispatchCommand}"
                            HorizontalAlignment="Left">
                        <TextBlock Text="↻  Cargar Despacho"/>
                    </Button>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#64748B" FontSize="11"
                               Margin="0,10,0,0" TextWrapping="Wrap"
                               Visibility="{Binding IsLoadingDispatch, Converter={StaticResource BoolVis}}"/>
                </StackPanel>
            </Border>

            <!-- ── SimBrief ── -->
            <Border Grid.Column="2" Style="{StaticResource GlassCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="SIMBRIEF" Foreground="#64748B" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Border Background="#0F1F14" CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                            <TextBlock Text="OFP" Foreground="#3FB950" FontSize="9" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <!-- Datos OFP cuando está cargado -->
                    <Border Background="#060D0A" CornerRadius="8" Padding="14,12" Margin="0,0,0,12"
                            Visibility="{Binding SimbriefLoaded, Converter={StaticResource BoolVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource DataLabel}" Text="COMBUSTIBLE"/>
                                <TextBlock Text="{Binding SimbriefFuel, TargetNullValue=—}"
                                           Foreground="#3FB950" FontFamily="Consolas" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Style="{StaticResource DataLabel}" Text="FL"/>
                                <TextBlock Text="{Binding SimbriefAlt, TargetNullValue=—}"
                                           Foreground="#38BDF8" FontFamily="Consolas" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource DataLabel}" Text="ALTERNO"/>
                                <TextBlock Text="{Binding SimbriefAlternate, TargetNullValue=—}"
                                           Foreground="#F59E0B" FontFamily="Consolas" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Ruta SimBrief -->
                    <Border Background="#060B12" CornerRadius="6" Padding="10,8" Margin="0,0,0,14"
                            Visibility="{Binding SimbriefLoaded, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="{Binding SimbriefRoute}" Foreground="#334155"
                                   FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" MaxHeight="40"/>
                    </Border>

                    <!-- Placeholder cuando no hay OFP -->
                    <Border Background="#060B12" CornerRadius="8" Padding="16,14" Margin="0,0,0,14">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SimbriefLoaded}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Sin OFP cargado" Foreground="#334155" FontSize="13"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="Genera el plan en SimBrief y luego importa el OFP"
                                       Foreground="#1E293B" FontSize="11" TextWrapping="Wrap"
                                       HorizontalAlignment="Center" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Style="{StaticResource BriefBtn}" Command="{Binding GenerateSimbriefCommand}" Margin="0,0,8,0">
                            <TextBlock Text="🌐  Generar en SimBrief"/>
                        </Button>
                        <Button Style="{StaticResource BriefBtn}" Command="{Binding FetchSimbriefCommand}">
                            <TextBlock Text="⬇  Importar OFP"/>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="Buscando OFP..." Foreground="#2D9CDB" FontSize="11"
                               Visibility="{Binding IsLoadingSimbrief, Converter={StaticResource BoolVis}}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SimbriefStatus}" Foreground="#475569"
                               FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ROW 2: METAR Origen + METAR Destino -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource GlassCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="🛫" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="METAR ORIGEN" Foreground="#64748B" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DepartureIcao}" FontFamily="Consolas" FontSize="13"
                                   Foreground="#38BDF8" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Style="{StaticResource MetarBox}">
                        <TextBlock Text="{Binding DepMetar, TargetNullValue=—}" Foreground="#475569"
                                   FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" MaxHeight="52"/>
                    </Border>
                    <TextBlock Text="{Binding DepartureWeatherSummary}" Foreground="#64748B"
                               FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource GlassCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="🛬" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="METAR DESTINO" Foreground="#64748B" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ArrivalIcao}" FontFamily="Consolas" FontSize="13"
                                   Foreground="#34D399" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Style="{StaticResource MetarBox}">
                        <TextBlock Text="{Binding ArrMetar, TargetNullValue=—}" Foreground="#475569"
                                   FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" MaxHeight="52"/>
                    </Border>
                    <TextBlock Text="{Binding ArrivalWeatherSummary}" Foreground="#64748B"
                               FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <Button Style="{StaticResource BriefBtn}" Command="{Binding FetchMetarCommand}"
                HorizontalAlignment="Left" Margin="0,0,0,14">
            <TextBlock Text="↻  Actualizar METAR"/>
        </Button>

        <!-- ROW 3: Configuración + Iniciar -->
        <Border Style="{StaticResource GlassCard}">
            <StackPanel>
                <TextBlock Text="CONFIGURACIÓN DEL VUELO" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource DataLabel}" Text="NRO. VUELO"/>
                        <TextBox Style="{StaticResource FieldInput}" Height="38"
                                 Text="{Binding FlightNumber, UpdateSourceTrigger=PropertyChanged}"
                                 CharacterCasing="Upper" IsReadOnly="{Binding IsFlightDataLocked}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource DataLabel}" Text="AERONAVE (ICAO)"/>
                        <TextBox Style="{StaticResource FieldInput}" Height="38"
                                 Text="{Binding AircraftIcao, UpdateSourceTrigger=PropertyChanged}"
                                 CharacterCasing="Upper" IsReadOnly="{Binding IsFlightDataLocked}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Style="{StaticResource DataLabel}" Text="FL CRUCERO"/>
                        <TextBox Style="{StaticResource FieldInput}" Height="38"
                                 Text="{Binding PlannedAlt, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <TextBlock Style="{StaticResource DataLabel}" Text="SIMULADOR"/>
                        <ComboBox Style="{StaticResource DarkComboBox}" Height="38"
                                  ItemsSource="{Binding SimulatorOptions}"
                                  SelectedItem="{Binding SelectedSim, Mode=TwoWay}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Style="{StaticResource DataLabel}" Text="RUTA" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource FieldInput}" Height="36" Margin="0,0,0,14"
                         Text="{Binding Route, UpdateSourceTrigger=PropertyChanged}" CharacterCasing="Upper"/>

                <!-- Mínimos -->
                <Border Background="#0A101C" CornerRadius="8" Padding="14,10" Margin="0,0,0,18">
                    <TextBlock Text="{Binding OperationalMinimaSummary}" Foreground="#475569"
                               FontSize="11" TextWrapping="Wrap"/>
                </Border>

                <!-- INICIAR VUELO -->
                <Button Style="{StaticResource StartBtn}" Command="{Binding StartFlightCommand}">
                    <TextBlock Text="✈  INICIAR VUELO"/>
                </Button>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{Binding FlightStarted, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3FB950|#FF6B6B'}"
                           FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

    </StackPanel>
    </ScrollViewer>
</UserControl>
