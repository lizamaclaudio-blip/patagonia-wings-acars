<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.NoDispatchPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid x:Name="PageRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="OFICINA DE DESPACHO"
                   Foreground="#0D1F3C"
                   FontSize="14"
                   FontWeight="Bold"
                   FontFamily="Segoe UI"
                   Margin="0,0,0,8"/>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#B8D0EA"
                BorderThickness="1.5"
                CornerRadius="14"
                Padding="14,12"
                Effect="{StaticResource PanelShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Badge + Avatar -->
                <StackPanel HorizontalAlignment="Center">
                    <Border Background="#E0EDFF" BorderBrush="#90B4D8" BorderThickness="1"
                            CornerRadius="12" Padding="12,4" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock Text="SIN RESERVA ACTIVA"
                                   Foreground="#1565C0"
                                   FontSize="8.5"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI"/>
                    </Border>

                    <Border Width="60"
                            Height="60"
                            CornerRadius="30"
                            Background="#E8F2FF"
                            BorderBrush="#90B4D8"
                            BorderThickness="2"
                            HorizontalAlignment="Center">
                        <TextBlock Text="PW"
                                   Foreground="#1565C0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Title -->
                <TextBlock Grid.Row="1"
                           Text="{Binding NoDispatchTitle}"
                           Foreground="#0D1F3C"
                           FontSize="14"
                           FontWeight="Bold"
                           FontFamily="Segoe UI"
                           Margin="0,12,0,0"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>

                <!-- Body -->
                <TextBlock Grid.Row="2"
                           Text="{Binding NoDispatchBody}"
                           Foreground="#1E3A64"
                           FontSize="10"
                           FontFamily="Segoe UI"
                           Margin="0,8,0,0"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>

                <!-- Status box -->
                <Border Grid.Row="3"
                        Margin="0,12,0,0"
                        Background="#F0F6FF"
                        BorderBrush="#C8DDF5"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="ESTADO ACTUAL"
                                   Foreground="#4A6E9A"
                                   FontSize="7.5"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding MainVM.PreFlightVM.StatusMessage}"
                                   Foreground="#1565C0"
                                   FontSize="9.5"
                                   FontFamily="Segoe UI"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding NoDispatchHint}"
                                   Foreground="#4A6E9A"
                                   FontSize="8.5"
                                   FontFamily="Segoe UI"
                                   Margin="0,8,0,0"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="2" Margin="0,8,0,0">
            <Button Click="ReserveButton_Click"
                    Height="42"
                    Margin="0,0,0,7"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1565C0" Offset="0"/>
                                    <GradientStop Color="#1976D2" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="RESERVE SU VUELO"
                                       Foreground="White"
                                       FontSize="10.5"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.92"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.80"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Click="RetryButton_Click"
                    Height="38"
                    Margin="0,0,0,5"
                    Background="#EEF5FF"
                    BorderBrush="#90B4D8"
                    BorderThickness="1.5"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <TextBlock Text="REINTENTAR"
                                       Foreground="#1565C0"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#D0E8FF"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Click="BackButton_Click"
                    Height="32"
                    Background="Transparent"
                    BorderBrush="#C8DDF5"
                    BorderThickness="1"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <TextBlock Text="VOLVER"
                                       Foreground="#4A6E9A"
                                       FontSize="9.5"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#EEF5FF"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
