<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.NoDispatchPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid x:Name="PageRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="OFICINA DE DESPACHO"
                   Style="{StaticResource PageTitle}"
                   Margin="0,0,0,8"/>

        <Border Grid.Row="1"
                Style="{StaticResource CardBlue}"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Style="{StaticResource PillBlue}"
                            HorizontalAlignment="Center">
                        <TextBlock Text="SIN RESERVA ACTIVA"
                                   Foreground="{StaticResource AccentLightBlueBrush}"
                                   FontSize="8.5"
                                   FontWeight="Bold"/>
                    </Border>

                    <Border Width="56"
                            Height="56"
                            CornerRadius="28"
                            Background="#101A27"
                            BorderBrush="#345472"
                            BorderThickness="1"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">
                        <TextBlock Text="PW"
                                   Foreground="{StaticResource AccentBlueBrush}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Text="{Binding NoDispatchTitle}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="15"
                           FontWeight="Bold"
                           Margin="0,12,0,0"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>

                <TextBlock Grid.Row="2"
                           Text="{Binding NoDispatchBody}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10.5"
                           Margin="0,8,0,0"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>

                <Border Grid.Row="3"
                        Margin="0,12,0,0"
                        Style="{StaticResource InsetCard}">
                    <StackPanel>
                        <TextBlock Text="ESTADO ACTUAL"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding MainVM.PreFlightVM.StatusMessage}"
                                   Foreground="{StaticResource AccentLightBlueBrush}"
                                   FontSize="9.5"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding NoDispatchHint}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="8.5"
                                   Margin="0,8,0,0"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,8,0,0">
            <Button Style="{StaticResource PrimaryButton}"
                    Content="RESERVE SU VUELO"
                    Click="ReserveButton_Click"
                    Height="40"
                    Margin="0,0,0,8"/>

            <Button Style="{StaticResource SecondaryButton}"
                    Content="REINTENTAR"
                    Click="RetryButton_Click"
                    Height="38"
                    Margin="0,0,0,6"/>

            <Button Style="{StaticResource SecondaryButton}"
                    Content="VOLVER"
                    Click="BackButton_Click"
                    Height="34"
                    Background="Transparent"
                    BorderBrush="#223141"
                    Foreground="{StaticResource TextMutedBrush}"/>
        </StackPanel>
    </Grid>
</UserControl>
