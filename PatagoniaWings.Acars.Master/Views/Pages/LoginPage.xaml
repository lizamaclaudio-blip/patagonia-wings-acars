<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.DataContext>
        <Binding Path="DataContext.LoginVM" RelativeSource="{RelativeSource AncestorType=Window}"/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <Storyboard x:Key="LogoPulse" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="BottomLogo"
                             Storyboard.TargetProperty="Opacity"
                             From="0.55" To="1.0"
                             Duration="0:0:2.2"
                             AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="LogoScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.90" To="1.10"
                             Duration="0:0:2.2"
                             AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="LogoScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.90" To="1.10"
                             Duration="0:0:2.2"
                             AutoReverse="True"/>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource LogoPulse}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid x:Name="PageRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="140"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HERO — foto limpia + texto con glow -->
        <Border Grid.Row="0"
                CornerRadius="16"
                Margin="0,0,0,14"
                BorderThickness="0"
                ClipToBounds="True">
            <Grid>
                <Grid.Background>
                    <ImageBrush ImageSource="pack://application:,,,/Assets/patagonia-bg.jpg"
                                Stretch="UniformToFill"
                                Opacity="0.88"/>
                </Grid.Background>
                <!-- Overlay muy suave solo en la parte inferior para legibilidad -->
                <Border VerticalAlignment="Bottom" Height="70">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#CC091426" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Texto sobre la foto -->
                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock Text="PATAGONIA WINGS"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#0099FF" BlurRadius="22" ShadowDepth="0" Opacity="0.95"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="ACARS — SISTEMA DE VUELO"
                               Foreground="#C8E8FF"
                               FontSize="8.5"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,3,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#0066CC" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CAMPOS -->
        <TextBlock Grid.Row="1"
                   Text="NÚMERO / CORREO DEL PILOTO"
                   Foreground="#4A6E9A"
                   FontSize="8"
                   FontWeight="Bold"
                   FontFamily="Segoe UI"
                   Margin="0,0,0,3"/>
        <Border Grid.Row="2"
                Background="#F0F6FF"
                BorderBrush="#B8D0EA"
                BorderThickness="1.5"
                CornerRadius="10"
                Margin="0,0,0,10">
            <TextBox x:Name="EmailBox"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="#0D1F3C"
                     FontSize="11"
                     FontFamily="Segoe UI"
                     CaretBrush="#1565C0"
                     Padding="10,8"
                     Height="38"/>
        </Border>

        <TextBlock Grid.Row="3"
                   Text="CONTRASEÑA"
                   Foreground="#4A6E9A"
                   FontSize="8"
                   FontWeight="Bold"
                   FontFamily="Segoe UI"
                   Margin="0,0,0,3"/>
        <Border Grid.Row="4"
                Background="#F0F6FF"
                BorderBrush="#B8D0EA"
                BorderThickness="1.5"
                CornerRadius="10"
                Margin="0,0,0,10">
            <PasswordBox x:Name="PwdBox"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#0D1F3C"
                         FontSize="11"
                         FontFamily="Segoe UI"
                         Padding="10,8"
                         Height="38"
                         PasswordChanged="PwdBox_PasswordChanged"/>
        </Border>

        <StackPanel Grid.Row="5" Margin="0,0,0,10">
            <CheckBox Content="Recordar sesión"
                      IsChecked="{Binding RememberMe}"
                      Foreground="#4A6E9A"
                      FontSize="9.5"
                      FontFamily="Segoe UI"
                      Margin="0,0,0,5"/>
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#C62828"
                       FontSize="9.5"
                       FontFamily="Segoe UI"
                       TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>

        <!-- BOTÓN INGRESAR -->
        <Button Grid.Row="6"
                Command="{Binding LoginCommand}"
                Height="44"
                Cursor="Hand"
                Margin="0,0,0,6">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="13"
                            Effect="{StaticResource GlowShadow}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1565C0" Offset="0"/>
                                <GradientStop Color="#1976D2" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="INGRESAR"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.92"/></Trigger>
                        <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.80"/></Trigger>
                        <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- LOGO ANIMADO — grande, cubre espacio vacío, sin borde ni fondo -->
        <Grid Grid.Row="7" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Image x:Name="BottomLogo"
                   Source="pack://application:,,,/Assets/patagonia-logo.png"
                   Width="110"
                   Height="110"
                   Stretch="Uniform"
                   Opacity="0.72"
                   RenderOptions.BitmapScalingMode="HighQuality">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="LogoScale" ScaleX="1" ScaleY="1" CenterX="55" CenterY="55"/>
                </Image.RenderTransform>
                <Image.Effect>
                    <DropShadowEffect Color="#1565C0" BlurRadius="28" ShadowDepth="0" Opacity="0.55"/>
                </Image.Effect>
            </Image>
        </Grid>
    </Grid>
</UserControl>
