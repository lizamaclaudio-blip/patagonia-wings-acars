<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.DataContext>
        <Binding Path="DataContext.LoginVM" RelativeSource="{RelativeSource AncestorType=Window}"/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <!-- Animación glow/pulse del logo -->
        <Storyboard x:Key="LogoPulse" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LogoGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.3" To="1.0"
                             Duration="0:0:1.8"
                             AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="LogoScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.95" To="1.05"
                             Duration="0:0:1.8"
                             AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="LogoScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.95" To="1.05"
                             Duration="0:0:1.8"
                             AutoReverse="True"/>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource LogoPulse}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid x:Name="PageRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="148"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HERO BANNER -->
        <Border Grid.Row="0"
                CornerRadius="16"
                Margin="0,0,0,14"
                BorderBrush="#B8D0EA"
                BorderThickness="1.5"
                ClipToBounds="True"
                Effect="{StaticResource PanelShadow}">
            <Grid>
                <!-- Foto de fondo más clara -->
                <Grid.Background>
                    <ImageBrush ImageSource="pack://application:,,,/Assets/patagonia-bg.jpg"
                                Stretch="UniformToFill"
                                Opacity="0.70"/>
                </Grid.Background>
                <!-- Overlay suave azul (no negro) -->
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#881565C0" Offset="0"/>
                            <GradientStop Color="#CC0D3A8A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Contenido centrado -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Logo con animación -->
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,8">
                        <!-- Glow ring animado -->
                        <Ellipse x:Name="LogoGlow"
                                 Width="84" Height="84"
                                 Opacity="0.5">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#6090C8FF" Offset="0"/>
                                    <GradientStop Color="#0090C8FF" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <!-- Logo image -->
                        <Border Width="70" Height="70"
                                CornerRadius="35"
                                Background="#E8F4FF"
                                BorderBrush="White"
                                BorderThickness="2.5"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="LogoScale" ScaleX="1" ScaleY="1" CenterX="35" CenterY="35"/>
                            </Border.RenderTransform>
                            <Image Source="pack://application:,,,/Assets/patagonia-logo.png"
                                   Width="46"
                                   Height="46"
                                   Stretch="Uniform"/>
                        </Border>
                    </Grid>

                    <TextBlock Text="PATAGONIA WINGS"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                    <TextBlock Text="ACARS — SISTEMA DE VUELO"
                               Foreground="#C8E4FF"
                               FontSize="9"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,3,0,0"/>
                    <TextBlock Text="{Binding VersionBadge}"
                               Foreground="#A0C8F0"
                               FontSize="8.5"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CREDENCIALES -->
        <TextBlock Grid.Row="1"
                   Text="NÚMERO / CORREO DEL PILOTO"
                   Foreground="#4A6E9A"
                   FontSize="8"
                   FontWeight="Bold"
                   FontFamily="Segoe UI"
                   Margin="0,0,0,3"/>
        <Border Grid.Row="2"
                Background="#F0F6FF"
                BorderBrush="#B8D0EA"
                BorderThickness="1.5"
                CornerRadius="10"
                Margin="0,0,0,10">
            <TextBox x:Name="EmailBox"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="#0D1F3C"
                     FontSize="11"
                     FontFamily="Segoe UI"
                     CaretBrush="#1565C0"
                     Padding="10,8"
                     Height="38"/>
        </Border>

        <TextBlock Grid.Row="3"
                   Text="CONTRASEÑA"
                   Foreground="#4A6E9A"
                   FontSize="8"
                   FontWeight="Bold"
                   FontFamily="Segoe UI"
                   Margin="0,0,0,3"/>
        <Border Grid.Row="4"
                Background="#F0F6FF"
                BorderBrush="#B8D0EA"
                BorderThickness="1.5"
                CornerRadius="10"
                Margin="0,0,0,10">
            <PasswordBox x:Name="PwdBox"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#0D1F3C"
                         FontSize="11"
                         FontFamily="Segoe UI"
                         Padding="10,8"
                         Height="38"
                         PasswordChanged="PwdBox_PasswordChanged"/>
        </Border>

        <StackPanel Grid.Row="5" Margin="0,0,0,10">
            <CheckBox Content="Recordar sesión"
                      IsChecked="{Binding RememberMe}"
                      Foreground="#4A6E9A"
                      FontSize="9.5"
                      FontFamily="Segoe UI"
                      Margin="0,0,0,6"/>
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#C62828"
                       FontSize="9.5"
                       FontFamily="Segoe UI"
                       TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>

        <StackPanel Grid.Row="6" VerticalAlignment="Bottom">
            <Button Command="{Binding LoginCommand}"
                    Height="44"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="13">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1565C0" Offset="0"/>
                                    <GradientStop Color="#1976D2" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="INGRESAR"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.92"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.80"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <TextBlock Text="{Binding FooterVersion}"
                       Foreground="#4A6E9A"
                       FontSize="8.5"
                       FontFamily="Segoe UI"
                       Margin="0,10,0,0"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>
