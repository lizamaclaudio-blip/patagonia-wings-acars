<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.DataContext>
        <Binding Path="DataContext.LoginVM" RelativeSource="{RelativeSource AncestorType=Window}"/>
    </UserControl.DataContext>

    <Grid x:Name="PageRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="102"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="14"
                Margin="0,0,0,8"
                BorderBrush="#2C4868"
                BorderThickness="1"
                ClipToBounds="True">
            <Grid>
                <Grid.Background>
                    <ImageBrush ImageSource="pack://application:,,,/Assets/patagonia-bg.jpg"
                                Stretch="UniformToFill"
                                Opacity="0.50"/>
                </Grid.Background>
                <Border Background="#C80A1017"/>
                <StackPanel VerticalAlignment="Center" Margin="13,0,13,0">
                    <TextBlock Text="BIENVENIDO A"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="10"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="PATAGONIA WINGS"
                               Foreground="{StaticResource AccentBlueBrush}"
                               FontSize="21"
                               FontWeight="Bold"
                               Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding VersionBadge}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="9"
                               Margin="0,7,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="1"
                   Text="NUMERO / CORREO DEL PILOTO"
                   Style="{StaticResource FieldLabel}"/>
        <TextBox Grid.Row="2"
                 x:Name="EmailBox"
                 Style="{StaticResource DarkTextBox}"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 Height="36"
                 Margin="0,0,0,9"/>

        <TextBlock Grid.Row="3"
                   Text="CONTRASENA"
                   Style="{StaticResource FieldLabel}"/>
        <PasswordBox Grid.Row="4"
                     x:Name="PwdBox"
                     Style="{StaticResource DarkPasswordBox}"
                     Height="36"
                     Margin="0,0,0,9"
                     PasswordChanged="PwdBox_PasswordChanged"/>

        <StackPanel Grid.Row="5" Margin="0,0,0,8">
            <CheckBox Content="Recordar sesion"
                      IsChecked="{Binding RememberMe}"
                      Style="{StaticResource DarkCheckBox}"
                      Margin="0,0,0,6"/>
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#FF8A8A"
                       FontSize="9.5"
                       TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>

        <StackPanel Grid.Row="6" VerticalAlignment="Bottom">
            <Button Style="{StaticResource PrimaryButton}"
                    Command="{Binding LoginCommand}"
                    Content="INGRESAR"
                    Height="38"/>
            <TextBlock Text="{Binding FooterVersion}"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="8.5"
                       Margin="0,8,0,0"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>
