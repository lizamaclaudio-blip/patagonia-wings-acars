<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.SupportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="True">
    <Grid x:Name="PageRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TÍTULO + VERSIÓN -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="SOPORTE DE APLICACION"
                       Foreground="#0D1F3C"
                       FontSize="13"
                       FontWeight="Bold"
                       FontFamily="Segoe UI"
                       VerticalAlignment="Center"/>
            <Border Grid.Column="1"
                    Background="#E0EDFF" BorderBrush="#90B4D8" BorderThickness="1"
                    CornerRadius="8" Padding="8,3" VerticalAlignment="Center">
                <TextBlock Text="{Binding AcarsVersion}"
                           Foreground="#1565C0"
                           FontSize="9"
                           FontWeight="Bold"
                           FontFamily="Consolas"/>
            </Border>
        </Grid>

        <!-- ACARS + FSUIPC -->
        <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,7">
            <Border Background="#FFFFFF" BorderBrush="#B8D0EA" BorderThickness="1.5"
                    CornerRadius="10" Padding="8,7" Margin="0,0,4,0"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel>
                    <TextBlock Text="ACARS"
                               Foreground="#4A6E9A" FontSize="7.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                    <TextBlock Text="{Binding AcarsVersion}"
                               Foreground="#1565C0" FontSize="15" FontWeight="Bold" FontFamily="Consolas"/>
                </StackPanel>
            </Border>
            <Border Background="#FFFFFF" BorderBrush="#B8D0EA" BorderThickness="1.5"
                    CornerRadius="10" Padding="8,7" Margin="4,0,0,0"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel>
                    <TextBlock Text="FSUIPC"
                               Foreground="#4A6E9A" FontSize="7.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                    <TextBlock Text="{Binding FsuipcVersion}"
                               Foreground="#0288D1" FontSize="11" FontWeight="SemiBold" FontFamily="Consolas"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- OPCIONES + IP en fila -->
        <Grid Grid.Row="2" Margin="0,0,0,7">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Opciones -->
            <Border Background="#FFFFFF" BorderBrush="#B8D0EA" BorderThickness="1.5"
                    CornerRadius="10" Padding="10,8" Effect="{StaticResource PanelShadow}">
                <StackPanel>
                    <TextBlock Text="OPCIONES"
                               Foreground="#1565C0" FontSize="7.5" FontWeight="Bold"
                               FontFamily="Segoe UI" Margin="0,0,0,6"/>
                    <CheckBox Content="Siempre visible"
                              IsChecked="{Binding AlwaysVisible}"
                              Foreground="#1E3A64" FontSize="9.5" FontFamily="Segoe UI"
                              Margin="0,0,0,5"/>
                    <CheckBox Content="Usar KG"
                              IsChecked="{Binding UseKg}"
                              Foreground="#1E3A64" FontSize="9.5" FontFamily="Segoe UI"/>
                    <Separator Margin="0,7,0,7"/>
                    <TextBlock Text="HUD MSFS INTERNO"
                               Foreground="#1565C0" FontSize="7.5" FontWeight="Bold"
                               FontFamily="Segoe UI" Margin="0,0,0,5"/>
                    <CheckBox Content="Activar HUD MSFS"
                              IsChecked="{Binding EnableInSimHud}"
                              Foreground="#1E3A64" FontSize="9.5" FontFamily="Segoe UI"
                              Margin="0,0,0,4"/>
                    <CheckBox Content="Solo durante vuelo"
                              IsChecked="{Binding HudOnlyInFlight}"
                              Foreground="#1E3A64" FontSize="9.5" FontFamily="Segoe UI"
                              Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Puerto:" Foreground="#4A6E9A" FontSize="8" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding LocalHudPort, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="6,0,0,0"
                                 Height="24"
                                 VerticalContentAlignment="Center"
                                 Foreground="#0D1F3C" FontSize="9" FontFamily="Consolas"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Rate Hz:" Foreground="#4A6E9A" FontSize="8" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding HudUpdateRateHz, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="6,0,0,0"
                                 Height="24"
                                 VerticalContentAlignment="Center"
                                 Foreground="#0D1F3C" FontSize="9" FontFamily="Consolas"/>
                    </Grid>
                    <TextBlock Text="{Binding HudBridgeStatus}"
                               Foreground="#4A6E9A" FontSize="7.5" FontFamily="Segoe UI"
                               TextWrapping="Wrap" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding HudCommunityStatus}"
                               Foreground="#4A6E9A" FontSize="7.5" FontFamily="Segoe UI"
                               TextWrapping="Wrap" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding SimulatorConnectionStatus}"
                               Foreground="#4A6E9A" FontSize="7.5" FontFamily="Segoe UI"
                               TextWrapping="Wrap" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding HudIndependenceStatus}"
                               Foreground="#1E3A64" FontSize="7.5" FontFamily="Segoe UI"
                               TextWrapping="Wrap" Margin="0,0,0,5"/>
                    <UniformGrid Columns="1" Margin="0,0,0,4">
                        <Button Command="{Binding InstallHudToCommunityCommand}" Height="28" Margin="0,0,0,4">
                            <TextBlock Text="Instalar HUD" Foreground="#1565C0" FontSize="8.5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Command="{Binding OpenHudPackageFolderCommand}" Height="28" Margin="0,0,0,0">
                            <TextBlock Text="Paquete HUD" Foreground="#1565C0" FontSize="8.5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Button>
                    </UniformGrid>
                    <UniformGrid Columns="1">
                        <Button Command="{Binding CopyHudBridgeUrlCommand}" Height="28" Margin="0,0,0,4">
                            <TextBlock Text="Copiar URL" Foreground="#1565C0" FontSize="8.5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Command="{Binding ProbeHudBridgeCommand}" Height="28">
                            <TextBlock Text="Probar bridge" Foreground="#1565C0" FontSize="8.5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Button>
                    </UniformGrid>
                    <Separator Margin="0,7,0,7"/>
                    <TextBlock Text="AUTOUPDATE"
                               Foreground="#1565C0" FontSize="7.5" FontWeight="Bold"
                               FontFamily="Segoe UI" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding UpdateState}" Foreground="#1E3A64" FontSize="8.5" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding UpdateInstalledVersion, StringFormat=Instalada: {0}}" Foreground="#4A6E9A" FontSize="7.5" FontFamily="Segoe UI"/>
                    <TextBlock Text="{Binding UpdateLatestVersion, StringFormat=Disponible: {0}}" Foreground="#4A6E9A" FontSize="7.5" FontFamily="Segoe UI"/>
                    <TextBlock Text="{Binding UpdateChannel, StringFormat=Canal: {0}}" Foreground="#4A6E9A" FontSize="7.5" FontFamily="Segoe UI"/>
                    <TextBlock Text="{Binding UpdateManifestUrl, StringFormat=Manifest: {0}}" Foreground="#4A6E9A" FontSize="7.5" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding UpdateDownloadUrl, StringFormat=Descarga: {0}}" Foreground="#4A6E9A" FontSize="7.5" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding UpdateLastError, StringFormat=Error: {0}}" Foreground="#B91C1C" FontSize="7.5" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                    <UniformGrid Columns="1" Margin="0,4,0,4">
                        <Button Command="{Binding CheckUpdateCommand}" Height="28" Margin="0,0,0,4">
                            <TextBlock Text="Buscar actualizacion" Foreground="#1565C0" FontSize="8.5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Command="{Binding DownloadUpdateCommand}" Height="28">
                            <TextBlock Text="Descargar actualizacion" Foreground="#1565C0" FontSize="8.5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Button>
                    </UniformGrid>
                    <UniformGrid Columns="1">
                        <Button Command="{Binding OpenUpdateLogsCommand}" Height="28" Margin="0,0,0,4">
                            <TextBlock Text="Abrir logs update" Foreground="#1565C0" FontSize="8.5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Command="{Binding CopyUpdateDiagnosticCommand}" Height="28">
                            <TextBlock Text="Copiar diagnostico" Foreground="#1565C0" FontSize="8.5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- IP Simulador -->
            <Border Grid.Row="2"
                    Background="#FFFFFF" BorderBrush="#B8D0EA" BorderThickness="1.5"
                    CornerRadius="10" Padding="10,8" Effect="{StaticResource PanelShadow}">
                <StackPanel>
                    <TextBlock Text="IP SIMULADOR"
                               Foreground="#1565C0" FontSize="7.5" FontWeight="Bold"
                               FontFamily="Segoe UI" Margin="0,0,0,6"/>
                    <Border Background="#F0F6FF" BorderBrush="#B8D0EA" BorderThickness="1" CornerRadius="8">
                        <TextBox Text="{Binding SimulatorIp, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#0D1F3C" FontSize="10" FontFamily="Consolas"
                                 CaretBrush="#1565C0" Padding="7,5" Height="30"/>
                    </Border>
                    <TextBlock Text="Local o remota"
                               Foreground="#4A6E9A" FontSize="7.5" FontFamily="Segoe UI"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- FUNCIONES -->
        <Border Grid.Row="3"
                Background="#FFFFFF" BorderBrush="#B8D0EA" BorderThickness="1.5"
                CornerRadius="10" Padding="10,8" Margin="0,0,0,7"
                Effect="{StaticResource PanelShadow}">
            <StackPanel>
                <TextBlock Text="FUNCIONES"
                           Foreground="#1565C0" FontSize="7.5" FontWeight="Bold"
                           FontFamily="Segoe UI" Margin="0,0,0,7"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding LogoutCommand}" Height="34" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#FFF5F5" BorderBrush="#F5BBBB" BorderThickness="1.5" CornerRadius="9">
                                    <TextBlock Text="Cerrar sesion" Foreground="#C62828" FontSize="9" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                                    <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.70"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="2" Command="{Binding RetryLastPirepCommand}" Height="34" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#EEF5FF" BorderBrush="#90B4D8" BorderThickness="1.5" CornerRadius="9">
                                    <TextBlock Text="Reenviar PIREP" Foreground="#1565C0" FontSize="9" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#D0E8FF"/></Trigger>
                                    <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.80"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- CARPETAS -->
        <Border Grid.Row="4"
                Background="#FFFFFF" BorderBrush="#B8D0EA" BorderThickness="1.5"
                CornerRadius="10" Padding="10,8" Margin="0,0,0,7"
                Effect="{StaticResource PanelShadow}">
            <StackPanel>
                <TextBlock Text="CARPETAS"
                           Foreground="#1565C0" FontSize="7.5" FontWeight="Bold"
                           FontFamily="Segoe UI" Margin="0,0,0,7"/>
                <UniformGrid Columns="5">
                    <Button Command="{Binding OpenDebugFolderCommand}" Height="32" Margin="0,0,4,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#F0F6FF" BorderBrush="#C8DDF5" BorderThickness="1" CornerRadius="8">
                                    <TextBlock Text="Debug" Foreground="#1565C0" FontSize="9" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.80"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding OpenDataFolderCommand}" Height="32" Margin="2,0,2,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#F0F6FF" BorderBrush="#C8DDF5" BorderThickness="1" CornerRadius="8">
                                    <TextBlock Text="Data" Foreground="#1565C0" FontSize="9" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.80"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding OpenAppFolderCommand}" Height="32" Margin="4,0,0,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#F0F6FF" BorderBrush="#C8DDF5" BorderThickness="1" CornerRadius="8">
                                    <TextBlock Text="App" Foreground="#1565C0" FontSize="9" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.80"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding OpenExportsFolderCommand}" Height="32" Margin="4,0,0,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#F0F6FF" BorderBrush="#C8DDF5" BorderThickness="1" CornerRadius="8">
                                    <TextBlock Text="Exports" Foreground="#1565C0" FontSize="9" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.80"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding OpenConfigFolderCommand}" Height="32" Margin="4,0,0,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#F0F6FF" BorderBrush="#C8DDF5" BorderThickness="1" CornerRadius="8">
                                    <TextBlock Text="Config" Foreground="#1565C0" FontSize="9" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.80"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </UniformGrid>
            </StackPanel>
        </Border>

        <!-- TELEMETRY INSPECTOR -->
        <Border Grid.Row="5"
                Background="#FFFFFF" BorderBrush="#B8D0EA" BorderThickness="1.5"
                CornerRadius="10" Padding="10,8" Margin="0,0,0,7"
                Effect="{StaticResource PanelShadow}">
            <StackPanel>
                <TextBlock Text="PATAGONIA WINGS ACARS DATA LAB"
                           Foreground="#1565C0" FontSize="7.5" FontWeight="Bold"
                           FontFamily="Segoe UI" Margin="0,0,0,7"/>
                <UniformGrid Columns="3" Margin="0,0,0,6">
                    <Button Command="{Binding RefreshProfileCommand}" Height="30" Margin="0,0,4,0"><TextBlock Text="Refresh Profile" Foreground="#1565C0" FontSize="8.5" FontWeight="SemiBold" HorizontalAlignment="Center"/></Button>
                    <Button Command="{Binding ResetSampleSessionCommand}" Height="30" Margin="2,0,2,0"><TextBlock Text="Reset Session" Foreground="#1565C0" FontSize="8.5" FontWeight="SemiBold" HorizontalAlignment="Center"/></Button>
                    <Button Command="{Binding MarkAircraftTestedCommand}" Height="30" Margin="4,0,0,0"><TextBlock Text="Mark Tested" Foreground="#1565C0" FontSize="8.5" FontWeight="SemiBold" HorizontalAlignment="Center"/></Button>
                </UniformGrid>
                <UniformGrid Columns="3" Margin="0,0,0,6">
                    <Button Command="{Binding ExportSnapshotJsonCommand}" Height="30" Margin="0,0,4,0"><TextBlock Text="Export JSON" Foreground="#1565C0" FontSize="8.5" FontWeight="SemiBold" HorizontalAlignment="Center"/></Button>
                    <Button Command="{Binding ExportSessionCsvCommand}" Height="30" Margin="2,0,2,0"><TextBlock Text="Export CSV" Foreground="#1565C0" FontSize="8.5" FontWeight="SemiBold" HorizontalAlignment="Center"/></Button>
                    <Button Command="{Binding CopyTelemetryDiagnosticCommand}" Height="30" Margin="4,0,0,0"><TextBlock Text="Copy Diagnostic" Foreground="#1565C0" FontSize="8.5" FontWeight="SemiBold" HorizontalAlignment="Center"/></Button>
                </UniformGrid>
                <TextBlock Text="{Binding TelemetryInspectorLastExport}" Foreground="#4A6E9A" FontSize="7.5" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,3"/>
                <TextBlock Text="{Binding TelemetryInspectorLastMark}" Foreground="#4A6E9A" FontSize="7.5" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,5"/>
                <Border Background="#F0F6FF" BorderBrush="#B8D0EA" BorderThickness="1" CornerRadius="8" Padding="8,6">
                    <TextBlock Text="{Binding TelemetryInspectorSummary}" Foreground="#0D1F3C" FontSize="8" FontFamily="Consolas" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- STATUS MESSAGE -->
        <Border Grid.Row="6"
                Background="#EEF7FF" BorderBrush="#B8D0EA" BorderThickness="1"
                CornerRadius="8" Padding="8,6" Margin="0,0,0,6"
                Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#1565C0" FontSize="9" FontFamily="Segoe UI"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- VOLVER -->
        <Button Grid.Row="7"
                Command="{Binding BackCommand}"
                Height="42"
                Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1565C0" Offset="0"/>
                                <GradientStop Color="#1976D2" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="VOLVER"
                                   Foreground="White" FontSize="11" FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.92"/></Trigger>
                        <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.80"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
    </ScrollViewer>
</UserControl>
