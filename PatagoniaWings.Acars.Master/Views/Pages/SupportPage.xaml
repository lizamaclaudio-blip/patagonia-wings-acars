<UserControl x:Class="PatagoniaWings.Acars.Master.Views.Pages.SupportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.DataContext>
        <Binding Path="DataContext.SupportVM" RelativeSource="{RelativeSource AncestorType=Window}"/>
    </UserControl.DataContext>

    <Grid x:Name="PageRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TÍTULO + VERSIÓN -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="SOPORTE DE APLICACIÓN"
                       Foreground="#0D1F3C"
                       FontSize="13"
                       FontWeight="Bold"
                       FontFamily="Segoe UI"
                       VerticalAlignment="Center"/>
            <Border Grid.Column="1"
                    Background="#E0EDFF" BorderBrush="#90B4D8" BorderThickness="1"
                    CornerRadius="8" Padding="8,3" VerticalAlignment="Center">
                <TextBlock Text="{Binding AcarsVersion}"
                           Foreground="#1565C0"
                           FontSize="9"
                           FontWeight="Bold"
                           FontFamily="Consolas"/>
            </Border>
        </Grid>

        <!-- ACARS + FSUIPC -->
        <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,7">
            <Border Background="#FFFFFF" BorderBrush="#B8D0EA" BorderThickness="1.5"
                    CornerRadius="10" Padding="8,7" Margin="0,0,4,0"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel>
                    <TextBlock Text="ACARS"
                               Foreground="#4A6E9A" FontSize="7.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                    <TextBlock Text="{Binding AcarsVersion}"
                               Foreground="#1565C0" FontSize="15" FontWeight="Bold" FontFamily="Consolas"/>
                </StackPanel>
            </Border>
            <Border Background="#FFFFFF" BorderBrush="#B8D0EA" BorderThickness="1.5"
                    CornerRadius="10" Padding="8,7" Margin="4,0,0,0"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel>
                    <TextBlock Text="FSUIPC"
                               Foreground="#4A6E9A" FontSize="7.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                    <TextBlock Text="{Binding FsuipcVersion}"
                               Foreground="#0288D1" FontSize="11" FontWeight="SemiBold" FontFamily="Consolas"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- OPCIONES + IP en fila -->
        <Grid Grid.Row="2" Margin="0,0,0,7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Opciones -->
            <Border Background="#FFFFFF" BorderBrush="#B8D0EA" BorderThickness="1.5"
                    CornerRadius="10" Padding="10,8" Effect="{StaticResource PanelShadow}">
                <StackPanel>
                    <TextBlock Text="OPCIONES"
                               Foreground="#1565C0" FontSize="7.5" FontWeight="Bold"
                               FontFamily="Segoe UI" Margin="0,0,0,6"/>
                    <CheckBox Content="Siempre visible"
                              IsChecked="{Binding AlwaysVisible}"
                              Foreground="#1E3A64" FontSize="9.5" FontFamily="Segoe UI"
                              Margin="0,0,0,5"/>
                    <CheckBox Content="Usar KG"
                              IsChecked="{Binding UseKg}"
                              Foreground="#1E3A64" FontSize="9.5" FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

            <!-- IP Simulador -->
            <Border Grid.Column="2"
                    Background="#FFFFFF" BorderBrush="#B8D0EA" BorderThickness="1.5"
                    CornerRadius="10" Padding="10,8" Effect="{StaticResource PanelShadow}">
                <StackPanel>
                    <TextBlock Text="IP SIMULADOR"
                               Foreground="#1565C0" FontSize="7.5" FontWeight="Bold"
                               FontFamily="Segoe UI" Margin="0,0,0,6"/>
                    <Border Background="#F0F6FF" BorderBrush="#B8D0EA" BorderThickness="1" CornerRadius="8">
                        <TextBox Text="{Binding SimulatorIp, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#0D1F3C" FontSize="10" FontFamily="Consolas"
                                 CaretBrush="#1565C0" Padding="7,5" Height="30"/>
                    </Border>
                    <TextBlock Text="Local o remota"
                               Foreground="#4A6E9A" FontSize="7.5" FontFamily="Segoe UI"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- FUNCIONES -->
        <Border Grid.Row="3"
                Background="#FFFFFF" BorderBrush="#B8D0EA" BorderThickness="1.5"
                CornerRadius="10" Padding="10,8" Margin="0,0,0,7"
                Effect="{StaticResource PanelShadow}">
            <StackPanel>
                <TextBlock Text="FUNCIONES"
                           Foreground="#1565C0" FontSize="7.5" FontWeight="Bold"
                           FontFamily="Segoe UI" Margin="0,0,0,7"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding LogoutCommand}" Height="34" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#FFF5F5" BorderBrush="#F5BBBB" BorderThickness="1.5" CornerRadius="9">
                                    <TextBlock Text="Cerrar sesión" Foreground="#C62828" FontSize="9" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                                    <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.70"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="2" Command="{Binding RetryLastPirepCommand}" Height="34" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#EEF5FF" BorderBrush="#90B4D8" BorderThickness="1.5" CornerRadius="9">
                                    <TextBlock Text="Reenviar PIREP" Foreground="#1565C0" FontSize="9" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#D0E8FF"/></Trigger>
                                    <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.80"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- CARPETAS -->
        <Border Grid.Row="4"
                Background="#FFFFFF" BorderBrush="#B8D0EA" BorderThickness="1.5"
                CornerRadius="10" Padding="10,8" Margin="0,0,0,7"
                Effect="{StaticResource PanelShadow}">
            <StackPanel>
                <TextBlock Text="CARPETAS"
                           Foreground="#1565C0" FontSize="7.5" FontWeight="Bold"
                           FontFamily="Segoe UI" Margin="0,0,0,7"/>
                <UniformGrid Columns="3">
                    <Button Command="{Binding OpenDebugFolderCommand}" Height="32" Margin="0,0,4,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#F0F6FF" BorderBrush="#C8DDF5" BorderThickness="1" CornerRadius="8">
                                    <TextBlock Text="Debug" Foreground="#1565C0" FontSize="9" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.80"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding OpenDataFolderCommand}" Height="32" Margin="2,0,2,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#F0F6FF" BorderBrush="#C8DDF5" BorderThickness="1" CornerRadius="8">
                                    <TextBlock Text="Data" Foreground="#1565C0" FontSize="9" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.80"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding OpenAppFolderCommand}" Height="32" Margin="4,0,0,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#F0F6FF" BorderBrush="#C8DDF5" BorderThickness="1" CornerRadius="8">
                                    <TextBlock Text="App" Foreground="#1565C0" FontSize="9" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.80"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </UniformGrid>
            </StackPanel>
        </Border>

        <!-- STATUS MESSAGE -->
        <Border Grid.Row="5"
                Background="#EEF7FF" BorderBrush="#B8D0EA" BorderThickness="1"
                CornerRadius="8" Padding="8,6" Margin="0,0,0,6"
                Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#1565C0" FontSize="9" FontFamily="Segoe UI"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- VOLVER -->
        <Button Grid.Row="7"
                Command="{Binding BackCommand}"
                Height="42"
                Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1565C0" Offset="0"/>
                                <GradientStop Color="#1976D2" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="VOLVER"
                                   Foreground="White" FontSize="11" FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.92"/></Trigger>
                        <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.80"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
