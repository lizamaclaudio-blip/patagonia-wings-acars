<Window x:Class="PatagoniaWings.Acars.Master.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Patagonia Wings ACARS"
        Width="540"
        Height="310"
        MinWidth="520"
        MinHeight="290"
        MaxWidth="560"
        MaxHeight="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True">

    <Grid Background="Transparent">
        <Border Margin="10"
                CornerRadius="22"
                BorderBrush="#25405C"
                BorderThickness="1"
                Background="{StaticResource WindowBackgroundBrush}"
                Effect="{StaticResource PanelShadow}">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="ACTUALIZACION DISPONIBLE"
                               Foreground="{StaticResource AccentLightBlueBrush}"
                               FontSize="11"
                               FontWeight="Bold"/>
                    <TextBlock Text="Patagonia Wings ACARS"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,18,0,0">
                    <TextBlock x:Name="VersionLine"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="SourceLine"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="10"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Row="2" VerticalAlignment="Center">
                    <ProgressBar x:Name="ProgressBar"
                                 Height="18"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 Foreground="{StaticResource AccentBlueBrush}"
                                 Background="#162334"/>
                    <TextBlock x:Name="StatusText"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="12"
                               Margin="0,14,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ContinueButton"
                            Style="{StaticResource SecondaryButton}"
                            Content="CONTINUAR SIN ACTUALIZAR"
                            Width="190"
                            Height="38"
                            Visibility="Collapsed"
                            Click="ContinueButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
