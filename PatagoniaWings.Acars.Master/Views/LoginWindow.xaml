<Window x:Class="PatagoniaWings.Acars.Master.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PatagoniaWings.Acars.Master.ViewModels"
        xmlns:local="clr-namespace:PatagoniaWings.Acars.Master.Helpers"
        Title="Patagonia Wings ACARS"
        Width="980" Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>

    <Border CornerRadius="14" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="500"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- â”€â”€ PANEL IZQUIERDO: imagen atmosfÃ©rica â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <Border Grid.Column="0" CornerRadius="14,0,0,14">
                <Border.Background>
                    <ImageBrush ImageSource="pack://application:,,,/Assets/patagonia-bg.jpg"
                                Stretch="UniformToFill"/>
                </Border.Background>
                <Grid>
                    <!-- Overlay degradado pronunciado -->
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#550A0E14" Offset="0"/>
                                <GradientStop Color="#DD0A0E14" Offset="0.85"/>
                                <GradientStop Color="#FF0A0E14" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Overlay degradado vertical superior -->
                    <Rectangle VerticalAlignment="Top" Height="140">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#88000000" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Contenido del panel izquierdo -->
                    <Grid>
                        <!-- Logo superior -->
                        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left"
                                    Margin="28,28,0,0" Orientation="Horizontal">
                            <Image Source="pack://application:,,,/Assets/patagonia-logo.png"
                                   Height="32" Width="32" VerticalAlignment="Center"
                                   Margin="0,0,10,0" Stretch="Uniform"/>
                            <TextBlock Text="PATAGONIA WINGS" FontSize="13"
                                       FontWeight="Bold" Foreground="White"
                                       FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Texto principal inferior -->
                        <StackPanel VerticalAlignment="Bottom" Margin="28,0,24,36">
                            <!-- LÃ­nea decorativa -->
                            <Rectangle Height="3" Width="40" HorizontalAlignment="Left"
                                       Margin="0,0,0,14" RadiusX="2" RadiusY="2">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#2D9CDB" Offset="0"/>
                                        <GradientStop Color="#0CA789" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>

                            <TextBlock Text="ACARS" FontSize="42" FontWeight="Black"
                                       Foreground="White" FontFamily="Segoe UI"
                                       LineHeight="44"/>
                            <TextBlock Text="Aircraft Communications" FontSize="15"
                                       Foreground="#AACCDD" FontFamily="Segoe UI"
                                       Margin="0,2,0,0"/>
                            <TextBlock Text="Addressing and Reporting System"
                                       FontSize="13" Foreground="#7A9AAD"
                                       FontFamily="Segoe UI"/>

                            <!-- VersiÃ³n badge -->
                            <Border CornerRadius="4" Padding="8,4" Margin="0,16,0,0"
                                    HorizontalAlignment="Left" BorderThickness="1">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#1A3A5C"/>
                                </Border.BorderBrush>
                                <Border.Background>
                                    <SolidColorBrush Color="#0A1828"/>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="v2.0.6" Foreground="#2D9CDB"
                                               FontFamily="Consolas" FontSize="11"
                                               FontWeight="Bold" Margin="0,0,8,0"/>
                                    <TextBlock Text="Supabase Direct" Foreground="#606C7A"
                                               FontSize="11"/>
                                </StackPanel>
                            </Border>

                            <!-- Features list -->
                            <StackPanel Margin="0,12,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Ellipse Width="5" Height="5" Fill="#0CA789"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="IntegraciÃ³n MSFS 2020/2024"
                                               Foreground="#7A9AAD" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Ellipse Width="5" Height="5" Fill="#0CA789"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="TelemetrÃ­a en tiempo real"
                                               Foreground="#7A9AAD" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Ellipse Width="5" Height="5" Fill="#2D9CDB"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="PIREPs automÃ¡ticos vÃ­a Supabase"
                                               Foreground="#7A9AAD" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- â”€â”€ PANEL DERECHO: formulario â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <Border Grid.Column="1" CornerRadius="0,14,14,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FF0D1117" Offset="0"/>
                        <GradientStop Color="#FF0A0E14" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- LÃ­nea decorativa lateral izquierda -->
                    <Rectangle Width="2" HorizontalAlignment="Left">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#001A6FB5" Offset="0"/>
                                <GradientStop Color="#FF1A6FB5" Offset="0.3"/>
                                <GradientStop Color="#FF0CA789" Offset="0.7"/>
                                <GradientStop Color="#000CA789" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- BotÃ³n cerrar -->
                    <Button Content="âœ•" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,14,16,0" Width="30" Height="30"
                            Cursor="Hand" Click="BtnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#0A0E14"/>
                                <Setter Property="Foreground" Value="#8B949E"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="#252D3A"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1A2130"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Formulario centrado -->
                    <StackPanel VerticalAlignment="Center" Margin="42,0,40,0" MaxWidth="360">

                        <!-- TÃ­tulo -->
                        <TextBlock Text="Iniciar SesiÃ³n" FontSize="26" FontWeight="Bold"
                                   Foreground="White" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                        <TextBlock Text="Ingresa con tu correo o callsign de Patagonia Wings para entrar al centro de operaciones."
                                   Foreground="#606C7A" FontSize="12" FontFamily="Segoe UI"
                                   Margin="0,0,0,28" TextWrapping="Wrap"/>

                        <!-- Campo usuario -->
                        <TextBlock Text="EMAIL O CALLSIGN" Style="{StaticResource FieldLabel}"
                                   Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Height="44"/>

                        <!-- Campo contraseÃ±a -->
                        <TextBlock Text="CONTRASEÃ‘A" Style="{StaticResource FieldLabel}"
                                   Margin="0,14,0,6"/>
                        <PasswordBox x:Name="PwdBox" Style="{StaticResource DarkPasswordBox}"
                                     Height="44" PasswordChanged="PwdBox_PasswordChanged"/>

                        <!-- Recordar sesiÃ³n -->
                        <CheckBox Content="Recordar sesiÃ³n" Style="{StaticResource DarkCheckBox}"
                                  IsChecked="{Binding RememberMe}" Margin="0,12,0,0"/>

                        <!-- Mensaje de error -->
                        <Border CornerRadius="6" Padding="12,8" Margin="0,12,0,0"
                                BorderThickness="1"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#5C1A1A"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <SolidColorBrush Color="#1A0A0A"/>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="âš  " Foreground="#FF4444" FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6666"
                                           FontSize="12" FontFamily="Segoe UI"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- BotÃ³n ingresar -->
                        <Button Content="âœˆ  INGRESAR AL SISTEMA"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding LoginCommand}"
                                Margin="0,18,0,0" Height="46" FontSize="14"/>

                        <!-- Loading -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Margin="0,14,0,0"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#2D9CDB" Offset="0"/>
                                        <GradientStop Color="#1A4060" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="Conectando con Supabase..." Foreground="#2D9CDB"
                                       FontSize="12" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Footer -->
                        <TextBlock Text="Patagonia Wings Virtual Airline ACARS 2.0.10"
                                   Foreground="#252D3A" FontSize="10" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,28,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>

