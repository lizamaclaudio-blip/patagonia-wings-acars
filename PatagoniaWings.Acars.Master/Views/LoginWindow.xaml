<Window x:Class="PatagoniaWings.Acars.Master.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PatagoniaWings.Acars.Master.ViewModels"
        Title="Patagonia Wings ACARS"
        Width="900" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Border CornerRadius="12" ClipToBounds="True">
        <Grid>
            <!-- Fondo izquierdo: imagen + overlay -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Panel izquierdo: imagen -->
            <Border Grid.Column="0">
                <Border.Background>
                    <ImageBrush ImageSource="pack://application:,,,/Assets/patagonia-bg.jpg"
                                Stretch="UniformToFill"/>
                </Border.Background>
                <Grid>
                    <!-- Overlay degradado -->
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#CC0D1117" Offset="1"/>
                                <GradientStop Color="#660D1117" Offset="0"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <!-- Logo y texto -->
                    <StackPanel VerticalAlignment="Bottom" Margin="32,0,32,40">
                        <TextBlock Text="PATAGONIA WINGS" FontSize="28" FontWeight="Bold"
                                   Foreground="White" FontFamily="Segoe UI"/>
                        <TextBlock Text="ACARS v1.0" FontSize="14" Foreground="#2D9CDB"
                                   FontFamily="Segoe UI" Margin="0,4,0,0"/>
                        <TextBlock Text="Sistema de Registro de Vuelos" FontSize="12"
                                   Foreground="#8B949E" FontFamily="Segoe UI" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Panel derecho: formulario -->
            <Border Grid.Column="1" Background="#FF0D1117">
                <Grid>
                    <!-- Botón cerrar -->
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,12,16,0" Width="28" Height="28"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#8B949E" FontSize="14" Cursor="Hand"
                            Click="BtnClose_Click"/>

                    <StackPanel VerticalAlignment="Center" Margin="48,0">
                        <TextBlock Text="Iniciar Sesión" FontSize="26" FontWeight="Bold"
                                   Foreground="White" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                        <TextBlock Text="Ingresa con tu correo de Supabase o tu callsign"
                                   Foreground="#8B949E" FontSize="13" FontFamily="Segoe UI"
                                   Margin="0,0,0,32"/>

                        <!-- Usuario -->
                        <TextBlock Text="EMAIL O CALLSIGN" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Height="40"/>

                        <!-- Contraseña -->
                        <TextBlock Text="CONTRASEÑA" Style="{StaticResource FieldLabel}" Margin="0,16,0,6"/>
                        <PasswordBox x:Name="PwdBox" Style="{StaticResource DarkPasswordBox}"
                                     Height="40" PasswordChanged="PwdBox_PasswordChanged"/>

                        <!-- Recordar -->
                        <CheckBox Content="Recordar sesión" Style="{StaticResource DarkCheckBox}"
                                  IsChecked="{Binding RememberMe}" Margin="0,14,0,0"/>

                        <!-- Error -->
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF4444"
                                   FontSize="12" FontFamily="Segoe UI" TextWrapping="Wrap"
                                   Margin="0,12,0,0"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                        <!-- Botón login -->
                        <Button Content="INGRESAR" Style="{StaticResource PrimaryButton}"
                                Command="{Binding LoginCommand}"
                                Margin="0,20,0,0" Height="44"/>

                        <!-- Loading -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Margin="0,12,0,0"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Conectando..." Foreground="#8B949E"
                                       FontSize="12" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"
                                           xmlns:local="clr-namespace:PatagoniaWings.Acars.Master.Helpers"/>
    </Window.Resources>
</Window>
