<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:PatagoniaWings.Acars.Master.Helpers">

    <Color x:Key="BackgroundDarkColor">#060A10</Color>
    <Color x:Key="BackgroundMidColor">#0A111A</Color>
    <Color x:Key="BackgroundCardColor">#0E1622</Color>
    <Color x:Key="BackgroundCardAltColor">#101B29</Color>
    <Color x:Key="AccentBlueColor">#58A6FF</Color>
    <Color x:Key="AccentLightBlueColor">#A9D1FF</Color>
    <Color x:Key="AccentTealColor">#58D5FF</Color>
    <Color x:Key="AccentVioletColor">#7A8CFF</Color>
    <Color x:Key="TextPrimaryColor">#F7FAFF</Color>
    <Color x:Key="TextSecondaryColor">#BAC7D9</Color>
    <Color x:Key="TextMutedColor">#72839A</Color>
    <Color x:Key="BorderColor">#1E2B3D</Color>
    <Color x:Key="GreenColor">#4CD08C</Color>
    <Color x:Key="RedColor">#FF6767</Color>
    <Color x:Key="YellowColor">#F3C25B</Color>

    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="{StaticResource BackgroundDarkColor}"/>
    <SolidColorBrush x:Key="BackgroundMidBrush" Color="{StaticResource BackgroundMidColor}"/>
    <SolidColorBrush x:Key="BackgroundCardBrush" Color="{StaticResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="BackgroundCardAltBrush" Color="{StaticResource BackgroundCardAltColor}"/>
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="AccentLightBlueBrush" Color="{StaticResource AccentLightBlueColor}"/>
    <SolidColorBrush x:Key="AccentTealBrush" Color="{StaticResource AccentTealColor}"/>
    <SolidColorBrush x:Key="AccentVioletBrush" Color="{StaticResource AccentVioletColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}"/>
    <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource YellowColor}"/>

    <FontFamily x:Key="MainFont">Segoe UI</FontFamily>

    <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#061018" Offset="0"/>
        <GradientStop Color="#0B1622" Offset="0.48"/>
        <GradientStop Color="#081019" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ActionGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#5AA8FF" Offset="0"/>
        <GradientStop Color="#7692FF" Offset="1"/>
    </LinearGradientBrush>

    <DropShadowEffect x:Key="PanelShadow" Color="#CC000000" BlurRadius="24" ShadowDepth="0" Opacity="0.46"/>
    <DropShadowEffect x:Key="GlowShadow" Color="#8058A6FF" BlurRadius="18" ShadowDepth="0" Opacity="0.36"/>

    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="8.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AccentLightBlueBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="8.5"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="#B20E1622"/>
        <Setter Property="BorderBrush" Value="#273444"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Effect" Value="{StaticResource PanelShadow}"/>
    </Style>

    <Style x:Key="InsetCard" TargetType="Border">
        <Setter Property="Background" Value="#0B121C"/>
        <Setter Property="BorderBrush" Value="#1D2A39"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="8,7"/>
    </Style>

    <Style x:Key="InsetCardTight" TargetType="Border" BasedOn="{StaticResource InsetCard}">
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Padding" Value="7,6"/>
    </Style>

    <Style x:Key="CardBlue" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderBrush" Value="#4578AE"/>
    </Style>
    <Style x:Key="CardTeal" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderBrush" Value="#387D9E"/>
    </Style>
    <Style x:Key="CardGreen" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderBrush" Value="#3C8B6D"/>
    </Style>
    <Style x:Key="CardGold" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderBrush" Value="#8A7042"/>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ActionGradientBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="9.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Effect" Value="{StaticResource GlowShadow}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.96"/></Trigger>
                        <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.82"/></Trigger>
                        <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.35"/><Setter Property="Effect" Value="{x:Null}"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="#121D2B"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="#2A3B50"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="9.5"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#172437"/><Setter Property="BorderBrush" Value="#4E6887"/></Trigger>
                        <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.82"/></Trigger>
                        <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.35"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="#1B2735" BorderThickness="1" CornerRadius="14" Padding="{TemplateBinding Padding}" Margin="0,0,0,8">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Background" Value="#121E2B"/><Setter Property="Foreground" Value="White"/></Trigger>
                        <Trigger Property="IsPressed" Value="True"><Setter TargetName="Root" Property="Background" Value="#162639"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="SidebarActiveControlTemplate" TargetType="Button">
        <Border Margin="0,0,0,8" CornerRadius="14" Background="#151F2D" BorderBrush="#4E6C8E" BorderThickness="1" Padding="{TemplateBinding Padding}">
            <Grid>
                <Border Width="4" HorizontalAlignment="Left" Margin="-14,-12,0,-12" Background="{StaticResource AccentBlueBrush}" CornerRadius="2"/>
                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </ControlTemplate>

    <Style x:Key="DarkTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="#0A121D"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="#263648"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentLightBlueBrush}"/>
    </Style>

    <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
        <Setter Property="Background" Value="#0A121D"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="#263648"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="10"/>
    </Style>

    <Style x:Key="DarkComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="#0A121D"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="#263648"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="Background" Value="#101822"/>
                    <Setter Property="Padding" Value="8,6"/>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TelemetryValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style x:Key="TelemetryUnit" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Margin" Value="5,0,0,3"/>
    </Style>
    <Style x:Key="StatBig" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AccentLightBlueBrush}"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="PillGreen" TargetType="Border"><Setter Property="Background" Value="#15231E"/><Setter Property="BorderBrush" Value="#2E5344"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="11"/><Setter Property="Padding" Value="8,3"/></Style>
    <Style x:Key="PillBlue" TargetType="Border"><Setter Property="Background" Value="#131C28"/><Setter Property="BorderBrush" Value="#38506D"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="11"/><Setter Property="Padding" Value="8,3"/></Style>
    <Style x:Key="PillGold" TargetType="Border"><Setter Property="Background" Value="#2A2318"/><Setter Property="BorderBrush" Value="#7B6740"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="11"/><Setter Property="Padding" Value="8,3"/></Style>

    <Style x:Key="DarkListBox" TargetType="ListBox"><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/></Style>
    <Style x:Key="DarkListBoxItem" TargetType="ListBoxItem"><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/><Setter Property="Padding" Value="6,4"/></Style>
    <Style x:Key="DarkCheckBox" TargetType="CheckBox"><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/><Setter Property="FontFamily" Value="{StaticResource MainFont}"/><Setter Property="FontSize" Value="9.5"/></Style>
    <Style TargetType="ScrollBar"><Setter Property="Background" Value="Transparent"/><Setter Property="Width" Value="6"/><Setter Property="Opacity" Value="0.55"/></Style>

    <Style x:Key="LedStatusDot" TargetType="Ellipse">
        <Setter Property="Width" Value="12"/>
        <Setter Property="Height" Value="12"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Stroke" Value="#203040"/>
        <Setter Property="StrokeThickness" Value="0.8"/>
    </Style>

    <Style x:Key="LedStatusLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="8.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    <helpers:StringFallbackConverter x:Key="StringFallbackConverter"/>
    <helpers:BoolInverseConverter x:Key="BoolInverseConverter"/>
    <helpers:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    <helpers:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
    <helpers:ScoreToDisplayConverter x:Key="ScoreToDisplayConverter"/>
    <helpers:GradeToColorConverter x:Key="GradeToColorConverter"/>
    <helpers:VSToColorConverter x:Key="VSToColorConverter"/>
    <helpers:BoolToColorConverter x:Key="BoolToColorConverter"/>
    <helpers:TabToVisibilityConverter x:Key="TabToVisibilityConverter"/>
    <helpers:PhaseToStringConverter x:Key="PhaseToStringConverter"/>
    <helpers:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
</ResourceDictionary>
