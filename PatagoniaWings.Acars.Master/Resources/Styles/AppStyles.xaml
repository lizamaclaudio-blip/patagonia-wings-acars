<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ COLORES ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="BackgroundDarkColor">#FFEFF6FF</Color>
    <Color x:Key="BackgroundMidColor">#FFF8FAFC</Color>
    <Color x:Key="BackgroundCardColor">#FFFFFFFF</Color>
    <Color x:Key="AccentBlueColor">#FF0369A1</Color>
    <Color x:Key="AccentLightBlueColor">#FF0284C7</Color>
    <Color x:Key="AccentTealColor">#FF0EA5E9</Color>
    <Color x:Key="TextPrimaryColor">#FF0F172A</Color>
    <Color x:Key="TextSecondaryColor">#FF64748B</Color>
    <Color x:Key="BorderColor">#FFBFDBFE</Color>
    <Color x:Key="GreenColor">#FF10B981</Color>
    <Color x:Key="RedColor">#FFEF4444</Color>
    <Color x:Key="YellowColor">#FFF59E0B</Color>

    <SolidColorBrush x:Key="BackgroundDarkBrush"    Color="{StaticResource BackgroundDarkColor}"/>
    <SolidColorBrush x:Key="BackgroundMidBrush"     Color="{StaticResource BackgroundMidColor}"/>
    <SolidColorBrush x:Key="BackgroundCardBrush"    Color="{StaticResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="AccentBlueBrush"        Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="AccentLightBlueBrush"   Color="{StaticResource AccentLightBlueColor}"/>
    <SolidColorBrush x:Key="AccentTealBrush"        Color="{StaticResource AccentTealColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"       Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"     Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="BorderBrush"            Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="GreenBrush"             Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="RedBrush"               Color="{StaticResource RedColor}"/>
    <SolidColorBrush x:Key="YellowBrush"            Color="{StaticResource YellowColor}"/>

    <!-- ═══ FUENTES ═══════════════════════════════════════════════════════════ -->
    <FontFamily x:Key="MainFont">Segoe UI</FontFamily>

    <!-- ═══ BOTÓN PRIMARIO ════════════════════════════════════════════════════ -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF1A6FB5" Offset="0"/>
                    <GradientStop Color="#FF0CA789" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground"   Value="White"/>
        <Setter Property="FontFamily"   Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"     Value="12"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Padding"      Value="14,7"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#FF0284C7" BlurRadius="8" ShadowDepth="0" Opacity="0.30"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.88"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.72"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity"  Value="0.38"/>
                            <Setter Property="Effect"   Value="{x:Null}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ BOTÓN SECUNDARIO ══════════════════════════════════════════════════ -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground"       Value="{StaticResource AccentLightBlueBrush}"/>
        <Setter Property="BorderBrush"      Value="#BFDBFE"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="FontFamily"       Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"         Value="11"/>
        <Setter Property="Padding"          Value="10,6"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#DBEAFE"/>
                            <Setter Property="BorderBrush" Value="{StaticResource AccentLightBlueBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.75"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ BOTÓN SIDEBAR ════════════════════════════════════════════════════ -->
    <Style x:Key="SidebarButton" TargetType="Button">
        <Setter Property="Background"               Value="Transparent"/>
        <Setter Property="Foreground"               Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontFamily"               Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"                 Value="12"/>
        <Setter Property="Padding"                  Value="10,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="Cursor"                   Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}"
                            CornerRadius="5" Padding="{TemplateBinding Padding}" Margin="3,1"
                            BorderBrush="Transparent" BorderThickness="0">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#DBEAFE"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#BFDBFE"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ TEMPLATE ACTIVO SIDEBAR ══════════════════════════════════════════ -->
    <ControlTemplate x:Key="SidebarActiveControlTemplate" TargetType="Button">
        <Grid Margin="3,1">
            <Border Width="3" HorizontalAlignment="Left"
                    Background="{StaticResource AccentTealBrush}"
                    Margin="-3,3,0,3"/>
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="0,5,5,0" Padding="{TemplateBinding Padding}" Margin="3,0,0,0">
                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </ControlTemplate>

    <!-- ═══ BOTÓN SIDEBAR ACTIVO ════════════════════════════════════════════ -->
    <Style x:Key="SidebarButtonActive" TargetType="Button" BasedOn="{StaticResource SidebarButton}">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#DBEAFE" Offset="0"/>
                    <GradientStop Color="#EFF6FF" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="{StaticResource AccentLightBlueBrush}"/>
        <Setter Property="Template" Value="{StaticResource SidebarActiveControlTemplate}"/>
    </Style>

    <!-- ═══ TEXTBOX ══════════════════════════════════════════════════════════ -->
    <Style x:Key="DarkTextBox" TargetType="TextBox">
        <Setter Property="Background"       Value="#F0F9FF"/>
        <Setter Property="Foreground"       Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Padding"          Value="8,6"/>
        <Setter Property="FontFamily"       Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"         Value="12"/>
        <Setter Property="CaretBrush"       Value="{StaticResource AccentLightBlueBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost" Focusable="False"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ COMBOBOX ═════════════════════════════════════════════════════════ -->
    <Style x:Key="DarkComboBox" TargetType="ComboBox">
        <Setter Property="Background"       Value="#F0F9FF"/>
        <Setter Property="Foreground"       Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Padding"          Value="8,6"/>
        <Setter Property="FontFamily"       Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"         Value="12"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="Background" Value="{StaticResource BackgroundMidBrush}"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="ItemBorder"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="#DBEAFE"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="#BFDBFE"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid SnapsToDevicePixels="True">
                        <ToggleButton x:Name="ToggleButton"
                                      Focusable="False"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="ToggleBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="5">
                                        <Grid TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="26"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0"
                                                              Margin="10,0,4,0"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Left"
                                                              Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                              ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                              ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="▼"
                                                       FontSize="9"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentTealBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide"
                               IsOpen="{TemplateBinding IsDropDownOpen}">
                            <Border Background="{StaticResource BackgroundMidBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ CARD ══════════════════════════════════════════════════════════════ -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background"       Value="{StaticResource BackgroundCardBrush}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="8"/>
        <Setter Property="Padding"          Value="12"/>
    </Style>

    <Style x:Key="CardBlue" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderThickness"  Value="0,2,0,0"/>
        <Setter Property="BorderBrush"      Value="{StaticResource AccentBlueBrush}"/>
    </Style>
    <Style x:Key="CardTeal" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderThickness"  Value="0,2,0,0"/>
        <Setter Property="BorderBrush"      Value="{StaticResource AccentTealBrush}"/>
    </Style>
    <Style x:Key="CardGreen" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderThickness"  Value="0,2,0,0"/>
        <Setter Property="BorderBrush"      Value="{StaticResource GreenBrush}"/>
    </Style>
    <Style x:Key="CardGold" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderThickness"  Value="0,2,0,0"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#FFD700"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ LABEL CAMPO ═══════════════════════════════════════════════════════ -->
    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="#64748B"/>
        <Setter Property="FontFamily"   Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"     Value="9"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Margin"       Value="0,0,0,3"/>
    </Style>

    <!-- ═══ TEXTO TÍTULO ══════════════════════════════════════════════════════ -->
    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily"   Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"     Value="16"/>
        <Setter Property="FontWeight"   Value="Bold"/>
        <Setter Property="Margin"       Value="0,0,0,10"/>
    </Style>

    <!-- ═══ DATO TELEMETRÍA ═══════════════════════════════════════════════════ -->
    <Style x:Key="TelemetryValue" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily"   Value="Consolas"/>
        <Setter Property="FontSize"     Value="18"/>
        <Setter Property="FontWeight"   Value="Bold"/>
    </Style>

    <Style x:Key="TelemetryUnit" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="#94A3B8"/>
        <Setter Property="FontFamily"   Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"     Value="10"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Margin"       Value="4,0,0,2"/>
    </Style>

    <!-- ═══ STAT BIG (dashboard) ════════════════════════════════════════════ -->
    <Style x:Key="StatBig" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource AccentLightBlueBrush}"/>
        <Setter Property="FontFamily"   Value="Consolas"/>
        <Setter Property="FontSize"     Value="22"/>
        <Setter Property="FontWeight"   Value="Bold"/>
    </Style>

    <!-- ═══ PILL / BADGE ════════════════════════════════════════════════════ -->
    <Style x:Key="PillGreen" TargetType="Border">
        <Setter Property="Background"       Value="#D1FAE5"/>
        <Setter Property="BorderBrush"      Value="#6EE7B7"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="10"/>
        <Setter Property="Padding"          Value="6,2"/>
    </Style>
    <Style x:Key="PillBlue" TargetType="Border">
        <Setter Property="Background"       Value="#DBEAFE"/>
        <Setter Property="BorderBrush"      Value="#93C5FD"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="10"/>
        <Setter Property="Padding"          Value="6,2"/>
    </Style>
    <Style x:Key="PillGold" TargetType="Border">
        <Setter Property="Background"       Value="#FEF3C7"/>
        <Setter Property="BorderBrush"      Value="#FCD34D"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="10"/>
        <Setter Property="Padding"          Value="6,2"/>
    </Style>

    <!-- ═══ LISTBOX ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="DarkListBox" TargetType="ListBox">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Foreground"       Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style x:Key="DarkListBoxItem" TargetType="ListBoxItem">
        <Setter Property="Background"   Value="Transparent"/>
        <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Padding"      Value="6,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border Background="{TemplateBinding Background}" CornerRadius="5"
                            Padding="{TemplateBinding Padding}" Margin="0,1">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#DBEAFE"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#BFDBFE"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ SCROLLBAR ════════════════════════════════════════════════════════ -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background"   Value="Transparent"/>
        <Setter Property="Width"        Value="4"/>
        <Setter Property="Opacity"      Value="0.4"/>
    </Style>

    <!-- ═══ CHECKBOX ═════════════════════════════════════════════════════════ -->
    <Style x:Key="DarkCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily"   Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"     Value="12"/>
    </Style>

    <!-- ═══ PASSWORDBOX ═══════════════════════════════════════════════════════ -->
    <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
        <Setter Property="Background"       Value="#F0F9FF"/>
        <Setter Property="Foreground"       Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Padding"          Value="8,6"/>
        <Setter Property="FontFamily"       Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"         Value="12"/>
        <Setter Property="CaretBrush"       Value="{StaticResource AccentLightBlueBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost" Focusable="False"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ CONVERTERS GLOBALES ═══════════════════════════════════════════════ -->
    <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter"
        xmlns:helpers="clr-namespace:PatagoniaWings.Acars.Master.Helpers"/>
    <helpers:BoolInverseConverter x:Key="BoolInverseConverter"
        xmlns:helpers="clr-namespace:PatagoniaWings.Acars.Master.Helpers"/>
    <helpers:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"
        xmlns:helpers="clr-namespace:PatagoniaWings.Acars.Master.Helpers"/>
    <helpers:GradeToColorConverter x:Key="GradeToColorConverter"
        xmlns:helpers="clr-namespace:PatagoniaWings.Acars.Master.Helpers"/>
    <helpers:VSToColorConverter x:Key="VSToColorConverter"
        xmlns:helpers="clr-namespace:PatagoniaWings.Acars.Master.Helpers"/>
    <helpers:BoolToColorConverter x:Key="BoolToColorConverter"
        xmlns:helpers="clr-namespace:PatagoniaWings.Acars.Master.Helpers"/>
    <helpers:TabToVisibilityConverter x:Key="TabToVisibilityConverter"
        xmlns:helpers="clr-namespace:PatagoniaWings.Acars.Master.Helpers"/>
    <helpers:PhaseToStringConverter x:Key="PhaseToStringConverter"
        xmlns:helpers="clr-namespace:PatagoniaWings.Acars.Master.Helpers"/>
    <helpers:BoolToBrushConverter x:Key="BoolToBrushConverter"
        xmlns:helpers="clr-namespace:PatagoniaWings.Acars.Master.Helpers"/>
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

</ResourceDictionary>
