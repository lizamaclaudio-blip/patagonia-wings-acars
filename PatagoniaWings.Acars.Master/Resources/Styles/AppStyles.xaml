<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:PatagoniaWings.Acars.Master.Helpers">

    <ResourceDictionary.MergedDictionaries>
        <!-- Converters de runtime conectados desde la carpeta dedicada creada para el sistema visual. -->
        <ResourceDictionary Source="Converters.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ── Tema blanco/azul premium ── -->
    <Color x:Key="BackgroundDarkColor">#0A1525</Color>
    <Color x:Key="BackgroundMidColor">#0E1C30</Color>
    <Color x:Key="BackgroundCardColor">#F3F8FF</Color>
    <Color x:Key="BackgroundCardAltColor">#EBF3FF</Color>
    <Color x:Key="AccentBlueColor">#1565C0</Color>
    <Color x:Key="AccentLightBlueColor">#1976D2</Color>
    <Color x:Key="AccentTealColor">#0288D1</Color>
    <Color x:Key="AccentVioletColor">#5C6BC0</Color>
    <Color x:Key="TextPrimaryColor">#0D1F3C</Color>
    <Color x:Key="TextSecondaryColor">#1E3A64</Color>
    <Color x:Key="TextMutedColor">#4A6E9A</Color>
    <Color x:Key="BorderColor">#B8D0EA</Color>
    <Color x:Key="GreenColor">#1B8A4C</Color>
    <Color x:Key="RedColor">#C62828</Color>
    <Color x:Key="YellowColor">#E65100</Color>

    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="{StaticResource BackgroundDarkColor}"/>
    <SolidColorBrush x:Key="BackgroundMidBrush" Color="{StaticResource BackgroundMidColor}"/>
    <SolidColorBrush x:Key="BackgroundCardBrush" Color="{StaticResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="BackgroundCardAltBrush" Color="{StaticResource BackgroundCardAltColor}"/>
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="AccentLightBlueBrush" Color="{StaticResource AccentLightBlueColor}"/>
    <SolidColorBrush x:Key="AccentTealBrush" Color="{StaticResource AccentTealColor}"/>
    <SolidColorBrush x:Key="AccentVioletBrush" Color="{StaticResource AccentVioletColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}"/>
    <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource YellowColor}"/>

    <FontFamily x:Key="MainFont">Segoe UI</FontFamily>

    <!-- Fondo ventana: blanco premium -->
    <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#EEF5FF" Offset="0.5"/>
        <GradientStop Color="#E6F0FF" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ActionGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#1565C0" Offset="0"/>
        <GradientStop Color="#1976D2" Offset="1"/>
    </LinearGradientBrush>

    <DropShadowEffect x:Key="PanelShadow" Color="#440D1F3C" BlurRadius="18" ShadowDepth="2" Opacity="0.18"/>
    <DropShadowEffect x:Key="GlowShadow" Color="#801565C0" BlurRadius="14" ShadowDepth="0" Opacity="0.32"/>

    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="8"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="8"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#B8D0EA"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Effect" Value="{StaticResource PanelShadow}"/>
    </Style>

    <Style x:Key="InsetCard" TargetType="Border">
        <Setter Property="Background" Value="#F0F6FF"/>
        <Setter Property="BorderBrush" Value="#C8DDF5"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="8,7"/>
    </Style>

    <Style x:Key="InsetCardTight" TargetType="Border" BasedOn="{StaticResource InsetCard}">
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Padding" Value="7,6"/>
    </Style>

    <Style x:Key="CardBlue" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderBrush" Value="#90B4D8"/>
        <Setter Property="Background" Value="#FFFFFF"/>
    </Style>
    <Style x:Key="CardTeal" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderBrush" Value="#6EC4D8"/>
        <Setter Property="Background" Value="#FFFFFF"/>
    </Style>
    <Style x:Key="CardGreen" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderBrush" Value="#4CAF82"/>
        <Setter Property="Background" Value="#FFFFFF"/>
    </Style>
    <Style x:Key="CardGold" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderBrush" Value="#D4A647"/>
        <Setter Property="Background" Value="#FFFFFF"/>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ActionGradientBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="9.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Effect" Value="{StaticResource GlowShadow}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.96"/></Trigger>
                        <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.82"/></Trigger>
                        <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.35"/><Setter Property="Effect" Value="{x:Null}"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="#E8F2FF"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="#90B4D8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="9.5"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#D0E8FF"/><Setter Property="BorderBrush" Value="#6A9DC8"/></Trigger>
                        <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.82"/></Trigger>
                        <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.35"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="#B8D0EA" BorderThickness="1" CornerRadius="14" Padding="{TemplateBinding Padding}" Margin="0,0,0,8">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Background" Value="#E0EDFF"/><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/></Trigger>
                        <Trigger Property="IsPressed" Value="True"><Setter TargetName="Root" Property="Background" Value="#C8DEFF"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="SidebarActiveControlTemplate" TargetType="Button">
        <Border Margin="0,0,0,8" CornerRadius="14" Background="#E0EDFF" BorderBrush="#90B4D8" BorderThickness="1" Padding="{TemplateBinding Padding}">
            <Grid>
                <Border Width="4" HorizontalAlignment="Left" Margin="-14,-12,0,-12" Background="{StaticResource AccentBlueBrush}" CornerRadius="2"/>
                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </ControlTemplate>

    <Style x:Key="DarkTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="#F0F6FF"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="#B8D0EA"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentBlueBrush}"/>
    </Style>

    <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
        <Setter Property="Background" Value="#F0F6FF"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="#B8D0EA"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="10"/>
    </Style>

    <Style x:Key="DarkComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="#F0F6FF"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="#B8D0EA"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="Background" Value="#F0F6FF"/>
                    <Setter Property="Padding" Value="8,6"/>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TelemetryValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style x:Key="TelemetryUnit" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Margin" Value="5,0,0,3"/>
    </Style>
    <Style x:Key="StatBig" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AccentLightBlueBrush}"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="PillGreen" TargetType="Border"><Setter Property="Background" Value="#E0F5EC"/><Setter Property="BorderBrush" Value="#4CAF82"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="11"/><Setter Property="Padding" Value="8,3"/></Style>
    <Style x:Key="PillBlue" TargetType="Border"><Setter Property="Background" Value="#E0EDFF"/><Setter Property="BorderBrush" Value="#90B4D8"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="11"/><Setter Property="Padding" Value="8,3"/></Style>
    <Style x:Key="PillGold" TargetType="Border"><Setter Property="Background" Value="#FFF3E0"/><Setter Property="BorderBrush" Value="#D4A647"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="11"/><Setter Property="Padding" Value="8,3"/></Style>

    <Style x:Key="DarkListBox" TargetType="ListBox"><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/></Style>
    <Style x:Key="DarkListBoxItem" TargetType="ListBoxItem"><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/><Setter Property="Padding" Value="6,4"/></Style>
    <Style x:Key="DarkCheckBox" TargetType="CheckBox"><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/><Setter Property="FontFamily" Value="{StaticResource MainFont}"/><Setter Property="FontSize" Value="9.5"/></Style>
    <Style TargetType="ScrollBar"><Setter Property="Background" Value="Transparent"/><Setter Property="Width" Value="6"/><Setter Property="Opacity" Value="0.55"/></Style>

    <Style x:Key="LedStatusDot" TargetType="Ellipse">
        <Setter Property="Width" Value="12"/>
        <Setter Property="Height" Value="12"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Stroke" Value="#B8D0EA"/>
        <Setter Property="StrokeThickness" Value="0.8"/>
    </Style>

    <Style x:Key="LedStatusLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize" Value="8.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <helpers:BoolInverseConverter x:Key="BoolInverseConverter"/>
    <helpers:GradeToColorConverter x:Key="GradeToColorConverter"/>
    <helpers:VSToColorConverter x:Key="VSToColorConverter"/>
    <helpers:PhaseToStringConverter x:Key="PhaseToStringConverter"/>
    <helpers:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
</ResourceDictionary>
