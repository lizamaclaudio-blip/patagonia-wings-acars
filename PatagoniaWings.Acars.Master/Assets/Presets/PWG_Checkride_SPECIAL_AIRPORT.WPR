            <WindLayerSpeed Value="14.000" Unit="knts"/>
        </WindLayer>
        <WindLayer>
            <WindLayerAltitude Value="1000.000" Unit="m"/>
            <WindLayerAngle Value="255.000" Unit="degrees"/>
            <WindLayerSpeed Value="22.000" Unit="knts"/>
        </WindLayer>
        <WindLayer>
            <WindLayerAltitude Value="4000.000" Unit="m"/>
            <WindLayerAngle Value="270.000" Unit="degrees"/>
            <WindLayerSpeed Value="38.000" Unit="knts"/>
        </WindLayer>
        <MSLPressure Value="101125.000" Unit="pa"/>
        <MSLTemperature Value="284.150" Unit="k"/>
        <AerosolDensity Value="7000.000" Unit="m"/>
        <Pollution Value="0.100" Unit="(0 - 1)"/>
        <Precipitations Value="0.800" Unit="mm/h"/>
        <SnowCover Value="0.000" Unit="m"/>
        <ThunderstormIntensity Value="0.000" Unit="(0 - 1)"/>
