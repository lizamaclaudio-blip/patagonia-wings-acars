            <CloudLayerAltitudeBot Value="457.200" Unit="m"/>
            <CloudLayerAltitudeTop Value="1200.000" Unit="m"/>
            <CloudLayerScattering Value="0.800" Unit="(0 - 1)"/>
        </CloudLayer>
        <CloudLayer>
            <CloudLayerDensity Value="4.000" Unit="(0 - 1)"/>
            <CloudLayerCoverage Value="0.500" Unit="(0 - 1)"/>
            <CloudLayerAltitudeBot Value="3000.000" Unit="m"/>
            <CloudLayerAltitudeTop Value="5000.000" Unit="m"/>
            <CloudLayerScattering Value="0.600" Unit="(0 - 1)"/>
        </CloudLayer>
        <CloudLayer>
            <CloudLayerDensity Value="1.000" Unit="(0 - 1)"/>
            <CloudLayerCoverage Value="0.000" Unit="(0 - 1)"/>
            <CloudLayerAltitudeBot Value="9000.000" Unit="m"/>
            <CloudLayerAltitudeTop Value="9500.000" Unit="m"/>
            <CloudLayerScattering Value="0.000" Unit="(0 - 1)"/>
        </CloudLayer>
        <!-- Viento montañoso variable con turbulencia -->
        <WindLayer>
            <WindLayerAltitude Value="0.000" Unit="m"/>
