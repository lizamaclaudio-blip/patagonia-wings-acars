        "ias",
        "gs",
        "route_distance",
        "fuel",
        "pause",
        "sim_rate_if_available"
      ]
    },
    {
      "phase": "DESCENT_APPROACH",
      "measure": [
        "vs",
        "ias_below_10000",
        "landing_lights_if_supported",
        "gear_if_supported",
        "flaps",
        "qnh_dest",
        "stabilized_approach_input"
      ]
    },
    {
      "phase": "LANDING",
      "measure": [
        "touchdown_on_ground_transition",
        "landing_vs",
        "landing_g",
        "ias",
        "pitch",
        "bank",
        "wind",
        "lat_lon"
      ]
    },
    {
      "phase": "TAXI_IN_GATE",
      "measure": [
        "runway_exit_inferred",
        "taxi_speed",
        "lights",
        "xpdr_standby_if_supported",
        "parking_brake_on",
        "engines_off",
        "doors_if_supported",
        "fuel_end"
      ]
    }
  ],
